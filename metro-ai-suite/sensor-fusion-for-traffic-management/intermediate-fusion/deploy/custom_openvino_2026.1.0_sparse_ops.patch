+namespace ov::intel_cpu::node {
+
+bool SparseToDense::isSupportedOperation(const std::shared_ptr<const ov::Node>& op,
+                                         std::string& errorMessage) noexcept {
+    try {
+        if (op->get_type_info() != ov::op::v15::SparseToDense::get_type_info_static()) {
+            errorMessage = "Only SparseToDense operation from opset15 is supported by the CPU plugin.";
+            return false;
+        }
+    } catch (...) {
+        return false;
+    }
+    return true;
+}
+
+SparseToDense::SparseToDense(const std::shared_ptr<ov::Node>& op, const GraphContext::CPtr& context)
+    : Node(op, context, NgraphShapeInferFactory(op)) {
+    std::string errorMessage;
+    if (!isSupportedOperation(op, errorMessage)) {
+        OPENVINO_THROW_NOT_IMPLEMENTED(errorMessage);
+    }
+
+    const auto sparse = std::dynamic_pointer_cast<const ov::op::v15::SparseToDense>(op);
+    m_attr_spatial_shape = sparse->get_spatial_shape();
+    m_attr_batch_size = sparse->get_batch_size();
+    m_channels_first = sparse->get_channels_first();
+    m_flatten_output = sparse->get_flatten_output();
+}
+
+void SparseToDense::getSupportedDescriptors() {
+    const auto edges = getParentEdges().size();
+    if (edges != 2 && edges != 4) {
+        CPU_NODE_THROW("has incorrect number of input edges: ", edges);
+    }
+    if (getChildEdges().empty()) {
+        CPU_NODE_THROW("has incorrect number of output edges.");
+    }
+}
+
+void SparseToDense::initSupportedPrimitiveDescriptors() {
+    if (!supportedPrimitiveDescriptors.empty())
+        return;
+
+    auto features_prc = getOriginalInputPrecisionAtPort(FEATURES_IDX);
+    auto indices_prc = getOriginalInputPrecisionAtPort(INDICES_IDX);
+
+    if (features_prc != ov::element::f32 && features_prc != ov::element::f16) {
+        features_prc = ov::element::f32;
+    }
+    if (indices_prc != ov::element::i32 && indices_prc != ov::element::i64) {
+        indices_prc = ov::element::i32;
+    }
+
+    std::vector<PortConfigurator> in_configs{{LayoutType::ncsp, features_prc}, {LayoutType::ncsp, indices_prc}};
+    if (getParentEdges().size() == 4) {
+        auto spatial_prc = getOriginalInputPrecisionAtPort(SPATIAL_SHAPE_IDX);
+        auto batch_prc = getOriginalInputPrecisionAtPort(BATCH_SIZE_IDX);
+        if (spatial_prc != ov::element::i32 && spatial_prc != ov::element::i64)
+            spatial_prc = ov::element::i32;
+        if (batch_prc != ov::element::i32 && batch_prc != ov::element::i64)
+            batch_prc = ov::element::i32;
+        in_configs.push_back({LayoutType::ncsp, spatial_prc});
+        in_configs.push_back({LayoutType::ncsp, batch_prc});
+    }
+
+    addSupportedPrimDesc(in_configs, {{LayoutType::ncsp, features_prc}}, ref_any);
+}
+
+namespace {
+
+template <typename SrcT>
+int64_t read_int_value(const void* data, size_t i) {
+    return static_cast<int64_t>(reinterpret_cast<const SrcT*>(data)[i]);
+}
+
+int64_t read_int_at(const void* data, ov::element::Type prc, size_t i) {
+    if (prc == ov::element::i64)
+        return read_int_value<int64_t>(data, i);
+    return read_int_value<int32_t>(data, i);
+}
+
+}  // namespace
+
+template <typename T, typename IdxT>
+void SparseToDense::executeImpl() {
+    const auto& cpu_parallel = context->getCpuParallel();
+
+    const auto& features_mem = getSrcMemoryAtPort(FEATURES_IDX);
+    const auto& indices_mem = getSrcMemoryAtPort(INDICES_IDX);
+    const auto& output_mem = getDstMemoryAtPort(0);
+
+    const auto* features = getSrcDataAtPortAs<const T>(FEATURES_IDX);
+    const auto* indices = getSrcDataAtPortAs<const IdxT>(INDICES_IDX);
+    auto* output = getDstDataAtPortAs<T>(0);
+
+    const auto& features_dims = features_mem->getStaticDims();
+    OPENVINO_ASSERT(features_dims.size() == 2, "SparseToDense expects features to be rank-2");
+    const auto num_points = features_dims[0];
+    const auto channels = features_dims[1];
+
+    std::vector<int64_t> spatial_shape = m_attr_spatial_shape;
+    int64_t batch_size = m_attr_batch_size;
+    if (getParentEdges().size() == 4) {
+        const auto& spatial_mem = getSrcMemoryAtPort(SPATIAL_SHAPE_IDX);
+        const auto& batch_mem = getSrcMemoryAtPort(BATCH_SIZE_IDX);
+        const auto spatial_prc = spatial_mem->getDesc().getPrecision();
+        const auto batch_prc = batch_mem->getDesc().getPrecision();
+        const auto spatial_count = spatial_mem->getShape().getElementsCount();
+        if (spatial_count == 3) {
+            spatial_shape.resize(3);
+            for (size_t i = 0; i < 3; ++i)
+                spatial_shape[i] = read_int_at(spatial_mem->getData(), spatial_prc, i);
+        }
+        if (batch_mem->getShape().getElementsCount() >= 1) {
+            batch_size = read_int_at(batch_mem->getData(), batch_prc, 0);
+        }
+    }
+
+    OPENVINO_ASSERT(spatial_shape.size() == 3, "SparseToDense requires spatial_shape with 3 elements");
+    OPENVINO_ASSERT(batch_size > 0, "SparseToDense requires positive batch_size");
+
+    const auto out_count = output_mem->getShape().getElementsCount();
+    std::memset(output, 0, out_count * sizeof(T));
+
+    const auto depth = static_cast<size_t>(spatial_shape[0]);
+    const auto height = static_cast<size_t>(spatial_shape[1]);
+    const auto width = static_cast<size_t>(spatial_shape[2]);
+    const auto channel_plane = depth * height * width;
+    const auto batch_us = static_cast<size_t>(batch_size);
+    const bool channels_first = m_channels_first;
+    const bool flatten_output = m_flatten_output;
+
+    cpu_parallel->parallel_for(num_points, [&](size_t point) {
+        const auto* row = indices + point * 4;
+        const auto batch_idx = static_cast<int64_t>(row[0]);
+        const auto z = static_cast<int64_t>(row[1]);
+        const auto y = static_cast<int64_t>(row[2]);
+        const auto x = static_cast<int64_t>(row[3]);
+
+        if (batch_idx < 0 || static_cast<size_t>(batch_idx) >= batch_us)
+            return;
+        if (z < 0 || static_cast<size_t>(z) >= depth)
+            return;
+        if (y < 0 || static_cast<size_t>(y) >= height)
+            return;
+        if (x < 0 || static_cast<size_t>(x) >= width)
+            return;
+
+        const auto* src = features + point * channels;
+        const auto b = static_cast<size_t>(batch_idx);
+
+        if (flatten_output) {
+            // [B, C*X, Z, Y]; channels_first is enforced upstream
+            const auto x_us = static_cast<size_t>(x);
+            for (size_t channel = 0; channel < channels; ++channel) {
+                const auto out_channel = channel * width + x_us;
+                const auto offset = ((b * channels * width + out_channel) * depth + z) * height + y;
+                output[offset] = src[channel];
+            }
+        } else if (channels_first) {
+            // [B, C, Z, Y, X]
+            const auto spatial_offset = (static_cast<size_t>(z) * height + y) * width + x;
+            const auto base = b * channels * channel_plane + spatial_offset;
+            for (size_t channel = 0; channel < channels; ++channel) {
+                output[base + channel * channel_plane] = src[channel];
+            }
+        } else {
+            // [B, Z, Y, X, C]
+            const auto offset = (((b * depth + z) * height + y) * width + x) * channels;
+            std::copy(src, src + channels, output + offset);
+        }
+    });
+}
+
+void SparseToDense::execute([[maybe_unused]] const dnnl::stream& strm) {
+    const auto features_prc = getSrcMemoryAtPort(FEATURES_IDX)->getDesc().getPrecision();
+    const auto indices_prc = getSrcMemoryAtPort(INDICES_IDX)->getDesc().getPrecision();
+
+    if (features_prc == ov::element::f16) {
+        if (indices_prc == ov::element::i64)
+            executeImpl<ov::float16, int64_t>();
+        else
+            executeImpl<ov::float16, int32_t>();
+    } else {
+        if (indices_prc == ov::element::i64)
+            executeImpl<float, int64_t>();
+        else
+            executeImpl<float, int32_t>();
+    }
+}
+
+void SparseToDense::executeDynamicImpl(const dnnl::stream& strm) {
+    execute(strm);
+}
+
+bool SparseToDense::created() const {
+    return getType() == Type::SparseToDense;
+}
+
+}  // namespace ov::intel_cpu::node
