+static constexpr int XMX_I8_SG_SIZE = 16;
+static constexpr int XMX_I8_TM = 8;
+static constexpr int XMX_I8_TN = 16;
+static constexpr int XMX_I8_TK = 32;
+static constexpr int XMX_I8_TILE_M = XMX_I8_TM * 4;
+static constexpr int XMX_I8_TILE_N = XMX_I8_TN * 2;
+static constexpr int XMX_I8_TILE_K = XMX_I8_TK;
+static constexpr int XMX_I8_NUM_SG = 8;
+static constexpr int XMX_I8_SKEW = 8;
+static constexpr int SLM_I8_IN_STRIDE = XMX_I8_TILE_K + XMX_I8_SKEW;
+static constexpr int SLM_I8_WT_STRIDE = XMX_I8_TILE_N + XMX_I8_SKEW;
+static constexpr int SLM_I8_IN_BUF_SIZE = XMX_I8_TILE_M * SLM_I8_IN_STRIDE;
+static constexpr int SLM_I8_WT_BUF_SIZE = XMX_I8_TILE_K * SLM_I8_WT_STRIDE;
+
+static constexpr int XMX_I8_TILE_N_WIDE = XMX_I8_TN * 4;
+static constexpr int XMX_I8_NUM_SG_WIDE = 16;
+static constexpr int SLM_I8_WT_STRIDE_WIDE = XMX_I8_TILE_N_WIDE + XMX_I8_SKEW;
+static constexpr int SLM_I8_WT_BUF_SIZE_WIDE = XMX_I8_TILE_K * SLM_I8_WT_STRIDE_WIDE;
+
+static inline void load_int8_input_tile_to_slm(::sycl::local_accessor<int8_t, 1>& slm_input,
+                                               int slm_base,
+                                               int local_id,
+                                               int out_row_start,
+                                               int M,
+                                               int K,
+                                               int k_vol,
+                                               int kernel_idx,
+                                               int k_offset_in_kernel,
+                                               const int8_t* __restrict__ in_feats,
+                                               const int32_t* __restrict__ out_in_map) {
+    const int assigned_row = local_id / 4;
+    const int col_start = (local_id % 4) * 8;
+    if (assigned_row >= XMX_I8_TILE_M)
+        return;
+
+    const int global_row = out_row_start + assigned_row;
+    const int slm_row_base = slm_base + assigned_row * SLM_I8_IN_STRIDE;
+    int map_idx = -1;
+    if (global_row < M)
+        map_idx = out_in_map[global_row * k_vol + kernel_idx];
+
+    const int k_start = k_offset_in_kernel + col_start;
+    if (map_idx >= 0 && col_start + 8 <= XMX_I8_TILE_K && k_start + 8 <= K) {
+        using char8 = ::sycl::vec<int8_t, 8>;
+        const int8_t* src = in_feats + static_cast<int64_t>(map_idx) * K + k_start;
+        char8 v;
+        v.load(0,
+               ::sycl::address_space_cast<::sycl::access::address_space::global_space,
+                                          ::sycl::access::decorated::no>(src));
+        for (int j = 0; j < 8; ++j)
+            slm_input[slm_row_base + col_start + j] = v[j];
+    } else {
+        for (int j = 0; j < 8; ++j) {
+            const int col = col_start + j;
+            int8_t value = 0;
+            if (col < XMX_I8_TILE_K) {
+                const int k_idx = k_offset_in_kernel + col;
+                if (map_idx >= 0 && k_idx < K)
+                    value = in_feats[static_cast<int64_t>(map_idx) * K + k_idx];
+            }
+            slm_input[slm_row_base + col] = value;
+        }
+    }
+}
+
+static inline void load_int8_weight_tile_to_slm(::sycl::local_accessor<int8_t, 1>& slm_weight,
+                                                int slm_base,
+                                                int local_id,
+                                                int out_col_start,
+                                                int K,
+                                                int N,
+                                                int kernel_idx,
+                                                int k_offset_in_kernel,
+                                                const int8_t* __restrict__ weights) {
+    const int k_row = local_id / 4;
+    const int n_base = (local_id % 4) * 8;
+    if (k_row >= XMX_I8_TILE_K)
+        return;
+
+    const int global_k = k_offset_in_kernel + k_row;
+    const int global_n = out_col_start + n_base;
+    int8_t* slm_ptr = &slm_weight[slm_base + k_row * SLM_I8_WT_STRIDE + n_base];
+    if (global_k < K && global_n + 8 <= N && n_base + 8 <= XMX_I8_TILE_N) {
+        using char8 = ::sycl::vec<int8_t, 8>;
+        const int8_t* src = weights + static_cast<int64_t>(kernel_idx) * K * N + static_cast<int64_t>(global_k) * N + global_n;
+        char8 v;
+        v.load(0,
+               ::sycl::address_space_cast<::sycl::access::address_space::global_space,
+                                          ::sycl::access::decorated::no>(src));
+        for (int j = 0; j < 8; ++j)
+            slm_ptr[j] = v[j];
+    } else {
+        for (int j = 0; j < 8; ++j) {
+            const int n_idx = n_base + j;
+            int8_t value = 0;
+            if (global_k < K && n_idx < XMX_I8_TILE_N && out_col_start + n_idx < N) {
+                value = weights[static_cast<int64_t>(kernel_idx) * K * N + static_cast<int64_t>(global_k) * N + out_col_start + n_idx];
+            }
+            slm_ptr[j] = value;
+        }
+    }
+}
+
+static void conv_implicit_gemm_int8_xmx_kernel(::sycl::nd_item<2> item,
+                                               ::sycl::local_accessor<int8_t, 1> slm_input,
+                                               ::sycl::local_accessor<int8_t, 1> slm_weight,
+                                               ::sycl::local_accessor<int32_t, 1> slm_temp,
+                                               int M,
+                                               int K,
+                                               int N,
+                                               int k_vol,
+                                               const int8_t* __restrict__ in_feats,
+                                               const int8_t* __restrict__ weights,
+                                               const int32_t* __restrict__ out_in_map,
+                                               ::sycl::half* __restrict__ out_feats,
+                                               float act_abs_max,
+                                               const float* __restrict__ per_channel_weight_scale,
+                                               const ::sycl::half* __restrict__ bias,
+                                               bool apply_relu) {
+    auto sg = item.get_sub_group();
+    const int sg_id = sg.get_group_linear_id();
+    const int local_id = item.get_local_linear_id();
+    const int out_row_start = item.get_group(0) * XMX_I8_TILE_M;
+    const int out_col_start = item.get_group(1) * XMX_I8_TILE_N;
+    const int sg_row_start = out_row_start + (sg_id / 2) * XMX_I8_TM;
+    const int sg_col_start = out_col_start + (sg_id % 2) * XMX_I8_TN;
+
+    sycl_matrix::joint_matrix<::sycl::sub_group, int8_t, sycl_matrix::use::a,
+                              XMX_I8_TM, XMX_I8_TK, sycl_matrix::layout::row_major> sub_a;
+    sycl_matrix::joint_matrix<::sycl::sub_group, int8_t, sycl_matrix::use::b,
+                              XMX_I8_TK, XMX_I8_TN, sycl_matrix::layout::row_major> sub_b;
+    sycl_matrix::joint_matrix<::sycl::sub_group, int32_t, sycl_matrix::use::accumulator,
+                              XMX_I8_TM, XMX_I8_TN> sub_c;
+    sycl_matrix::joint_matrix_fill(sg, sub_c, 0);
+
+    const int K_tile_padded = ((K + XMX_I8_TILE_K - 1) / XMX_I8_TILE_K) * XMX_I8_TILE_K;
+    const int total_k_iters = (K_tile_padded * k_vol) / XMX_I8_TILE_K;
+    const int sg_slm_row = (sg_id / 2) * XMX_I8_TM;
+    const int sg_slm_col_b = (sg_id % 2) * XMX_I8_TN;
+
+    if (total_k_iters > 0) {
+        int cur_buf = 0;
+        load_int8_input_tile_to_slm(slm_input, 0, local_id, out_row_start, M, K, k_vol, 0, 0, in_feats, out_in_map);
+        load_int8_weight_tile_to_slm(slm_weight, 0, local_id, out_col_start, K, N, 0, 0, weights);
+
+        for (int k_iter = 0; k_iter < total_k_iters; ++k_iter) {
+            item.barrier(::sycl::access::fence_space::local_space);
+            const int in_base = cur_buf * SLM_I8_IN_BUF_SIZE;
+            const int wt_base = cur_buf * SLM_I8_WT_BUF_SIZE;
+            const int next_buf = 1 - cur_buf;
+
+            if (k_iter + 1 < total_k_iters) {
+                const int next_iter = k_iter + 1;
+                const int next_kernel_idx = next_iter * XMX_I8_TILE_K / K_tile_padded;
+                const int next_k_offset = (next_iter * XMX_I8_TILE_K) % K_tile_padded;
+                load_int8_input_tile_to_slm(slm_input,
+                                            next_buf * SLM_I8_IN_BUF_SIZE,
+                                            local_id,
+                                            out_row_start,
+                                            M,
+                                            K,
+                                            k_vol,
+                                            next_kernel_idx,
+                                            next_k_offset,
+                                            in_feats,
+                                            out_in_map);
+                load_int8_weight_tile_to_slm(slm_weight,
+                                             next_buf * SLM_I8_WT_BUF_SIZE,
+                                             local_id,
+                                             out_col_start,
+                                             K,
+                                             N,
+                                             next_kernel_idx,
+                                             next_k_offset,
+                                             weights);
+            }
+
+            sycl_matrix::joint_matrix_load(sg,
+                                           sub_a,
+                                           slm_input.template get_multi_ptr<::sycl::access::decorated::no>() +
+                                               in_base + sg_slm_row * SLM_I8_IN_STRIDE,
+                                           SLM_I8_IN_STRIDE);
+            sycl_matrix::joint_matrix_load(sg,
+                                           sub_b,
+                                           slm_weight.template get_multi_ptr<::sycl::access::decorated::no>() + wt_base + sg_slm_col_b,
+                                           SLM_I8_WT_STRIDE);
+            sycl_matrix::joint_matrix_mad(sg, sub_c, sub_a, sub_b, sub_c);
+            cur_buf = next_buf;
+        }
+    }
+
+    constexpr int elements_per_sg = XMX_I8_TM * XMX_I8_TN;
+    int32_t* temp_c = slm_temp.get_multi_ptr<::sycl::access::decorated::no>().get_raw() + sg_id * elements_per_sg;
+    auto temp_c_ptr = ::sycl::address_space_cast<::sycl::access::address_space::local_space,
+                                                 ::sycl::access::decorated::no>(temp_c);
+    sycl_matrix::joint_matrix_store(sg, sub_c, temp_c_ptr, XMX_I8_TN, sycl_matrix::layout::row_major);
+
+    if (act_abs_max < 1e-8f)
+        act_abs_max = 1e-8f;
+    const float act_scale = act_abs_max / 127.0f;
+    float wscale_cache[XMX_I8_TN];
+    float bias_cache[XMX_I8_TN];
+    for (int j = 0; j < XMX_I8_TN; ++j) {
+        const int gc = sg_col_start + j;
+        wscale_cache[j] = (gc < N) ? per_channel_weight_scale[gc] : 0.0f;
+        bias_cache[j] = (gc < N && bias) ? static_cast<float>(bias[gc]) : 0.0f;
+    }
+
+    const int sg_local_id = static_cast<int>(sg.get_local_id()[0]);
+    constexpr int elems_per_thread = elements_per_sg / XMX_I8_SG_SIZE;
+    const int flat_start = sg_local_id * elems_per_thread;
+    for (int i = 0; i < elems_per_thread; ++i) {
+        const int flat = flat_start + i;
+        const int row = flat / XMX_I8_TN;
+        const int col = flat % XMX_I8_TN;
+        const int global_row = sg_row_start + row;
+        const int global_col = sg_col_start + col;
+        if (global_row < M && global_col < N) {
+            const int64_t out_idx = static_cast<int64_t>(global_row) * N + global_col;
+            float value = static_cast<float>(temp_c[flat]) * act_scale * wscale_cache[col] + bias_cache[col];
+            if (apply_relu && value < 0.0f)
+                value = 0.0f;
+            out_feats[out_idx] = static_cast<::sycl::half>(value);
+        }
+    }
+}
