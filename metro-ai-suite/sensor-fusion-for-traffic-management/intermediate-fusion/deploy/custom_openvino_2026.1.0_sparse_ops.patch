+
+namespace ov::intel_gpu {
+namespace {
+
+std::shared_ptr<ov::op::v0::Constant> as_range_constant(const ov::Output<ov::Node>& input) {
+    auto node = input.get_node_shared_ptr();
+    while (ov::is_type<ov::op::v0::Convert>(node)) {
+        if (node->get_input_size() == 0)
+            return nullptr;
+        node = node->get_input_node_shared_ptr(0);
+    }
+    return ov::as_type_ptr<ov::op::v0::Constant>(node);
+}
+
+float abs_max_from_constant(const std::shared_ptr<ov::op::v0::Constant>& constant) {
+    if (!constant)
+        return 0.0f;
+
+    const auto values = constant->cast_vector<float>();
+    float abs_max = 0.0f;
+    for (const auto value : values)
+        abs_max = std::max(abs_max, std::fabs(value));
+    return abs_max;
+}
+
+template <typename SparseConvType>
+bool set_input_abs_max_from_fake_quantize(ov::pass::pattern::Matcher& matcher) {
+    auto sparse_conv = ov::as_type_ptr<SparseConvType>(matcher.get_match_root());
+    if (!sparse_conv || sparse_conv->get_input_abs_max() > 0.0f)
+        return false;
+
+    auto fake_quantize = ov::as_type_ptr<ov::op::v0::FakeQuantize>(sparse_conv->input_value(0).get_node_shared_ptr());
+    if (!fake_quantize || fake_quantize->get_levels() != 256)
+        return false;
+
+    const auto low = abs_max_from_constant(as_range_constant(fake_quantize->input_value(3)));
+    const auto high = abs_max_from_constant(as_range_constant(fake_quantize->input_value(4)));
+    const auto abs_max = std::max(low, high);
+    if (!(abs_max > 0.0f))
+        return false;
+
+    sparse_conv->set_input_abs_max(abs_max);
+    return false;
+}
+
+}  // namespace
+
+EatSparseConvolutionInputFakeQuantize::EatSparseConvolutionInputFakeQuantize() {
+    auto sparse_conv = ov::pass::pattern::wrap_type<ov::op::v15::SparseConvolution>();
+
+    matcher_pass_callback callback = [](ov::pass::pattern::Matcher& matcher) {
+        return set_input_abs_max_from_fake_quantize<ov::op::v15::SparseConvolution>(matcher);
+    };
+
+    auto matcher = std::make_shared<ov::pass::pattern::Matcher>(sparse_conv, "EatSparseConvolutionInputFakeQuantize");
+    register_matcher(matcher, callback);
+
+}
+
+}  // namespace ov::intel_gpu
