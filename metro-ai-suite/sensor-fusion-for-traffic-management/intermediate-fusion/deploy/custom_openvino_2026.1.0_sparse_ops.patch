diff --git a/src/plugins/intel_gpu/src/graph/sparse_convolution.cpp b/src/plugins/intel_gpu/src/graph/sparse_convolution.cpp
new file mode 100644
index 0000000000..5ca7dfdf80
--- /dev/null
+++ b/src/plugins/intel_gpu/src/graph/sparse_convolution.cpp
@@ -0,0 +1,153 @@
+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#include "sparse_convolution_inst.h"
+
+#include "intel_gpu/runtime/memory.hpp"
+#include "json_object.h"
+#include "openvino/reference/sparse_convolution.hpp"
+#include "primitive_type_base.h"
+
+#include <array>
+#include <sstream>
+#include <type_traits>
+
+namespace cldnn {
+GPU_DEFINE_PRIMITIVE_TYPE_ID(sparse_convolution)
+
+namespace {
+
+std::array<int64_t, 3> to_array3(const std::vector<int64_t>& values) {
+    return {{values[0], values[1], values[2]}};
+}
+
+bool try_get_actual_output_points(const sparse_convolution& primitive,
+                                  const kernel_impl_params& impl_param,
+                                  size_t& actual_output_points) {
+    if (primitive.subm || primitive.output_bound > 0 || impl_param.memory_deps.count(1) == 0)
+        return false;
+
+    if (primitive.input_spatial_shape.size() != 3 || primitive.kernel_size.size() != 3 ||
+        primitive.stride.size() != 3 || primitive.padding.size() != 3 || primitive.dilation.size() != 3)
+        return false;
+
+    const auto indices_values = read_vector<int64_t>(impl_param.memory_deps.at(1), impl_param.get_stream());
+    if (indices_values.size() % 4 != 0)
+        return false;
+    if (indices_values.empty()) {
+        actual_output_points = 0;
+        return true;
+    }
+
+    ov::reference::SparseConvolutionMetadata metadata;
+    std::array<int64_t, 3> explicit_output_spatial_shape = {0, 0, 0};
+    if (primitive.output_spatial_shape.size() == 3)
+        explicit_output_spatial_shape = to_array3(primitive.output_spatial_shape);
+
+    if (!ov::reference::compute_sparse_convolution_metadata(indices_values.data(),
+                                                       indices_values.size() / 4,
+                                                       4,
+                                                       to_array3(primitive.input_spatial_shape),
+                                                       to_array3(primitive.kernel_size),
+                                                       to_array3(primitive.stride),
+                                                       to_array3(primitive.padding),
+                                                       to_array3(primitive.dilation),
+                                                       false,
+                                                       metadata,
+                                                       explicit_output_spatial_shape)) {
+        return false;
+    }
+
+    actual_output_points = metadata.num_points();
+    return true;
+}
+
+}  // namespace
+
+sparse_convolution_inst::typed_primitive_inst(network& network, sparse_convolution_node const& node) : parent(network, node) {}
+
+layout sparse_convolution_inst::calc_output_layout(sparse_convolution_node const& node, const kernel_impl_params& impl_param) {
+    return calc_output_layouts<ov::PartialShape>(node, impl_param)[0];
+}
+
+template <typename ShapeType>
+std::vector<layout> sparse_convolution_inst::calc_output_layouts(sparse_convolution_node const& node,
+                                                            const kernel_impl_params& impl_param) {
+    auto primitive = impl_param.typed_desc<sparse_convolution>();
+    const auto& input_layout = impl_param.get_input_layout(0);  // features [M_in, C_in]
+    const auto& weight_layout = impl_param.get_input_layout(2);
+    const auto& weight_shape = weight_layout.get_partial_shape();
+
+    // Determine output channels
+    ov::Dimension output_channels = ov::Dimension::dynamic();
+    if (primitive->out_channels > 0) {
+        output_channels = static_cast<int64_t>(primitive->out_channels);
+    } else if (weight_shape.rank().is_static() && weight_shape.rank().get_length() >= 3) {
+        output_channels = weight_shape[2];
+    }
+
+    ShapeType feat_shape;
+    ShapeType coord_shape;
+    size_t actual_output_points = 0;
+    const bool has_actual_output_points = try_get_actual_output_points(*primitive, impl_param, actual_output_points);
+
+    if constexpr (std::is_same_v<ShapeType, ov::PartialShape>) {
+        const auto input_shape = input_layout.get<ShapeType>();
+        ov::Dimension m_out;
+        if (primitive->subm) {
+            // SubMConv: M_out == M_in
+            m_out = (input_shape.rank().is_static() && input_shape.rank().get_length() > 0)
+                        ? input_shape[0]
+                        : ov::Dimension::dynamic();
+        } else if (primitive->output_bound > 0) {
+            // SparseConv with output_bound: pre-allocate buffer of specified size.
+            m_out = ov::Dimension(static_cast<int64_t>(primitive->output_bound));
+        } else if (has_actual_output_points) {
+            m_out = ov::Dimension(static_cast<int64_t>(actual_output_points));
+        } else {
+            // SparseConv stride>1: use M_in as initial allocation size.
+            m_out = (input_shape.rank().is_static() && input_shape.rank().get_length() > 0)
+                        ? input_shape[0]
+                        : ov::Dimension::dynamic();
+        }
+        feat_shape = ShapeType{m_out, output_channels};
+        coord_shape = ShapeType{m_out, 4};
+    } else {
+        const auto input_shape = input_layout.get<ShapeType>();
+        size_t m_out = (primitive->output_bound > 0 && !primitive->subm)
+                           ? static_cast<size_t>(primitive->output_bound)
+                       : (has_actual_output_points)
+                           ? actual_output_points
+                           : static_cast<size_t>(input_shape[0]);
+        size_t c_out = (primitive->out_channels > 0)
+                            ? static_cast<size_t>(primitive->out_channels)
+                            : (weight_shape.rank().is_static() && weight_shape[2].is_static()
+                                   ? static_cast<size_t>(weight_shape[2].get_length())
+                                   : 0);
+        feat_shape = ShapeType{m_out, c_out};
+        coord_shape = ShapeType{m_out, size_t{4}};
+    }
+
+    return {layout{feat_shape, input_layout.data_type, format::bfyx},
+            layout{coord_shape, data_types::i32, format::bfyx}};
+}
+
+template std::vector<layout> sparse_convolution_inst::calc_output_layouts<ov::PartialShape>(
+    sparse_convolution_node const& node,
+    const kernel_impl_params& impl_param);
+
+std::string sparse_convolution_inst::to_string(sparse_convolution_node const& node) {
+    auto node_info = node.desc_to_json();
+    auto desc = node.get_primitive();
+    json_composite info;
+    info.add("subm", desc->subm);
+    info.add("out_channels", desc->out_channels);
+    info.add("output_bound", desc->output_bound);
+    node_info->add("sparse_convolution info", info);
+    std::stringstream ss;
+    node_info->dump(ss);
+    return ss.str();
+}
+
+}  // namespace cldnn
