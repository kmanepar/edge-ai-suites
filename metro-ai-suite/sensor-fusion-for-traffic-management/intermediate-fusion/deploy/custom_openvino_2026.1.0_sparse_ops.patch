+// ===== Main SYCL implementation wrapping ov_minuet::Minuet =====
+
+struct sparse_convolution_sycl : public typed_primitive_sycl_impl<sparse_convolution> {
+    using parent = typed_primitive_sycl_impl<sparse_convolution>;
+    using parent::parent;
+
+    std::shared_ptr<::sycl::context> fallback_context;
+    std::shared_ptr<::sycl::queue> fallback_queue;
+    void* fallback_queue_handle = nullptr;
+
+    memory::ptr cached_feature_staging;
+    memory::ptr cached_indices_staging;
+    memory::ptr cached_weight_staging;
+    memory::ptr cached_bias_staging;
+    memory::ptr cached_output_features_staging;
+    memory::ptr cached_output_indices_staging;
+
+    memory::ptr cached_ordered_point_indices;
+    memory::ptr cached_batch_of_point;
+    memory::ptr cached_output_batch_of_point;
+    memory::ptr cached_batch_ids;
+    memory::ptr cached_input_coords_xyz;
+
+    // P1: single-batch fast path — skip batch ID extraction when we've already
+    // confirmed single-batch and the input shape hasn't grown.
+    bool batch_analysis_done = false;
+    size_t batch_analysis_N = 0;
+    // Compute path uses fp16 throughout (v2 minuet is fp16-only).
+    // f32 inputs are promoted via these staging buffers.
+    memory::ptr cached_output_coords_xyz;
+    memory::ptr cached_input_features_f16;
+    memory::ptr cached_output_features_f16;
+    memory::ptr cached_weight_xyz_f16;  // post-XYZ-reorder weights, f16 data
+    memory::ptr cached_bias_f16;        // demoted f32 bias (only used on f32 path)
+    memory::ptr cached_input_i8;
+    memory::ptr cached_weight_i8;
+    memory::ptr cached_weight_packed_i8;
+    memory::ptr cached_weight_scale_f32;
+
+    // Unified fp16 path: deeply-optimized MinuetV2 (XMX VNNI + rulebook reuse).
+    // FP32 inputs are promoted to fp16 internally (via fp16 staging buffers)
+    // to keep a single optimized accumulator path.
+    std::unique_ptr<ov_minuet::MinuetV2> minuet_instance_v2;
+    int cached_ic = 0;
+    int cached_oc = 0;
+    std::vector<int64_t> cached_kernel_size;
+    bool cached_allow_esimd_sort = false;
+    data_types cached_compute_data_type = data_types::f32;
+    void* cached_queue_identity = nullptr;
+    const void* cached_weight_staging_source_buffer = nullptr;
+    const void* cached_bias_staging_source_buffer = nullptr;
+    const void* cached_weight_buffer = nullptr;
+    const void* cached_weight_source_buffer = nullptr;
+    const void* cached_bias_source_buffer = nullptr;
+    const void* cached_int8_weight_source_buffer = nullptr;
+    int cached_int8_weight_kernel_volume = 0;
+    int cached_int8_weight_input_channels = 0;
+    int cached_int8_weight_output_channels = 0;
+    int cached_int8_weight_input_channels_padded = 0;
+    int cached_int8_weight_output_channels_padded = 0;
+    ::sycl::event last_completion_event;
+    bool has_last_completion_event = false;
+    std::vector<int32_t> cached_batch_ids_host;
+    std::vector<size_t> cached_segment_offsets;
+    bool cached_single_batch = false;
+    int32_t cached_single_batch_id = 0;
+
+    mutable std::mutex execute_mutex;
+
+    DECLARE_OBJECT_TYPE_SERIALIZATION(cldnn::sycl::sparse_convolution_sycl)
+
+    sparse_convolution_sycl(const sparse_convolution_sycl& other)
+        : parent(other),
+          fallback_context(nullptr),
+          fallback_queue(nullptr),
+          fallback_queue_handle(nullptr),
+          minuet_instance_v2(nullptr),
+          cached_ic(0),
+          cached_oc(0),
+          cached_allow_esimd_sort(false),
+          cached_compute_data_type(data_types::f32),
+          cached_queue_identity(nullptr),
+          cached_weight_staging_source_buffer(nullptr),
+          cached_bias_staging_source_buffer(nullptr),
+          cached_weight_buffer(nullptr),
+          cached_weight_source_buffer(nullptr),
+          cached_bias_source_buffer(nullptr),
+          cached_int8_weight_source_buffer(nullptr),
+          cached_int8_weight_kernel_volume(0),
+          cached_int8_weight_input_channels(0),
+          cached_int8_weight_output_channels(0),
+          cached_int8_weight_input_channels_padded(0),
+          cached_int8_weight_output_channels_padded(0),
+          has_last_completion_event(false),
+          cached_single_batch(false),
+          cached_single_batch_id(0) {}
+
+    sparse_convolution_sycl() = default;
+
+    ~sparse_convolution_sycl() override {
+        if (has_last_completion_event) {
+            last_completion_event.wait();
+            has_last_completion_event = false;
+        }
+        erase_minuet_subm_rulebook_cache_owner(this);
+    }
+
+    std::unique_ptr<primitive_impl> clone() const override {
+        return std::make_unique<sparse_convolution_sycl>(*this);
+    }
+
+    static allocation_type get_staging_usm_type(engine& engine) {
+        if (engine.supports_allocation(allocation_type::usm_device))
+            return allocation_type::usm_device;
+        if (engine.supports_allocation(allocation_type::usm_shared))
+            return allocation_type::usm_shared;
+        return allocation_type::usm_host;
+    }
+
+    static bool can_use_minuet_esimd(const cldnn::device_info& info) {
+        // Upstream Minuet ESIMD radix sort runs on Arc-class devices, but the
+        // same kernel compilation fails on XeLP (for example UHD 770) on both
+        // Level Zero and OpenCL backends with unsupported SLM/LSC intrinsics.
+        return info.arch != gpu_arch::unknown && info.arch != gpu_arch::xe_lp;
+    }
+
+    static memory::ptr ensure_usm(memory::ptr mem,
+                                  memory::ptr& cached_staging,
+                                  stream& stream,
+                                  engine& engine,
+                                  bool is_output,
+                                  bool blocking) {
+        OPENVINO_ASSERT(mem != nullptr, "SparseConvolution SYCL: null memory");
+        if (memory_capabilities::is_usm_type(mem->get_allocation_type()))
+            return mem;
+
+        const auto required_usm_type = get_staging_usm_type(engine);
+        if (cached_staging == nullptr ||
+            cached_staging->get_layout() != mem->get_layout() ||
+            cached_staging->get_allocation_type() != required_usm_type) {
+            cached_staging = engine.allocate_memory(mem->get_layout(), required_usm_type, false);
+        }
+
+        if (!is_output)
+            cached_staging->copy_from(stream, *mem, blocking);
+        return cached_staging;
+    }
+
+    static memory::ptr ensure_usm(memory::ptr mem,
+                                  memory::ptr& cached_staging,
+                                  const void*& cached_source_buffer,
+                                  stream& stream,
+                                  engine& engine,
+                                  bool is_output,
+                                  bool blocking,
+                                  bool source_is_immutable) {
+        OPENVINO_ASSERT(mem != nullptr, "SparseConvolution SYCL: null memory");
+        if (memory_capabilities::is_usm_type(mem->get_allocation_type()))
+            return mem;
+
+        const auto required_usm_type = get_staging_usm_type(engine);
+        bool staging_reallocated = false;
+        if (cached_staging == nullptr ||
+            cached_staging->get_layout() != mem->get_layout() ||
+            cached_staging->get_allocation_type() != required_usm_type) {
+            cached_staging = engine.allocate_memory(mem->get_layout(), required_usm_type, false);
+            staging_reallocated = true;
+        }
+
+        if (!is_output) {
+            const auto* source_buffer = mem->buffer_ptr();
+            const bool needs_copy = !source_is_immutable || staging_reallocated || cached_source_buffer != source_buffer;
+            if (needs_copy) {
+                cached_staging->copy_from(stream, *mem, blocking);
+                cached_source_buffer = source_buffer;
+            }
+        }
+
+        return cached_staging;
+    }
+
+    static memory::ptr ensure_temp_buffer(memory::ptr& cached_buffer,
+                                          engine& engine,
+                                          allocation_type usm_type,
+                                          const ov::Shape& shape,
+                                          data_types data_type) {
+        const layout required_layout{shape, data_type, format::get_default_format(shape.size())};
+        if (cached_buffer == nullptr ||
+            cached_buffer->get_layout() != required_layout ||
+            cached_buffer->get_allocation_type() != usm_type) {
+            cached_buffer = engine.allocate_memory(required_layout, usm_type, false);
+        }
+        return cached_buffer;
+    }
+
+    std::pair<::sycl::queue*, void*> get_sycl_queue(ocl::ocl_stream& ov_stream, engine& engine) {
+        if (auto* native = dynamic_cast<ocl::sycl_stream*>(&ov_stream)) {
+            auto* queue = &native->get_sycl_queue();
+            return {queue, static_cast<void*>(queue)};
+        }
+
+        auto& ocl_engine = downcast<ocl::ocl_engine>(engine);
+        auto current = static_cast<void*>(ov_stream.get_cl_queue().get());
+        if (!fallback_queue || fallback_queue_handle != current) {
+            fallback_context = std::make_shared<::sycl::context>(
+                ::sycl::make_context<::sycl::backend::opencl>(ocl_engine.get_cl_context().get()));
+            fallback_queue = std::make_shared<::sycl::queue>(
+                ::sycl::make_queue<::sycl::backend::opencl>(ov_stream.get_cl_queue().get(), *fallback_context));
+            fallback_queue_handle = current;
+        }
+        return {fallback_queue.get(), current};
+    }
+
+    event::ptr execute_impl(const std::vector<event::ptr>& events,
+                            typed_primitive_inst<sparse_convolution>& instance) override {
+        auto& network = instance.get_network();
+        auto& ov_stream = downcast<ocl::ocl_stream>(network.get_stream());
+        auto& engine = network.get_engine();
+        const auto desc = instance.get_typed_desc<sparse_convolution>();
+
+        const bool is_subm = desc->subm;
+        const bool fused_relu = is_relu_activation(desc->activation);
+        const bool weight_is_constant = instance.get_node().get_dependency(2).is_constant();
+        const bool bias_is_constant = instance.get_node().get_dependency(3).is_constant();
+        uint64_t rulebook_generation = sparse_inference_generation.load(std::memory_order_relaxed);
+        if (desc->id == "lidar/conv0" || (desc->rulebook == "subm1" && desc->in_channels == 4 && desc->out_channels == 16)) {
+            rulebook_generation = sparse_inference_generation.fetch_add(1, std::memory_order_relaxed) + 1;
+            clear_sparse_actual_m();
+        }
+
+        ov_stream.wait_for_events(events);
+
+        const std::lock_guard<std::mutex> lock(execute_mutex);
+
+        auto queue_info = get_sycl_queue(ov_stream, engine);
+        auto* q = queue_info.first;
+        auto* queue_identity = queue_info.second;
+        const auto staging_usm_type = get_staging_usm_type(engine);
+        const auto allow_esimd_sort = can_use_minuet_esimd(engine.get_device_info());
+
+        if (has_last_completion_event) {
+            last_completion_event.wait_and_throw();
+            has_last_completion_event = false;
+        }
+
+        auto feature_mem = instance.input_memory_ptr(0);
+        auto indices_mem = instance.input_memory_ptr(1);
+        auto weight_mem = instance.input_memory_ptr(2);
+        auto bias_mem = instance.input_memory_ptr(3);
+        auto out_features_mem = instance.output_memory_ptr(0);
+        auto out_indices_mem = instance.output_memory_ptr(1);
+
+        feature_mem = ensure_usm(feature_mem, cached_feature_staging, ov_stream, engine, false, true);
+        weight_mem = ensure_usm(weight_mem,
+                    cached_weight_staging,
+                    cached_weight_staging_source_buffer,
+                    ov_stream,
+                    engine,
+                    false,
+                    true,
+                    weight_is_constant);
+        bias_mem = ensure_usm(bias_mem,
+                      cached_bias_staging,
+                      cached_bias_staging_source_buffer,
+                      ov_stream,
+                      engine,
+                      false,
+                      true,
+                      bias_is_constant);
+        auto kernel_out_features = ensure_usm(out_features_mem, cached_output_features_staging, ov_stream, engine, true, true);
+        auto kernel_out_indices = ensure_usm(out_indices_mem, cached_output_indices_staging, ov_stream, engine, true, true);
+        const bool has_output_staging = (kernel_out_features != out_features_mem) ||
+                        (kernel_out_indices != out_indices_mem);
+
+        const auto feature_shape = feature_mem->get_layout().get_shape();
+        OPENVINO_ASSERT(feature_shape.size() == 2);
+        auto N = static_cast<size_t>(feature_shape[0]);
+        auto IC = static_cast<size_t>(feature_shape[1]);
+        const auto input_feature_rows = N;
+        const auto input_indices_shape = indices_mem->get_layout().get_shape();
+        const auto input_indices_rows = input_indices_shape.size() > 0 ? static_cast<size_t>(input_indices_shape[0]) : 0;
+        const auto input_indices_channels = input_indices_shape.size() > 1 ? static_cast<size_t>(input_indices_shape[1]) : 0;
+
+        const auto weight_shape = weight_mem->get_layout().get_shape();
+        OPENVINO_ASSERT(weight_shape.size() == 3);
+        const auto kernel_volume = static_cast<size_t>(weight_shape[0]);
+        const auto expected_IC = static_cast<size_t>(weight_shape[1]);
+        const auto OC = static_cast<size_t>(weight_shape[2]);
+
+        // Override N with actual voxel count from predecessor's output, when
+        // available via sparse_actual_m_map. The map is keyed by the producer
+        // SparseConv's output buffer pointer; if OV's plugin feeds the same
+        // physical buffer to the consumer's input slot, the lookup hits.
+        //
+        // Safety: clamp the looked-up value to [1, current N] (the buffer-
+        // shape upper bound) — this protects against stale entries (from a
+        // freed buffer recycled by OV) that could hold a value larger than
+        // the current allocation and lead to OOB reads in batch analysis.
+        const size_t N_buffer_shape = input_indices_rows > 0 ? input_indices_rows : N;
+        int actual_input_m = 0;
+        const bool actual_input_m_hit = get_sparse_actual_m(indices_mem->buffer_ptr(), N_buffer_shape, actual_input_m, rulebook_generation);
+        if (actual_input_m_hit) {
+            N = static_cast<size_t>(actual_input_m);
+        }
+
+        bool repaired_input_shape = false;
+        if (!actual_input_m_hit && input_indices_rows > 0 && input_indices_channels >= 4 &&
+            (input_feature_rows != input_indices_rows || IC != expected_IC)) {
+            N = input_indices_rows;
+            IC = expected_IC;
+            repaired_input_shape = true;
+        } else if (actual_input_m_hit && IC != expected_IC) {
+            IC = expected_IC;
+            repaired_input_shape = true;
+        }
+
+        OPENVINO_ASSERT(IC == expected_IC,
+                        "SparseConvolution SYCL: feature channel count does not match weight input channels");
+        const bool unreliable_sparse_layout = repaired_input_shape ||
+            (actual_input_m_hit && input_indices_rows > 0 && input_feature_rows != input_indices_rows);
+
+        int32_t prepared_input_batch_id = 0;
+        auto prepared_input_coords_xyz_mem = find_prepared_single_batch_coords(indices_mem,
+                                                                               queue_identity,
+                                               rulebook_generation,
+                                                                               N,
+                                                                               prepared_input_batch_id);
+        if (!prepared_input_coords_xyz_mem) {
+            indices_mem = ensure_usm(indices_mem, cached_indices_staging, ov_stream, engine, false, true);
+        }
+
+        const auto& kernel_size_vec = desc->kernel_size;
+        const auto compute_data_type = feature_mem->get_layout().data_type;
+        // V2 minuet is fp16-only. fp32 inputs are promoted to fp16 internally.
+        const bool input_is_f16 = (compute_data_type == data_types::f16);
+        const bool input_is_f32 = (compute_data_type == data_types::f32);
+        OPENVINO_ASSERT(input_is_f16 || input_is_f32,
+                        "SparseConvolution SYCL: only f16 / f32 feature inputs are supported");
+
+        if (N == 0 || IC == 0 || OC == 0)
+            return nullptr;
+
+        const auto out_feature_shape = out_features_mem->get_layout().get_shape();
+        auto M = static_cast<size_t>(out_feature_shape[0]);
+        if (is_subm) {
+            M = N;
+        }
+        const size_t max_output_points = is_subm ? N : std::max(M, N * static_cast<size_t>(kernel_volume));
+        // V2 always computes in fp16. We can write the f16 result directly to
+        // the output buffer only if the output is f16; for f32 outputs we
+        // convert through an f16 staging buffer at the end.
+        const bool can_write_output_features_directly =
+            kernel_out_features->get_layout().data_type == data_types::f16;
+
+        const auto batch_fold_config = make_batch_fold_config(*desc);
+
+        const auto input_coords_xyz_mem = prepared_input_coords_xyz_mem
+            ? prepared_input_coords_xyz_mem
+            : ensure_temp_buffer(cached_input_coords_xyz,
+                                 engine,
+                                 staging_usm_type,
+                                 ov::Shape{N, 3},
+                                 data_types::i32);
+        // Reordered f16 input features (v2 input format). For f32 inputs we
+        // also use this buffer as the f16 promotion target.
+        const auto input_features_compute_mem = ensure_temp_buffer(cached_input_features_f16,
+                                                                   engine,
+                                                                   staging_usm_type,
+                                                                   ov::Shape{N, IC},
+                                                                   data_types::f16);
+        const auto output_coords_xyz_mem = ensure_temp_buffer(cached_output_coords_xyz,
+                                                              engine,
+                                                              staging_usm_type,
+                                                              ov::Shape{max_output_points, 3},
+                                                              data_types::i32);
+        // V2 always writes f16. If the output buffer is already f16 we hand it
+        // straight to v2; otherwise we use a f16 staging buffer and demote.
+        const auto output_features_compute_mem = can_write_output_features_directly
+            ? kernel_out_features
+            : ensure_temp_buffer(cached_output_features_f16,
+                                 engine,
+                                 staging_usm_type,
+                                 ov::Shape{max_output_points, OC},
+                                 data_types::f16);
+
+        // P1: single-batch fast path — if we previously confirmed single-batch,
+        // skip the expensive GPU kernel + D2H memcpy for batch ID extraction.
+        // Only re-analyze if N has changed (different input).
+        bool has_multiple_batches = false;
+        int32_t max_batch_id = 0;
+        bool can_use_folded_batch_path = false;
+
+        if (prepared_input_coords_xyz_mem) {
+            has_multiple_batches = false;
+            max_batch_id = prepared_input_batch_id;
+            batch_analysis_done = true;
+            batch_analysis_N = N;
+            cached_single_batch = true;
+            cached_single_batch_id = prepared_input_batch_id;
+            cached_segment_offsets = {0, N};
+        } else if (batch_analysis_done && cached_single_batch && N == batch_analysis_N) {
+            // Reuse previous single-batch result — no GPU work needed.
+            has_multiple_batches = false;
+            max_batch_id = cached_single_batch_id;
+        } else {
+            // Full batch analysis needed.
+            const auto batch_ids_mem = ensure_temp_buffer(cached_batch_ids,
+                                      engine,
+                                      staging_usm_type,
+                                      ov::Shape{N},
+                                      data_types::i32);
+            extract_batch_ids(*q,
+                              static_cast<const int32_t*>(indices_mem->buffer_ptr()),
+                              static_cast<int32_t*>(batch_ids_mem->buffer_ptr()),
+                              N).wait_and_throw();
+
+            std::vector<int32_t> current_batch_ids(N);
+            q->memcpy(current_batch_ids.data(), batch_ids_mem->buffer_ptr(), sizeof(int32_t) * current_batch_ids.size()).wait();
+
+            OPENVINO_ASSERT(!current_batch_ids.empty(), "SparseConvolution SYCL: batch analysis expects non-empty input");
+            const auto first_batch = current_batch_ids.front();
+            if (first_batch < 0) {
+                // Garbage in padding region (output_bound > actual). Treat as single batch 0.
+                batch_analysis_done = true;
+                batch_analysis_N = N;
+                cached_single_batch = true;
+                cached_single_batch_id = 0;
+                cached_segment_offsets = {0, N};
+            } else {
+                max_batch_id = first_batch;
+                for (const auto batch_id : current_batch_ids) {
+                    if (batch_id < 0) break;  // hit padding region, stop
+                    has_multiple_batches = has_multiple_batches || batch_id != first_batch;
+                    max_batch_id = std::max(max_batch_id, batch_id);
+                }
+            }
+
+            // Cache result for P1 fast path.
+            if (!has_multiple_batches) {
+                batch_analysis_done = true;
+                batch_analysis_N = N;
+                cached_single_batch = true;
+                cached_single_batch_id = first_batch;
+                cached_segment_offsets = {0, N};
+            } else {
+                batch_analysis_done = false;
+            }
+
+            can_use_folded_batch_path = has_multiple_batches &&
+                                                   batch_fold_config.valid &&
+                                                   max_batch_id <= batch_fold_config.max_supported_batch;
+
+            // Handle multi-batch partition (only when has_multiple_batches).
+            if (has_multiple_batches && !can_use_folded_batch_path) {
+                const bool batch_partition_changed = cached_batch_ids_host.size() != current_batch_ids.size() ||
+                                                     !std::equal(current_batch_ids.begin(), current_batch_ids.end(), cached_batch_ids_host.begin());
+
+                if (batch_partition_changed) {
+                    cached_batch_ids_host = current_batch_ids;
+                    const auto batch_partition = build_batch_partition(current_batch_ids);
+                    cached_single_batch = batch_partition.single_batch;
+                    cached_single_batch_id = batch_partition.single_batch_id;
+                    cached_segment_offsets = batch_partition.segment_offsets;
+
+                    if (!cached_single_batch) {
+                        OPENVINO_ASSERT(batch_partition.ordered_point_indices.size() == N,
+                                        "SparseConvolution SYCL: invalid batch partition");
+                        ensure_temp_buffer(cached_ordered_point_indices, engine, staging_usm_type, ov::Shape{N}, data_types::i32);
+                        ensure_temp_buffer(cached_batch_of_point, engine, staging_usm_type, ov::Shape{N}, data_types::i32);
+                        q->memcpy(cached_ordered_point_indices->buffer_ptr(),
+                                  batch_partition.ordered_point_indices.data(),
+                                  sizeof(int32_t) * batch_partition.ordered_point_indices.size()).wait();
+                        q->memcpy(cached_batch_of_point->buffer_ptr(),
+                                  batch_partition.batch_of_point.data(),
+                                  sizeof(int32_t) * batch_partition.batch_of_point.size()).wait();
+                    }
+                }
+            }
+        }
+
+        if (!has_multiple_batches) {
+            can_use_folded_batch_path = false;
+        }
+
+        memory::ptr ordered_point_indices_mem;
+        memory::ptr batch_of_point_mem;
+
+        std::vector<::sycl::event> prepare_events;
+        if (prepared_input_coords_xyz_mem) {
+            // Coordinates are already in Minuet's XYZ order for this tensor.
+        } else if (can_use_folded_batch_path) {
+            prepare_events.push_back(fold_coords_bzyx_to_xyz(*q,
+                                                             static_cast<const int32_t*>(indices_mem->buffer_ptr()),
+                                                             static_cast<int32_t*>(input_coords_xyz_mem->buffer_ptr()),
+                                                             N,
+                                                             batch_fold_config.batch_stride));
+        } else if (has_multiple_batches && !cached_single_batch) {
+            ordered_point_indices_mem = cached_ordered_point_indices;
+            batch_of_point_mem = cached_batch_of_point;
+            prepare_events.push_back(reorder_coords_bzyx_to_xyz(*q,
+                                                                static_cast<const int32_t*>(indices_mem->buffer_ptr()),
+                                                                static_cast<const int32_t*>(ordered_point_indices_mem->buffer_ptr()),
+                                                                static_cast<int32_t*>(input_coords_xyz_mem->buffer_ptr()),
+                                                                N));
+        } else {
+            // Single batch path — no batch extraction needed.
+            if (!batch_analysis_done || !cached_single_batch) {
+                cached_single_batch = true;
+                cached_single_batch_id = max_batch_id;
+                cached_segment_offsets = {0, N};
+            }
+            prepare_events.push_back(reorder_coords_bzyx_to_xyz_identity(*q,
+                                                                         static_cast<const int32_t*>(indices_mem->buffer_ptr()),
+                                                                         static_cast<int32_t*>(input_coords_xyz_mem->buffer_ptr()),
+                                                                         N));
+        }
+
+        // V2 always computes in f16. Promote f32 inputs to f16 in-place
+        // (input features go through the same staging buffer used for batch
+        // reordering; weights similarly go through cached_weight_xyz_f16 in
+        // f16 layout). This single optimized kernel path replaces the legacy
+        // dual fp16/fp32 branches.
+        ::sycl::half* prepared_input_features_buffer = nullptr;
+        const void* prepared_weight_buffer = weight_mem->buffer_ptr();
+        const ::sycl::half* minuet_weight_buffer = nullptr;
+        const ::sycl::half* prepared_bias_buffer_f16 = nullptr;
+        const float* prepared_bias_buffer_f32 = nullptr;
+        if (input_is_f16) {
+            prepared_bias_buffer_f16 = static_cast<const ::sycl::half*>(bias_mem->buffer_ptr());
+        } else {
+            prepared_bias_buffer_f32 = static_cast<const float*>(bias_mem->buffer_ptr());
+        }
+
+        if (input_is_f16) {
+            if (can_use_folded_batch_path || cached_single_batch) {
+                prepared_input_features_buffer = static_cast<::sycl::half*>(feature_mem->buffer_ptr());
+            } else {
+                prepare_events.push_back(reorder_features(*q,
+                                                          static_cast<const ::sycl::half*>(feature_mem->buffer_ptr()),
+                                                          static_cast<const int32_t*>(ordered_point_indices_mem->buffer_ptr()),
+                                                          static_cast<::sycl::half*>(input_features_compute_mem->buffer_ptr()),
+                                                          N,
+                                                          IC));
+                prepared_input_features_buffer = static_cast<::sycl::half*>(input_features_compute_mem->buffer_ptr());
+            }
+        } else {
+            // f32 → f16 promotion. We always go through the staging buffer.
+            auto* dst_f16 = static_cast<::sycl::half*>(input_features_compute_mem->buffer_ptr());
+            if (can_use_folded_batch_path || cached_single_batch) {
+                const auto* src_f32 = static_cast<const float*>(feature_mem->buffer_ptr());
+                prepare_events.push_back(convert_buffer(*q, src_f32, dst_f16, N * IC));
+            } else {
+                // Fuse reorder + f32→f16 conversion in one kernel.
+                const auto* src_f32 = static_cast<const float*>(feature_mem->buffer_ptr());
+                const auto* ord = static_cast<const int32_t*>(ordered_point_indices_mem->buffer_ptr());
+                const size_t in_ch = IC;
+                const size_t pts = N;
+                prepare_events.push_back(q->submit([&](::sycl::handler& cgh) {
+                    cgh.parallel_for(::sycl::range<1>(pts * in_ch), [=](::sycl::id<1> id) {
+                        const auto linear = static_cast<size_t>(id[0]);
+                        const auto ordered = linear / in_ch;
+                        const auto channel = linear % in_ch;
+                        const auto original = static_cast<size_t>(ord[ordered]);
+                        dst_f16[linear] = static_cast<::sycl::half>(src_f32[original * in_ch + channel]);
+                    });
+                }));
+            }
+            prepared_input_features_buffer = dst_f16;
+        }
+
+        // Weight prep: the model's [K, IC, OC] tensor iterates K as (kx, ky, kz)
+        // outer-to-inner (XYZ order) — matching v2 Minuet's kernel_offset
+        // table iteration. So no spatial reorder is needed; just demote the
+        // f32 input case to f16 and pass through for f16.
+        memory::ptr weight_xyz_mem;
+        const bool weight_layout_changed = cached_weight_buffer != prepared_weight_buffer ||
+                                           cached_ic != static_cast<int>(IC) ||
+                                           cached_oc != static_cast<int>(OC) ||
+                                           cached_kernel_size != kernel_size_vec ||
+                                           cached_compute_data_type != compute_data_type;
+        if (input_is_f16) {
+            minuet_weight_buffer = static_cast<const ::sycl::half*>(prepared_weight_buffer);
+        } else {
+            weight_xyz_mem = ensure_temp_buffer(cached_weight_xyz_f16,
+                                                engine,
+                                                staging_usm_type,
+                                                ov::Shape{kernel_volume, IC, OC},
+                                                data_types::f16);
+            if (!weight_is_constant || weight_layout_changed) {
+                prepare_events.push_back(convert_buffer(*q,
+                                                        static_cast<const float*>(prepared_weight_buffer),
+                                                        static_cast<::sycl::half*>(weight_xyz_mem->buffer_ptr()),
+                                                        kernel_volume * IC * OC));
+            }
+            minuet_weight_buffer = static_cast<::sycl::half*>(weight_xyz_mem->buffer_ptr());
+        }
+        // For f32 path we also need an f16 bias.
+        if (input_is_f32) {
+            ensure_temp_buffer(cached_bias_f16, engine, staging_usm_type, ov::Shape{OC}, data_types::f16);
+            // Demote bias once per (re)bind. Bias is f32 input.
+            if (!bias_is_constant || weight_layout_changed) {
+                prepare_events.push_back(convert_buffer(*q,
+                                                        static_cast<const float*>(bias_mem->buffer_ptr()),
+                                                        static_cast<::sycl::half*>(cached_bias_f16->buffer_ptr()),
+                                                        OC));
+            }
+            prepared_bias_buffer_f16 = static_cast<const ::sycl::half*>(cached_bias_f16->buffer_ptr());
+        }
+
+        // P2: Minuet's internal ESIMD sort does a queue-level sync (q.wait())
+        // which drains all prior submissions, so prepare kernels complete implicitly.
+        // Only force a wait when we need to (re)create the Minuet instance, because
+        // the constructor reads the weight buffer that may still be in flight.
+        const bool minuet_needs_rebuild = !minuet_instance_v2 ||
+            cached_queue_identity != queue_identity ||
+            cached_weight_buffer != prepared_weight_buffer ||
+            cached_ic != static_cast<int>(IC) ||
+            cached_oc != static_cast<int>(OC) ||
+            cached_kernel_size != kernel_size_vec ||
+            cached_compute_data_type != compute_data_type ||
+            cached_allow_esimd_sort != allow_esimd_sort;
+
+        // Always synchronize before invoking the Minuet forward. The Minuet
+        // kernels (especially the ESIMD radix sort) perform their own host-
+        // side reads (`q.memcpy(&m, ...).wait()` inside nsf rulebook
+        // construction) and don't observe USM dependency tracking the same
+        // way regular SYCL kernels do.
+        for (auto& event : prepare_events)
+            event.wait_and_throw();
+
+        if (allow_esimd_sort && minuet_needs_rebuild) {
+            erase_minuet_subm_rulebook_cache_owner(this);
+            minuet_instance_v2.reset();
+
+            // OV plugin axis convention matches the upstream voxelizer (BXYZ
+            // coord layout) and the model's ONNX attributes. Both Minuet and
+            // the wrapper agree on (X, Y, Z) for spatial axes — pass through.
+            int kernel_size_arr[3] = {static_cast<int>(desc->kernel_size[0]),
+                                      static_cast<int>(desc->kernel_size[1]),
+                                      static_cast<int>(desc->kernel_size[2])};
+            int stride_arr[3] = {static_cast<int>(desc->stride[0]),
+                                 static_cast<int>(desc->stride[1]),
+                                 static_cast<int>(desc->stride[2])};
+            int padding_arr[3] = {static_cast<int>(desc->padding[0]),
+                                  static_cast<int>(desc->padding[1]),
+                                  static_cast<int>(desc->padding[2])};
+            int dilation_arr[3] = {static_cast<int>(desc->dilation[0]),
+                                   static_cast<int>(desc->dilation[1]),
+                                   static_cast<int>(desc->dilation[2])};
+            int* oss_arr_ptr = nullptr;
+            int oss_arr[3] = {0, 0, 0};
+            if (desc->output_spatial_shape.size() == 3) {
+                oss_arr[0] = static_cast<int>(desc->output_spatial_shape[0]);
+                oss_arr[1] = static_cast<int>(desc->output_spatial_shape[1]);
+                oss_arr[2] = static_cast<int>(desc->output_spatial_shape[2]);
+                oss_arr_ptr = oss_arr;
+            }
+
+            // Unified deep-optimized fp16 path (XMX VNNI + rulebook reuse +
+            // output-stationary fused GEMM). f32 inputs are promoted to f16
+            // before reaching the minuet kernels.
+            minuet_instance_v2 = std::make_unique<ov_minuet::MinuetV2>(
+                *q,
+                const_cast<::sycl::half*>(minuet_weight_buffer),
+                static_cast<int>(kernel_volume * IC * OC * sizeof(::sycl::half)),
+                static_cast<int>(IC),
+                static_cast<int>(OC),
+                is_subm,
+                kernel_size_arr,
+                stride_arr,
+                padding_arr,
+                dilation_arr,
+                oss_arr_ptr,
+                /*weights_on_device=*/true);
+            cached_queue_identity = queue_identity;
+            cached_weight_buffer = prepared_weight_buffer;
+            cached_ic = static_cast<int>(IC);
+            cached_oc = static_cast<int>(OC);
+            cached_kernel_size = kernel_size_vec;
+            cached_compute_data_type = compute_data_type;
+            cached_allow_esimd_sort = allow_esimd_sort;
+        }
+
+        auto* input_coords_xyz = static_cast<int32_t*>(input_coords_xyz_mem->buffer_ptr());
+        auto* output_coords_xyz = static_cast<int32_t*>(output_coords_xyz_mem->buffer_ptr());
+        // V2 always writes f16. If the output buffer is also f16 we point at it
+        // directly; otherwise we land in the f16 staging buffer and demote later.
+        auto* output_features_compute = static_cast<::sycl::half*>(output_features_compute_mem->buffer_ptr());
+
+        const bool single_rulebook_forward = can_use_folded_batch_path || cached_single_batch || cached_segment_offsets.size() <= 2;
+        const bool int8_requested = desc->input_abs_max > 0.0f;
+        const bool int8_sparse_enabled = int8_requested &&
+                         allow_esimd_sort &&
+                         single_rulebook_forward &&
+                         input_is_f16 &&
+                         compute_data_type == data_types::f16;
+
+        const auto coord_key = [](int axis0, int axis1, int axis2) -> uint64_t {
+            return (static_cast<uint64_t>(static_cast<uint32_t>(axis0)) << 42) |
+                   (static_cast<uint64_t>(static_cast<uint32_t>(axis1)) << 21) |
+                   static_cast<uint64_t>(static_cast<uint32_t>(axis2));
+        };
+
+        const auto run_reference_forward = [&](int num_points,
+                                               size_t input_point_offset,
+                                               size_t output_point_offset,
+                                               int* produced_points) {
+            const auto points = static_cast<size_t>(num_points);
+            std::vector<int32_t> coords(points * 3);
+            std::vector<::sycl::half> features(points * IC);
+            std::vector<::sycl::half> weights(kernel_volume * IC * OC);
+
+            q->memcpy(coords.data(), input_coords_xyz + input_point_offset * 3, coords.size() * sizeof(int32_t)).wait();
+            q->memcpy(features.data(), prepared_input_features_buffer + input_point_offset * IC, features.size() * sizeof(::sycl::half)).wait();
+            q->memcpy(weights.data(), minuet_weight_buffer, weights.size() * sizeof(::sycl::half)).wait();
+
+            std::vector<size_t> sorted_input_order(points);
+            std::iota(sorted_input_order.begin(), sorted_input_order.end(), 0);
+            std::sort(sorted_input_order.begin(), sorted_input_order.end(), [&](size_t lhs, size_t rhs) {
+                const auto lhs_key = coord_key(coords[lhs * 3 + 0], coords[lhs * 3 + 1], coords[lhs * 3 + 2]);
+                const auto rhs_key = coord_key(coords[rhs * 3 + 0], coords[rhs * 3 + 1], coords[rhs * 3 + 2]);
+                return lhs_key < rhs_key;
+            });
+
+            std::map<uint64_t, size_t> input_by_key;
+            for (const auto point : sorted_input_order) {
+                input_by_key.emplace(coord_key(coords[point * 3 + 0], coords[point * 3 + 1], coords[point * 3 + 2]), point);
+            }
+
+            std::vector<std::array<int32_t, 3>> output_coords_host;
+            output_coords_host.reserve(is_subm ? points : points * kernel_volume);
+            if (is_subm) {
+                for (const auto point : sorted_input_order) {
+                    output_coords_host.push_back({coords[point * 3 + 0], coords[point * 3 + 1], coords[point * 3 + 2]});
+                }
+            } else {
+                std::map<uint64_t, std::array<int32_t, 3>> output_by_key;
+                for (const auto point : sorted_input_order) {
+                    const int32_t in_coord[3] = {coords[point * 3 + 0], coords[point * 3 + 1], coords[point * 3 + 2]};
+                    for (int64_t kernel_axis0 = 0; kernel_axis0 < desc->kernel_size[0]; ++kernel_axis0) {
+                        const auto offset0 = static_cast<int32_t>(desc->padding[0] - kernel_axis0 * desc->dilation[0]);
+                        for (int64_t kernel_axis1 = 0; kernel_axis1 < desc->kernel_size[1]; ++kernel_axis1) {
+                            const auto offset1 = static_cast<int32_t>(desc->padding[1] - kernel_axis1 * desc->dilation[1]);
+                            for (int64_t kernel_axis2 = 0; kernel_axis2 < desc->kernel_size[2]; ++kernel_axis2) {
+                                const int32_t offsets[3] = {
+                                    offset0,
+                                    offset1,
+                                    static_cast<int32_t>(desc->padding[2] - kernel_axis2 * desc->dilation[2]),
+                                };
+                                int32_t out_coord[3] = {0, 0, 0};
+                                bool valid = true;
+                                for (size_t axis = 0; axis < 3; ++axis) {
+                                    const auto candidate = in_coord[axis] + offsets[axis];
+                                    const auto stride = static_cast<int32_t>(desc->stride[axis]);
+                                    valid = valid && candidate >= 0 && stride > 0 && (candidate % stride) == 0;
+                                    out_coord[axis] = valid ? candidate / stride : 0;
+                                    if (valid && desc->output_spatial_shape.size() == 3) {
+                                        valid = out_coord[axis] < desc->output_spatial_shape[axis];
+                                    }
+                                }
+                                if (!valid)
+                                    continue;
+                                output_by_key.emplace(coord_key(out_coord[0], out_coord[1], out_coord[2]),
+                                                      std::array<int32_t, 3>{out_coord[0], out_coord[1], out_coord[2]});
+                            }
+                        }
+                    }
+                }
+                for (const auto& entry : output_by_key)
+                    output_coords_host.push_back(entry.second);
+            }
+
+            OPENVINO_ASSERT(output_point_offset + output_coords_host.size() <= max_output_points,
+                            "SparseConvolution SYCL reference fallback produced more points than output capacity");
+
+            std::vector<::sycl::half> output_features_host(output_coords_host.size() * OC, ::sycl::half(0.0f));
+            for (size_t output_point = 0; output_point < output_coords_host.size(); ++output_point) {
+                const auto& out_coord = output_coords_host[output_point];
+                size_t kernel_index = 0;
+                for (int64_t kernel_axis0 = 0; kernel_axis0 < desc->kernel_size[0]; ++kernel_axis0) {
+                    const auto offset0 = static_cast<int32_t>(desc->padding[0] - kernel_axis0 * desc->dilation[0]);
+                    for (int64_t kernel_axis1 = 0; kernel_axis1 < desc->kernel_size[1]; ++kernel_axis1) {
+                        const auto offset1 = static_cast<int32_t>(desc->padding[1] - kernel_axis1 * desc->dilation[1]);
+                        for (int64_t kernel_axis2 = 0; kernel_axis2 < desc->kernel_size[2]; ++kernel_axis2, ++kernel_index) {
+                            const int32_t offsets[3] = {
+                                offset0,
+                                offset1,
+                                static_cast<int32_t>(desc->padding[2] - kernel_axis2 * desc->dilation[2]),
+                            };
+                            int32_t input_coord[3] = {0, 0, 0};
+                            bool valid = true;
+                            for (size_t axis = 0; axis < 3; ++axis) {
+                                input_coord[axis] = is_subm
+                                    ? out_coord[axis] - offsets[axis]
+                                    : out_coord[axis] * static_cast<int32_t>(desc->stride[axis]) - offsets[axis];
+                                valid = valid && input_coord[axis] >= 0;
+                            }
+                            if (!valid)
+                                continue;
+
+                            const auto input_it = input_by_key.find(coord_key(input_coord[0], input_coord[1], input_coord[2]));
+                            if (input_it == input_by_key.end())
+                                continue;
+
+                            const auto input_point = input_it->second;
+                            for (size_t oc = 0; oc < OC; ++oc) {
+                                float acc = static_cast<float>(output_features_host[output_point * OC + oc]);
+                                for (size_t ic = 0; ic < IC; ++ic) {
+                                    const auto feature = static_cast<float>(features[input_point * IC + ic]);
+                                    const auto weight = static_cast<float>(weights[(kernel_index * IC + ic) * OC + oc]);
+                                    acc += feature * weight;
+                                }
+                                output_features_host[output_point * OC + oc] = static_cast<::sycl::half>(acc);
+                            }
+                        }
+                    }
+                }
+            }
+
+            std::vector<int32_t> flat_output_coords(output_coords_host.size() * 3);
+            for (size_t output_point = 0; output_point < output_coords_host.size(); ++output_point) {
+                flat_output_coords[output_point * 3 + 0] = output_coords_host[output_point][0];
+                flat_output_coords[output_point * 3 + 1] = output_coords_host[output_point][1];
+                flat_output_coords[output_point * 3 + 2] = output_coords_host[output_point][2];
+            }
+
+            if (!flat_output_coords.empty()) {
+                q->memcpy(output_coords_xyz + output_point_offset * 3,
+                          flat_output_coords.data(),
+                          flat_output_coords.size() * sizeof(int32_t)).wait();
+                q->memcpy(output_features_compute + output_point_offset * OC,
+                          output_features_host.data(),
+                          output_features_host.size() * sizeof(::sycl::half)).wait();
+            }
+            *produced_points = static_cast<int>(output_coords_host.size());
+        };
+
+        const uint32_t* int8_rulebook_lut = nullptr;
+
+        // Chain-reuse compatibility: this layer's input feats and coords must be
+        // in the producer SubM layer's sort-order. That is exactly the case
+        // when prepared_input_coords_xyz_mem hit — i.e. the producer cached its
+        // stripped output coords against the OV indices buffer that we now see
+        // as input. OV wires the same buffer for both coords and feats inside
+        // a SubM chain, so a coord-side hit implies feats are in sort-order too.
+        const bool cached_chain_reuse_compatible = (prepared_input_coords_xyz_mem != nullptr);
+
+        // Same-frame SubM rulebook cache. Layers sharing a rulebook name and
+        // matching point count reuse the producer's already-built LUT and
+        // sorted output coords; the chain-reuse path skips Morton sort + LUT
+        // construction (and for FP16 the GEMM runs directly with the cached
+        // sorted-LUT). The (rulebook, generation, points) host-side match is
+        // sufficient — no GPU coordinate comparison needed.
+        bool fp16_chain_reused = false;
+        const auto run_minuet_forward = [&](int num_points,
+                                            size_t input_point_offset,
+                                            size_t output_point_offset,
+                                            int* produced_points) {
+            const bool skip_gemm = int8_sparse_enabled;
+            const bool can_use_subm_rulebook_cache = is_subm && !desc->rulebook.empty() &&
+                                                     input_point_offset == 0 && output_point_offset == 0;
+
+            // Chain reuse: if a previous SubM layer in this frame already built
+            // the rulebook for this name + point count, skip Morton sort + LUT
+            // construction.
+            //   INT8 path: borrow lut_ok for the wrapper's int8 GEMM, copy
+            //              cached output coords from input coords (SubM identity).
+            //   FP16 path: run forward_gemm_only with lut_sorted directly on
+            //              the producer's MinuetV2 instance — its weights match
+            //              this layer because each layer has its own MinuetV2.
+            //              Wait — different layer means different weights but
+            //              identical coords. We must run THIS layer's GEMM
+            //              with the cached LUT, not the producer's. So call
+            //              this->minuet_instance_v2->forward_gemm_only(...,
+            //              cached_lut_sorted, cached_qc_xyz).
+            MinuetSubmRulebookCacheEntry cached;
+            if (can_use_subm_rulebook_cache &&
+                cached_chain_reuse_compatible &&
+                find_minuet_subm_rulebook_cache(desc->rulebook,
+                                                rulebook_generation,
+                                                num_points,
+                                                static_cast<int>(kernel_volume),
+                                                cached) &&
+                cached.lut_sorted != nullptr && cached.qc_xyz != nullptr) {
+                // Chain reuse: this layer's input is the producer's sort-ordered
+                // output (OV wires producer.out_feat → consumer.in_feat for SubM
+                // chains). Both INT8 and FP16 GEMMs read in_feats[lut_sorted[...]],
+                // where lut_sorted indexes the sort-ordered space.
+                if (skip_gemm) {
+                    // INT8: wrapper int8 GEMM consumes the LUT later; stash it.
+                    int8_rulebook_lut = cached.lut_sorted;
+                    *produced_points = num_points;
+                    q->memcpy(output_coords_xyz,
+                              input_coords_xyz,
+                              static_cast<size_t>(num_points) * 3 * sizeof(int32_t)).wait();
+                    return;
+                }
+                // FP16 direct GEMM with cached sorted-LUT.
+                minuet_instance_v2->forward_gemm_only(
+                    num_points,
+                    prepared_input_features_buffer + input_point_offset * IC,
+                    produced_points,
+                    output_coords_xyz + output_point_offset * 3,
+                    output_features_compute + output_point_offset * OC,
+                    cached.qc_xyz,
+                    cached.lut_sorted);
+                fp16_chain_reused = true;
+                return;
+            }
+
+            minuet_instance_v2->forward(num_points,
+                                        input_coords_xyz + input_point_offset * 3,
+                                        prepared_input_features_buffer + input_point_offset * IC,
+                                        produced_points,
+                                        output_coords_xyz + output_point_offset * 3,
+                                        output_features_compute + output_point_offset * OC,
+                                        skip_gemm);
+            if (skip_gemm) {
+                // Drain the rulebook-construction kernels so the int8 GEMM
+                // which reads dLutOK contents sees the completed rulebook
+                // regardless of queue ordering semantics.
+                q->wait_and_throw();
+                int8_rulebook_lut = minuet_instance_v2->get_lut_ok();
+            }
+            if (can_use_subm_rulebook_cache && produced_points && *produced_points == num_points) {
+                update_minuet_subm_rulebook_cache(desc->rulebook,
+                                                  this,
+                                                  rulebook_generation,
+                                                  num_points,
+                                                  static_cast<int>(kernel_volume),
+                                                  minuet_instance_v2->get_lut_ok(),
+                                                  minuet_instance_v2->get_lut_sorted(),
+                                                  minuet_instance_v2->get_qc());
+            }
+        };
+
+        const auto run_sparse_forward = [&](int num_points,
+                                            size_t input_point_offset,
+                                            size_t output_point_offset,
+                                            int* produced_points) {
+            if (allow_esimd_sort) {
+                run_minuet_forward(num_points, input_point_offset, output_point_offset, produced_points);
+            } else {
+                run_reference_forward(num_points, input_point_offset, output_point_offset, produced_points);
+            }
+        };
+
+        int total_produced_points = 0;
+        memory::ptr output_batch_of_point_mem;
+        std::vector<int32_t> output_batch_ids_host;
+        if (can_use_folded_batch_path) {
+            int produced_points = 0;
+            run_sparse_forward(static_cast<int>(N), 0, 0, &produced_points);
+            if (is_subm) {
+                OPENVINO_ASSERT(produced_points == static_cast<int>(N),
+                                "SparseConvolution SYCL: SubM forward produced a mismatched point count");
+            }
+            total_produced_points = produced_points;
+        } else {
+            std::map<int32_t, std::vector<int32_t>> batch_map;
+            for (size_t i = 0; i < cached_batch_ids_host.size(); ++i) {
+                batch_map[cached_batch_ids_host[i]].push_back(static_cast<int32_t>(i));
+            }
+
+            for (size_t segment = 0; segment + 1 < cached_segment_offsets.size(); ++segment) {
+                const auto begin = cached_segment_offsets[segment];
+                const auto end = cached_segment_offsets[segment + 1];
+                const auto points_in_batch = static_cast<int>(end - begin);
+                if (points_in_batch == 0)
+                    continue;
+
+                int produced_points = 0;
+                run_sparse_forward(points_in_batch, begin, total_produced_points, &produced_points);
+                if (is_subm) {
+                    OPENVINO_ASSERT(produced_points == points_in_batch,
+                                    "SparseConvolution SYCL: SubM forward produced a mismatched point count");
+                }
+
+                if (!is_subm && !cached_single_batch && produced_points > 0) {
+                    auto it = batch_map.begin();
+                    std::advance(it, segment);
+                    const auto batch_id = it->first;
+                    output_batch_ids_host.insert(output_batch_ids_host.end(),
+                                                 static_cast<size_t>(produced_points), batch_id);
+                }
+                total_produced_points += produced_points;
+            }
+
+            if (!is_subm && !cached_single_batch && total_produced_points > 0) {
+                output_batch_of_point_mem = ensure_temp_buffer(cached_output_batch_of_point,
+                                                               engine,
+                                                               staging_usm_type,
+                                                               ov::Shape{static_cast<size_t>(total_produced_points)},
+                                                               data_types::i32);
+                q->memcpy(output_batch_of_point_mem->buffer_ptr(),
+                          output_batch_ids_host.data(),
+                          sizeof(int32_t) * output_batch_ids_host.size()).wait();
+            }
+        }
+
+        const size_t output_N_for_int8 = static_cast<size_t>(total_produced_points);
+        bool int8_path_taken = false;
+        ::sycl::event int8_conv_event;
+        if (int8_sparse_enabled && output_N_for_int8 > 0) {
+            const int8_t* input_i8_ptr = nullptr;
+            float input_i8_abs_max = desc->input_abs_max;
+
+            ::sycl::event input_quant_event;
+            bool has_input_quant_event = false;
+            if (input_i8_ptr == nullptr && desc->input_abs_max > 0.0f) {
+                auto input_i8_mem = ensure_temp_buffer(cached_input_i8,
+                                                       engine,
+                                                       staging_usm_type,
+                                                       ov::Shape{N, IC},
+                                                       data_types::i8);
+                input_quant_event = quantize_tensor_to_int8(*q,
+                                                            prepared_input_features_buffer,
+                                                            static_cast<int8_t*>(input_i8_mem->buffer_ptr()),
+                                                            N * IC,
+                                                            desc->input_abs_max);
+                has_input_quant_event = true;
+                input_i8_ptr = static_cast<const int8_t*>(input_i8_mem->buffer_ptr());
+                input_i8_abs_max = desc->input_abs_max;
+            }
+
+            if (input_i8_ptr != nullptr) {
+                const bool use_minuet_int8_kernel = OC >= 128 && kernel_volume >= 27;
+                const int int8_icp = align_up_int(static_cast<int>(IC), XMX_I8_TK);
+                const int int8_ocp = align_up_int(static_cast<int>(OC), XMX_I8_TN * 4);
+                const int8_t* weights_i8_ptr = nullptr;
+                const int8_t* weights_packed_i8_ptr = nullptr;
+                const float* weight_scale_ptr = nullptr;
+                ::sycl::event weight_quant_event;
+                ::sycl::event weight_pack_event;
+                bool has_weight_quant_event = false;
+                bool has_weight_pack_event = false;
+
+                auto weight_i8_mem = ensure_temp_buffer(cached_weight_i8,
+                                                        engine,
+                                                        staging_usm_type,
+                                                        ov::Shape{kernel_volume, IC, OC},
+                                                        data_types::i8);
+                auto weight_scale_mem = ensure_temp_buffer(cached_weight_scale_f32,
+                                                           engine,
+                                                           staging_usm_type,
+                                                           ov::Shape{OC},
+                                                           data_types::f32);
+                const bool int8_weight_cache_hit = weight_is_constant &&
+                                                   cached_int8_weight_source_buffer == minuet_weight_buffer &&
+                                                   cached_int8_weight_kernel_volume == static_cast<int>(kernel_volume) &&
+                                                   cached_int8_weight_input_channels == static_cast<int>(IC) &&
+                                                   cached_int8_weight_output_channels == static_cast<int>(OC);
+                if (!int8_weight_cache_hit) {
+                    weight_quant_event = quantize_weights_to_int8(*q,
+                                                                   minuet_weight_buffer,
+                                                                   static_cast<int8_t*>(weight_i8_mem->buffer_ptr()),
+                                                                   static_cast<float*>(weight_scale_mem->buffer_ptr()),
+                                                                   static_cast<int>(kernel_volume),
+                                                                   static_cast<int>(IC),
+                                                                   static_cast<int>(OC));
+                    has_weight_quant_event = true;
+                    cached_int8_weight_source_buffer = weight_is_constant ? minuet_weight_buffer : nullptr;
+                    cached_int8_weight_kernel_volume = weight_is_constant ? static_cast<int>(kernel_volume) : 0;
+                    cached_int8_weight_input_channels = weight_is_constant ? static_cast<int>(IC) : 0;
+                    cached_int8_weight_output_channels = weight_is_constant ? static_cast<int>(OC) : 0;
+                    cached_int8_weight_input_channels_padded = 0;
+                    cached_int8_weight_output_channels_padded = 0;
+                }
+                weights_i8_ptr = static_cast<const int8_t*>(weight_i8_mem->buffer_ptr());
+                weight_scale_ptr = static_cast<const float*>(weight_scale_mem->buffer_ptr());
+
+                if (use_minuet_int8_kernel) {
+                    auto weight_packed_mem = ensure_temp_buffer(cached_weight_packed_i8,
+                                                                engine,
+                                                                staging_usm_type,
+                                                                ov::Shape{kernel_volume,
+                                                                          static_cast<size_t>(int8_icp),
+                                                                          static_cast<size_t>(int8_ocp)},
+                                                                data_types::i8);
+                    const bool packed_cache_hit = int8_weight_cache_hit &&
+                                                  cached_int8_weight_input_channels_padded == int8_icp &&
+                                                  cached_int8_weight_output_channels_padded == int8_ocp;
+                    if (!packed_cache_hit) {
+                        weight_pack_event = pack_weights_i8_packed_b(*q,
+                                                                     static_cast<const int8_t*>(weight_i8_mem->buffer_ptr()),
+                                                                     static_cast<int8_t*>(weight_packed_mem->buffer_ptr()),
+                                                                     static_cast<int>(kernel_volume),
+                                                                     static_cast<int>(IC),
+                                                                     static_cast<int>(OC),
+                                                                     int8_icp,
+                                                                     int8_ocp,
+                                                                     has_weight_quant_event ? std::vector<::sycl::event>{weight_quant_event} : std::vector<::sycl::event>{});
+                        has_weight_pack_event = true;
+                        cached_int8_weight_input_channels_padded = weight_is_constant ? int8_icp : 0;
+                        cached_int8_weight_output_channels_padded = weight_is_constant ? int8_ocp : 0;
+                    }
+                    weights_packed_i8_ptr = static_cast<const int8_t*>(weight_packed_mem->buffer_ptr());
+                }
+
+                std::vector<::sycl::event> int8_deps;
+                if (has_input_quant_event) int8_deps.push_back(input_quant_event);
+                if (has_weight_quant_event) int8_deps.push_back(weight_quant_event);
+                if (has_weight_pack_event) int8_deps.push_back(weight_pack_event);
+                const auto* lut_ok_ptr = int8_rulebook_lut ? int8_rulebook_lut : minuet_instance_v2->get_lut_ok();
+                OPENVINO_ASSERT(lut_ok_ptr != nullptr, "SparseConvolution SYCL: INT8 path requires a Minuet rulebook LUT");
+                if (use_minuet_int8_kernel && weights_packed_i8_ptr != nullptr) {
+                    int8_conv_event = run_minuet_gemm_int8_xmx(*q,
+                                                               int8_deps,
+                                                               input_i8_ptr,
+                                                               weights_i8_ptr,
+                                                               weights_packed_i8_ptr,
+                                                               lut_ok_ptr,
+                                                               output_features_compute,
+                                                               input_i8_abs_max,
+                                                               weight_scale_ptr,
+                                                               prepared_bias_buffer_f16,
+                                                               fused_relu,
+                                                               static_cast<int>(output_N_for_int8),
+                                                               static_cast<int>(IC),
+                                                               static_cast<int>(OC),
+                                                               int8_icp,
+                                                               int8_ocp,
+                                                               static_cast<int>(kernel_volume));
+                } else {
+                    int8_conv_event = run_implicit_gemm_int8_xmx(*q,
+                                                                 int8_deps,
+                                                                 input_i8_ptr,
+                                                                 weights_i8_ptr,
+                                                                 reinterpret_cast<const int32_t*>(lut_ok_ptr),
+                                                                 output_features_compute,
+                                                                 input_i8_abs_max,
+                                                                 weight_scale_ptr,
+                                                                 prepared_bias_buffer_f16,
+                                                                 fused_relu,
+                                                                 static_cast<int>(output_N_for_int8),
+                                                                 static_cast<int>(IC),
+                                                                 static_cast<int>(OC),
+                                                                 static_cast<int>(kernel_volume));
+                }
+                int8_path_taken = true;
+            }
+        }
+
+        // V2 still owns rulebook construction; the wrapper may only borrow a
+        // validated SubM LUT for the INT8 GEMM launch above.
+
+        const size_t output_N = static_cast<size_t>(total_produced_points);
+        if (is_subm) {
+            OPENVINO_ASSERT(output_N == N,
+                            "SparseConvolution SYCL: SubM produced points (", output_N, ") != input N (", N, ")");
+        }
+
+        if (cached_single_batch && !can_use_folded_batch_path) {
+            update_prepared_single_batch_coords(out_indices_mem,
+                                                output_coords_xyz_mem,
+                                                queue_identity,
+                                                rulebook_generation,
+                                                output_N,
+                                                cached_single_batch_id);
+        } else {
+            clear_prepared_single_batch_coords(out_indices_mem);
+        }
+
+        // When the INT8 path took over output_features_compute, ensure the
+        // bias kernel observes it. We submit the bias kernel with an explicit
+        // dependency on int8_conv_event in that case.
+        auto submit_bias_in_place = [&](auto* output_buffer, const auto* bias_buffer) {
+            return q->submit([&](::sycl::handler& cgh) {
+                if (int8_path_taken) cgh.depends_on(int8_conv_event);
+                const auto pts = output_N;
+                const auto channels = OC;
+                const bool relu = fused_relu;
+                cgh.parallel_for(::sycl::range<1>(pts * channels), [=](::sycl::id<1> id) {
+                    const auto linear = static_cast<size_t>(id[0]);
+                    const auto channel = linear % channels;
+                    float value = static_cast<float>(output_buffer[linear]) + static_cast<float>(bias_buffer[channel]);
+                    if (relu && value < 0.0f) value = 0.0f;
+                    output_buffer[linear] = static_cast<std::remove_pointer_t<decltype(output_buffer)>>(value);
+                });
+            });
+        };
+        auto submit_pack_output = [&](const auto* src_buffer, const auto* bias_buffer, auto* dst_buffer) {
+            return q->submit([&](::sycl::handler& cgh) {
+                if (int8_path_taken) cgh.depends_on(int8_conv_event);
+                const auto pts = output_N;
+                const auto channels = OC;
+                const bool relu = fused_relu;
+                cgh.parallel_for(::sycl::range<1>(pts * channels), [=](::sycl::id<1> id) {
+                    const auto linear = static_cast<size_t>(id[0]);
+                    const auto channel = linear % channels;
+                    float value = static_cast<float>(src_buffer[linear]) + static_cast<float>(bias_buffer[channel]);
+                    if (relu && value < 0.0f) value = 0.0f;
+                    dst_buffer[linear] = static_cast<std::remove_pointer_t<decltype(dst_buffer)>>(value);
+                });
+            });
+        };
+        auto submit_cast_output = [&](const auto* src_buffer, auto* dst_buffer) {
+            return q->submit([&](::sycl::handler& cgh) {
+                if (int8_path_taken) cgh.depends_on(int8_conv_event);
+                const auto count = output_N * OC;
+                cgh.parallel_for(::sycl::range<1>(count), [=](::sycl::id<1> id) {
+                    const auto linear = static_cast<size_t>(id[0]);
+                    dst_buffer[linear] = static_cast<std::remove_pointer_t<decltype(dst_buffer)>>(src_buffer[linear]);
+                });
+            });
+        };
+
+        ::sycl::event feature_finalize_event;
+        bool has_feature_finalize_event = false;
+        if (output_N > 0) {
+            if (int8_path_taken && can_write_output_features_directly) {
+                feature_finalize_event = int8_conv_event;
+                has_feature_finalize_event = true;
+            } else if (can_write_output_features_directly) {
+                // f16 in-place bias (output_features_compute already aliases kernel_out_features).
+                feature_finalize_event = submit_bias_in_place(output_features_compute, prepared_bias_buffer_f16);
+                has_feature_finalize_event = true;
+            } else if (int8_path_taken) {
+                const auto out_dtype = kernel_out_features->get_layout().data_type;
+                OPENVINO_ASSERT(out_dtype == data_types::f32,
+                                "SparseConvolution SYCL: unexpected output data type");
+                feature_finalize_event = submit_cast_output(output_features_compute,
+                                                            static_cast<float*>(kernel_out_features->buffer_ptr()));
+                has_feature_finalize_event = true;
+            } else {
+                // Output buffer is f32. Promote f16 compute output → f32 + add bias.
+                const auto out_dtype = kernel_out_features->get_layout().data_type;
+                OPENVINO_ASSERT(out_dtype == data_types::f32,
+                                "SparseConvolution SYCL: unexpected output data type");
+                feature_finalize_event = submit_pack_output(output_features_compute,
+                                                            prepared_bias_buffer_f32,
+                                                            static_cast<float*>(kernel_out_features->buffer_ptr()));
+                has_feature_finalize_event = true;
+            }
+        }
+
+        std::vector<::sycl::event> completion_deps;
+        if (has_feature_finalize_event)
+            completion_deps.push_back(feature_finalize_event);
+
+        const auto feature_output_rows = kernel_out_features->get_layout().get_shape()[0];
+        ::sycl::event feature_tail_zero_event;
+        if (!unreliable_sparse_layout && feature_output_rows > output_N) {
+            const auto tail_rows = feature_output_rows - output_N;
+            const auto out_dtype = kernel_out_features->get_layout().data_type;
+            if (out_dtype == data_types::f16) {
+                auto* dst = static_cast<::sycl::half*>(kernel_out_features->buffer_ptr()) + output_N * OC;
+                feature_tail_zero_event = q->memset(dst, 0, tail_rows * OC * sizeof(::sycl::half));
+            } else {
+                OPENVINO_ASSERT(out_dtype == data_types::f32,
+                                "SparseConvolution SYCL: unexpected output data type");
+                auto* dst = static_cast<float*>(kernel_out_features->buffer_ptr()) + output_N * OC;
+                feature_tail_zero_event = q->memset(dst, 0, tail_rows * OC * sizeof(float));
+            }
+            completion_deps.push_back(feature_tail_zero_event);
+        }
+
+        const auto* output_batch_ptr = (!is_subm && !cached_single_batch && !can_use_folded_batch_path && output_batch_of_point_mem)
+            ? static_cast<const int32_t*>(output_batch_of_point_mem->buffer_ptr())
+            : (batch_of_point_mem ? static_cast<const int32_t*>(batch_of_point_mem->buffer_ptr()) : nullptr);
+
+          auto indices_pack_event = can_use_folded_batch_path
+                                  ? unfold_output_indices_xyz_to_bzyx(*q,
+                                                        output_coords_xyz,
+                                                        static_cast<int32_t*>(kernel_out_indices->buffer_ptr()),
+                                                        output_N,
+                                                        batch_fold_config.batch_stride)
+                                  : (cached_single_batch
+                                      ? pack_output_indices_single_batch(*q,
+                                                          output_coords_xyz,
+                                                          cached_single_batch_id,
+                                                          static_cast<int32_t*>(kernel_out_indices->buffer_ptr()),
+                                                          output_N)
+                                      : pack_output_indices(*q,
+                                                    output_coords_xyz,
+                                                    output_batch_ptr,
+                                                    static_cast<int32_t*>(kernel_out_indices->buffer_ptr()),
+                                                    output_N));
+        completion_deps.push_back(indices_pack_event);
+
+        const auto indices_output_rows = kernel_out_indices->get_layout().get_shape()[0];
+        ::sycl::event indices_tail_zero_event;
+        if (!unreliable_sparse_layout && indices_output_rows > output_N) {
+            auto* dst = static_cast<int32_t*>(kernel_out_indices->buffer_ptr()) + output_N * 4;
+            indices_tail_zero_event = q->memset(dst, 0, (indices_output_rows - output_N) * 4 * sizeof(int32_t));
+            completion_deps.push_back(indices_tail_zero_event);
+        }
+
+        ::sycl::event completion_event = completion_deps.back();
+        if (completion_deps.size() > 1) {
+            completion_event = q->ext_oneapi_submit_barrier(completion_deps);
+        }
+
+        const auto feature_output_dtype = kernel_out_features->get_layout().data_type;
+        const bool needs_host_visible_completion = !int8_sparse_enabled &&
+                                                     (feature_output_dtype == data_types::f32 ||
+                                                      feature_output_dtype == data_types::f16);
+        if (has_output_staging || needs_host_visible_completion) {
+            completion_event.wait_and_throw();
+        }
+
+        if (kernel_out_features != out_features_mem)
+            out_features_mem->copy_from(ov_stream, *kernel_out_features, true);
+        if (kernel_out_indices != out_indices_mem)
+            out_indices_mem->copy_from(ov_stream, *kernel_out_indices, true);
+
+        // Store actual output point count so downstream layers (SubM, SparseToDense)
+        // can read it via sparse_actual_m_map and use the correct N instead of the
+        // inflated buffer shape from output_bound.
+        set_sparse_actual_m(out_indices_mem->buffer_ptr(), static_cast<int>(output_N), out_indices_mem->get_layout().get_shape()[0], rulebook_generation);
+        set_sparse_actual_m(out_features_mem->buffer_ptr(), static_cast<int>(output_N), out_features_mem->get_layout().get_shape()[0], rulebook_generation);
+        if (kernel_out_indices != out_indices_mem)
+            set_sparse_actual_m(kernel_out_indices->buffer_ptr(), static_cast<int>(output_N), kernel_out_indices->get_layout().get_shape()[0], rulebook_generation);
+        if (kernel_out_features != out_features_mem)
+            set_sparse_actual_m(kernel_out_features->buffer_ptr(), static_cast<int>(output_N), kernel_out_features->get_layout().get_shape()[0], rulebook_generation);
+
+        // Dynamic SparseConvolution still has fully determined runtime output buffers at this point,
+        // so we can hand the completion event back to the framework instead of forcing a layer-local wait.
+        if (has_output_staging) {
+            return nullptr;
+        }
+
+        last_completion_event = completion_event;
+        has_last_completion_event = true;
+        return to_ocl_event(ov_stream, completion_event);
+    }
+};
+
+std::unique_ptr<primitive_impl> SparseConvolutionV15SyclImpl::create_impl(const program_node& node,
+                                                                      const kernel_impl_params& params) const {
+    auto& engine = node.get_program().get_engine();
+    auto& config = node.get_program().get_config();
+    return std::make_unique<sparse_convolution_sycl>(engine, config);
+}
