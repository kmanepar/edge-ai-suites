+namespace ov {
+namespace op {
+namespace v15 {
+
+/// @brief SparseToDense materializes sparse voxel features into either a dense 5D tensor or a fused 4D BEV tensor.
+///
+/// Inputs (2 or 4):
+///   0 (features)      [N, C]           sparse point features (f32/f16)
+///   1 (indices)       [N, 4]           [batch, z, y, x] coordinates (i32/u32/i64/u64)
+///   2 (spatial_shape) [3]              optional model-provided [Z, Y, X] shape (integer)
+///   3 (batch_size)    [] or [1]        optional model-provided dense batch size (integer)
+///
+/// Attributes:
+///   spatial_shape  [3]   dense spatial shape [Z, Y, X]
+///   batch_size     int   dense batch size
+///   channels_first bool  true = BCDHW, false = BDHWC
+///   flatten_output bool  true = fused 4D BEV output [B, C*X, Z, Y]
+///
+/// Output:
+///   0                 [B, C, Z, Y, X]  when channels_first=true and flatten_output=false
+///                     [B, Z, Y, X, C]  when channels_first=false and flatten_output=false
+///                     [B, C * X, Z, Y] when channels_first=true and flatten_output=true
+class OPENVINO_API SparseToDense : public Op {
+public:
+    OPENVINO_OP("SparseToDense", "opset15");
+    SparseToDense() = default;
+
+    explicit SparseToDense(const OutputVector& inputs,
+                           std::vector<int64_t> spatial_shape,
+                           int64_t batch_size,
+                           bool channels_first = true,
+                           bool flatten_output = false);
+
+    bool visit_attributes(AttributeVisitor& visitor) override;
+    void validate_and_infer_types() override;
+    std::shared_ptr<Node> clone_with_new_inputs(const OutputVector& new_args) const override;
+    bool evaluate(TensorVector& outputs, const TensorVector& inputs) const override;
+    bool has_evaluate() const override;
+
+    const std::vector<int64_t>& get_spatial_shape() const;
+    void set_spatial_shape(const std::vector<int64_t>& value);
+
+    int64_t get_batch_size() const;
+    void set_batch_size(int64_t value);
+
+    bool get_channels_first() const;
+    void set_channels_first(bool value);
+
+    bool get_flatten_output() const;
+    void set_flatten_output(bool value);
+
+    bool get_fuse_permute_reshape() const;
+    void set_fuse_permute_reshape(bool value);
+
+private:
+    std::vector<int64_t> m_spatial_shape;
+    int64_t m_batch_size = 1;
+    bool m_channels_first = true;
+    bool m_flatten_output = false;
+};
+
+}  // namespace v15
+}  // namespace op
+}  // namespace ov
