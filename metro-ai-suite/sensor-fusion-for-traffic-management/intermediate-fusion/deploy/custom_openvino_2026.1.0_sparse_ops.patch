+    const auto indices = std::make_shared<Parameter>(element::i64, PartialShape{8, 4});
+
+    const auto op = std::make_shared<op::v15::SparseToDense>(
+        OutputVector{features, indices},
+        std::vector<int64_t>{2, 2, 2}, 1, false, false);
+
+    EXPECT_EQ(op->get_output_element_type(0), element::f16);
+    EXPECT_EQ(op->get_output_partial_shape(0), (PartialShape{1, 2, 2, 2, 32}));
+}
+
+TEST_F(TypePropSparseToDenseTest, flatten_output_static) {
+    const auto features = std::make_shared<Parameter>(element::f32, PartialShape{5, 32});
+    const auto indices = std::make_shared<Parameter>(element::i32, PartialShape{5, 4});
+
+    const auto op = std::make_shared<op::v15::SparseToDense>(
+        OutputVector{features, indices},
+        std::vector<int64_t>{4, 4, 4}, 2, true, true);
+
+    EXPECT_EQ(op->get_output_element_type(0), element::f32);
+    EXPECT_EQ(op->get_output_partial_shape(0), (PartialShape{2, 128, 4, 4}));
+}
+
+TEST_F(TypePropSparseToDenseTest, four_input_model_form_static) {
+    const auto features = std::make_shared<Parameter>(element::f32, PartialShape{Dimension::dynamic(), 128});
+    const auto indices = std::make_shared<Parameter>(element::i32, PartialShape{Dimension::dynamic(), 4});
+    const auto spatial_shape = op::v0::Constant::create(element::i32, Shape{3}, {128, 128, 1});
+    const auto batch_size = op::v0::Constant::create(element::i32, Shape{1}, {1});
