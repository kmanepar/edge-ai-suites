+    const auto weight = std::make_shared<ov::op::v0::Parameter>(ov::element::f32, ov::PartialShape{27, 16, 32});
+    const auto bias = std::make_shared<ov::op::v0::Parameter>(ov::element::f32, ov::PartialShape{32});
