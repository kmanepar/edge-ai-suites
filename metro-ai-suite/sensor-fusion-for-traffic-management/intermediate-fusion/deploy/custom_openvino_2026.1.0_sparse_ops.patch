+
+bool compute_sparse_to_dense_output_shape(const std::array<int64_t, 3>& spatial_shape,
+                                          int64_t batch_size,
+                                          size_t channels,
+                                          bool channels_first,
+                                          bool flatten_output,
+                                          ov::Shape& output_shape) {
+    if (batch_size < 0)
+        return false;
+
+    for (const auto dim : spatial_shape) {
+        if (dim < 0)
+            return false;
+    }
+
+    const auto batch = static_cast<size_t>(batch_size);
+    const auto depth = static_cast<size_t>(spatial_shape[0]);
+    const auto height = static_cast<size_t>(spatial_shape[1]);
+    const auto width = static_cast<size_t>(spatial_shape[2]);
+
+    if (flatten_output) {
+        if (!channels_first)
+            return false;
+        if (width != 0 && channels > std::numeric_limits<size_t>::max() / width)
+            return false;
+        output_shape = ov::Shape{batch, channels * width, depth, height};
+        return true;
+    }
+
+    output_shape = channels_first ? ov::Shape{batch, channels, depth, height, width}
+                                  : ov::Shape{batch, depth, height, width, channels};
+    return true;
+}
+
+template <typename TFeature, typename TIndex, bool ChannelsFirst, bool FlattenOutput>
+::sycl::event launch(::sycl::queue& q,
+                     const TFeature* features,
+                     const TIndex* indices,
+                     TFeature* output,
+                     size_t num_points,
+                     size_t channels,
+                     uint32_t batch,
+                     uint32_t depth,
+                     uint32_t height,
+                     uint32_t width,
+                     size_t output_elements) {
+    const size_t work_items = num_points * channels;
+    const size_t local_size = std::min<size_t>(128, std::max<size_t>(1, work_items));
+    const size_t global_size = ((std::max<size_t>(1, work_items) + local_size - 1) / local_size) * local_size;
+
+    return q.submit([&](::sycl::handler& cgh) {
+        cgh.parallel_for(::sycl::nd_range<1>(global_size, local_size), [=](::sycl::nd_item<1> item) {
+            const size_t gid = item.get_global_linear_id();
+            if (gid >= work_items)
+                return;
+
+            const size_t point = gid / channels;
+            const size_t channel = gid % channels;
+            const size_t coord_offset = point * 4;
+
+            const auto batch_idx = static_cast<int64_t>(indices[coord_offset + 0]);
+            const auto z = static_cast<int64_t>(indices[coord_offset + 1]);
+            const auto y = static_cast<int64_t>(indices[coord_offset + 2]);
+            const auto x = static_cast<int64_t>(indices[coord_offset + 3]);
+
+            if (batch_idx < 0 || static_cast<uint64_t>(batch_idx) >= batch)
+                return;
+            if (z < 0 || static_cast<uint64_t>(z) >= depth)
+                return;
+            if (y < 0 || static_cast<uint64_t>(y) >= height)
+                return;
+            if (x < 0 || static_cast<uint64_t>(x) >= width)
+                return;
+
+            size_t output_index = 0;
+            if constexpr (FlattenOutput) {
+                const size_t output_channel = channel * width + static_cast<size_t>(x);
+                output_index = (((static_cast<size_t>(batch_idx) * (channels * width) + output_channel) * depth + static_cast<size_t>(z)) *
+                                height + static_cast<size_t>(y));
+            } else if constexpr (ChannelsFirst) {
+                output_index = ((((static_cast<size_t>(batch_idx) * channels + channel) * depth + static_cast<size_t>(z)) *
+                                  height + static_cast<size_t>(y)) * width + static_cast<size_t>(x));
+            } else {
+                output_index = ((((static_cast<size_t>(batch_idx) * depth + static_cast<size_t>(z)) * height +
+                                  static_cast<size_t>(y)) * width + static_cast<size_t>(x)) * channels + channel);
+            }
+            if (output_index < output_elements) {
+                output[output_index] = features[gid];
+            }
+        });
+    });
+}
+
+template <typename TFeature, typename TIndex>
+::sycl::event dispatch(::sycl::queue& q,
+                       memory::ptr feature_mem,
+                       memory::ptr indices_mem,
+                       memory::ptr output_mem,
+                       size_t num_points,
+                       size_t channels,
+                       const std::array<int64_t, 3>& spatial_shape,
+                       int64_t batch_size,
+                       bool channels_first,
+                       bool flatten_output) {
+    const auto batch = static_cast<uint32_t>(batch_size);
+    const auto depth = static_cast<uint32_t>(spatial_shape[0]);
+    const auto height = static_cast<uint32_t>(spatial_shape[1]);
+    const auto width = static_cast<uint32_t>(spatial_shape[2]);
+    const auto output_elements = output_mem->get_layout().count();
+
+    if (flatten_output) {
+        return launch<TFeature, TIndex, true, true>(q,
+                                                    static_cast<const TFeature*>(feature_mem->buffer_ptr()),
+                                                    static_cast<const TIndex*>(indices_mem->buffer_ptr()),
+                                                    static_cast<TFeature*>(output_mem->buffer_ptr()),
+                                                    num_points,
+                                                    channels,
+                                                    batch,
+                                                    depth,
+                                                    height,
+                                                    width,
+                                                    output_elements);
+    }
+
+    if (channels_first) {
+        return launch<TFeature, TIndex, true, false>(q,
+                                                     static_cast<const TFeature*>(feature_mem->buffer_ptr()),
+                                                     static_cast<const TIndex*>(indices_mem->buffer_ptr()),
+                                                     static_cast<TFeature*>(output_mem->buffer_ptr()),
+                                                     num_points,
+                                                     channels,
+                                                     batch,
+                                                     depth,
+                                                     height,
+                                                     width,
+                                                     output_elements);
+    }
+
+    return launch<TFeature, TIndex, false, false>(q,
+                                                  static_cast<const TFeature*>(feature_mem->buffer_ptr()),
+                                                  static_cast<const TIndex*>(indices_mem->buffer_ptr()),
+                                                  static_cast<TFeature*>(output_mem->buffer_ptr()),
+                                                  num_points,
+                                                  channels,
+                                                  batch,
+                                                  depth,
+                                                  height,
+                                                  width,
+                                                  output_elements);
+}
