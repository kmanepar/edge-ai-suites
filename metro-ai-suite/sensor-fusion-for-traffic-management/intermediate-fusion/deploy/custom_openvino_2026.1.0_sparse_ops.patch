+struct sparse_to_dense_sycl : public typed_primitive_sycl_impl<sparse_to_dense> {
+    using parent = typed_primitive_sycl_impl<sparse_to_dense>;
+    using parent::parent;
+
+    std::shared_ptr<::sycl::context> fallback_context;
+    std::shared_ptr<::sycl::queue> fallback_queue;
+    void* fallback_queue_handle = nullptr;
+
+    memory::ptr cached_feature_staging;
+    memory::ptr cached_indices_staging;
+    memory::ptr cached_output_staging;
+
+    static allocation_type get_staging_usm_type(engine& engine) {
+        if (engine.supports_allocation(allocation_type::usm_device))
+            return allocation_type::usm_device;
+        if (engine.supports_allocation(allocation_type::usm_shared))
+            return allocation_type::usm_shared;
+        return allocation_type::usm_host;
+    }
+
+    static memory::ptr ensure_usm(memory::ptr mem,
+                                  memory::ptr& cached_staging,
+                                  stream& stream,
+                                  engine& engine,
+                                  bool is_output,
+                                  bool blocking) {
+        OPENVINO_ASSERT(mem != nullptr, "SparseToDense: null memory");
+        if (memory_capabilities::is_usm_type(mem->get_allocation_type()))
+            return mem;
+
+        const auto required_usm_type = get_staging_usm_type(engine);
+        if (cached_staging == nullptr ||
+            cached_staging->get_layout() != mem->get_layout() ||
+            cached_staging->get_allocation_type() != required_usm_type) {
+            cached_staging = engine.allocate_memory(mem->get_layout(), required_usm_type, false);
+        }
+
+        if (!is_output)
+            cached_staging->copy_from(stream, *mem, blocking);
+        return cached_staging;
+    }
+
+    DECLARE_OBJECT_TYPE_SERIALIZATION(cldnn::sycl::sparse_to_dense_sycl)
+
+    std::unique_ptr<primitive_impl> clone() const override { return std::make_unique<sparse_to_dense_sycl>(*this); }
+
+    event::ptr execute_impl(const std::vector<event::ptr>& events, typed_primitive_inst<sparse_to_dense>& instance) override {
+        auto& network = instance.get_network();
+        auto& stream = downcast<ocl::ocl_stream>(network.get_stream());
+        auto& engine = network.get_engine();
+        const auto desc = instance.get_typed_desc<sparse_to_dense>();
+
+        ::sycl::queue* q = nullptr;
+        if (auto* native_sycl_stream = dynamic_cast<ocl::sycl_stream*>(&stream)) {
+            q = &native_sycl_stream->get_sycl_queue();
+        } else {
+            auto& ocl_engine = downcast<ocl::ocl_engine>(engine);
+            auto current_queue_handle = static_cast<void*>(stream.get_cl_queue().get());
+            if (fallback_queue == nullptr || fallback_queue_handle != current_queue_handle) {
+                fallback_context = std::make_shared<::sycl::context>(
+                    ::sycl::make_context<::sycl::backend::opencl>(ocl_engine.get_cl_context().get()));
+                fallback_queue = std::make_shared<::sycl::queue>(
+                    ::sycl::make_queue<::sycl::backend::opencl>(stream.get_cl_queue().get(), *fallback_context));
+                fallback_queue_handle = current_queue_handle;
+            }
+            q = fallback_queue.get();
+        }
+
+        auto feature_mem = instance.input_memory_ptr(0);
+        auto indices_mem = instance.input_memory_ptr(1);
+        auto output_mem = instance.output_memory_ptr(0);
+
+        const auto feature_shape = feature_mem->get_layout().get_shape();
+        OPENVINO_ASSERT(feature_shape.size() == 2, "SparseToDense expects a rank-2 feature tensor at execution time");
+        auto num_points = feature_shape[0];
+        const auto channels = feature_shape[1];
+
+        // Override num_points with actual voxel count from upstream SparseConvolution.
+        // When output_bound inflates buffer shapes, sparse_actual_m_map provides
+        // the true point count to avoid scattering garbage coordinates.
+        int actual_m = 0;
+        if (get_sparse_actual_m(indices_mem->buffer_ptr(), num_points, actual_m) ||
+            get_sparse_actual_m(feature_mem->buffer_ptr(), num_points, actual_m)) {
+            num_points = static_cast<size_t>(actual_m);
+        }
+
+        OPENVINO_ASSERT(desc->spatial_shape.size() == 3, "SparseToDense spatial_shape attribute must contain exactly three values");
+        const auto& spatial_values = desc->spatial_shape;
+        const auto batch_size_val = desc->batch_size;
+
+        ov::Shape expected_output_shape;
+        OPENVINO_ASSERT(compute_sparse_to_dense_output_shape({{spatial_values[0], spatial_values[1], spatial_values[2]}},
+                                                             batch_size_val,
+                                                             channels,
+                                                             desc->channels_first,
+                                                             desc->flatten_output,
+                                                             expected_output_shape),
+                        "SparseToDense failed to compute the dense output shape");
+        OPENVINO_ASSERT(output_mem->get_layout().get_shape() == expected_output_shape,
+                        "SparseToDense output layout mismatch: expected ",
+                        expected_output_shape,
+                        ", got ",
+                        output_mem->get_layout().get_shape());
+
+        stream.wait_for_events(events);
+        const bool blocking_staging = stream.get_queue_type() == QueueTypes::out_of_order;
+
+        feature_mem = ensure_usm(feature_mem, cached_feature_staging, stream, engine, false, blocking_staging);
+        indices_mem = ensure_usm(indices_mem, cached_indices_staging, stream, engine, false, blocking_staging);
+        auto kernel_out = ensure_usm(output_mem, cached_output_staging, stream, engine, true, blocking_staging);
+        kernel_out->fill(stream, {}, blocking_staging);
+
+        const bool has_staging = (feature_mem != instance.input_memory_ptr(0)) ||
+                                 (indices_mem != instance.input_memory_ptr(1)) ||
+                                 (kernel_out != output_mem);
+
+        if (feature_mem->get_layout().data_type == data_types::f16) {
+            OPENVINO_ASSERT(q->get_device().has(::sycl::aspect::fp16),
+                            "SparseToDense fp16 path requires device fp16 support");
+        }
+
+        if (num_points == 0 || channels == 0 || kernel_out->get_layout().count() == 0) {
+            if (kernel_out != output_mem) {
+                output_mem->copy_from(stream, *kernel_out, true);
+            }
+            return nullptr;
+        }
+
+        ::sycl::event ev;
+#define DISPATCH_INDEX(TFeature) \
+        switch (indices_mem->get_layout().data_type) { \
+        case data_types::i32: \
+            ev = dispatch<TFeature, int32_t>(*q, feature_mem, indices_mem, kernel_out, num_points, channels, \
+                                             {{spatial_values[0], spatial_values[1], spatial_values[2]}}, batch_size_val, desc->channels_first, desc->flatten_output); \
+            break; \
+        case data_types::u32: \
+            ev = dispatch<TFeature, uint32_t>(*q, feature_mem, indices_mem, kernel_out, num_points, channels, \
+                                              {{spatial_values[0], spatial_values[1], spatial_values[2]}}, batch_size_val, desc->channels_first, desc->flatten_output); \
+            break; \
+        case data_types::i64: \
+            ev = dispatch<TFeature, int64_t>(*q, feature_mem, indices_mem, kernel_out, num_points, channels, \
+                                             {{spatial_values[0], spatial_values[1], spatial_values[2]}}, batch_size_val, desc->channels_first, desc->flatten_output); \
+            break; \
+        case data_types::u64: \
+            ev = dispatch<TFeature, uint64_t>(*q, feature_mem, indices_mem, kernel_out, num_points, channels, \
+                                              {{spatial_values[0], spatial_values[1], spatial_values[2]}}, batch_size_val, desc->channels_first, desc->flatten_output); \
+            break; \
+        default: \
+            OPENVINO_THROW("Unsupported SparseToDense index type"); \
+        }
+
+        switch (feature_mem->get_layout().data_type) {
+        case data_types::f16:
+            DISPATCH_INDEX(::sycl::half)
+            break;
+        case data_types::f32:
+            DISPATCH_INDEX(float)
+            break;
+        default:
+            OPENVINO_THROW("Unsupported SparseToDense feature type");
+        }
+#undef DISPATCH_INDEX
+
+        if (kernel_out != output_mem) {
+            ev.wait_and_throw();
+            output_mem->copy_from(stream, *kernel_out, true);
+            return nullptr;
+        }
+
+        if (has_staging) {
+            ev.wait_and_throw();
+            return nullptr;
+        }
+
+        return to_ocl_event(stream, ev);
+    }
+};
+
+std::unique_ptr<primitive_impl> SparseToDenseV15SyclImpl::create_impl(const program_node& node, const kernel_impl_params& params) const {
+    auto& engine = node.get_program().get_engine();
+    auto& config = node.get_program().get_config();
+    return std::make_unique<sparse_to_dense_sycl>(engine, config);
+}
