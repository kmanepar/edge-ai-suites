+void validate_attr(const ov::Node* node,
+                   const std::vector<int64_t>& values,
+                   const char* name,
+                   bool allow_zero) {
+    NODE_VALIDATION_CHECK(node, values.size() == 3, "Attribute '", name, "' must contain exactly 3 elements.");
+
+    for (const auto value : values) {
+        const bool valid = allow_zero ? value >= 0 : value > 0;
+        NODE_VALIDATION_CHECK(node, valid, "Attribute '", name, "' contains an invalid value: ", value);
+    }
+}
+
+bool is_relu_activation(const std::string& activation) {
+    return activation == "ReLU" || activation == "relu";
+}
+
+std::array<int64_t, 3> to_array3(const std::vector<int64_t>& values) {
+    return {{values[0], values[1], values[2]}};
+}
+
+std::vector<int64_t> to_i64_vector(const ov::Tensor& tensor) {
+    const auto count = ov::shape_size(tensor.get_shape());
+    std::vector<int64_t> values(count);
+
+    switch (tensor.get_element_type()) {
+    case ov::element::Type_t::i32: {
+        const auto* src = tensor.data<const int32_t>();
+        for (size_t i = 0; i < count; ++i)
+            values[i] = static_cast<int64_t>(src[i]);
+        break;
+    }
+    case ov::element::Type_t::i64: {
+        const auto* src = tensor.data<const int64_t>();
+        std::copy(src, src + count, values.begin());
+        break;
+    }
+    case ov::element::Type_t::u32: {
+        const auto* src = tensor.data<const uint32_t>();
+        for (size_t i = 0; i < count; ++i)
+            values[i] = static_cast<int64_t>(src[i]);
+        break;
+    }
+    case ov::element::Type_t::u64: {
+        const auto* src = tensor.data<const uint64_t>();
+        for (size_t i = 0; i < count; ++i) {
+            if (src[i] > static_cast<uint64_t>(std::numeric_limits<int64_t>::max())) {
+                values.clear();
+                return values;
+            }
+            values[i] = static_cast<int64_t>(src[i]);
+        }
+        break;
+    }
+    default:
+        values.clear();
+        break;
+    }
+
+    return values;
+}
+
+template <typename T>
+bool write_i64_vector(const std::vector<int64_t>& values, ov::Tensor& tensor) {
+    auto* dst = tensor.data<T>();
+    for (size_t i = 0; i < values.size(); ++i)
+        dst[i] = static_cast<T>(values[i]);
+    return true;
+}
+
+bool write_i64_tensor_data(const std::vector<int64_t>& values, ov::Tensor& tensor) {
+    switch (tensor.get_element_type()) {
+    case ov::element::Type_t::i32:
+        return write_i64_vector<int32_t>(values, tensor);
+    case ov::element::Type_t::i64:
+        return write_i64_vector<int64_t>(values, tensor);
+    case ov::element::Type_t::u32:
+        return write_i64_vector<uint32_t>(values, tensor);
+    case ov::element::Type_t::u64:
+        return write_i64_vector<uint64_t>(values, tensor);
+    default:
+        return false;
+    }
+}
