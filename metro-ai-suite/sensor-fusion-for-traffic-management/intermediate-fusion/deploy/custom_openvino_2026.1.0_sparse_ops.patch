+
+std::array<int64_t, 3> to_array3(const std::vector<int64_t>& values) {
+    std::array<int64_t, 3> out{0, 0, 0};
+    for (size_t i = 0; i < std::min<size_t>(3, values.size()); ++i)
+        out[i] = values[i];
+    return out;
+}
+
+}  // namespace
+
+bool SparseConvolution::isSupportedOperation(const std::shared_ptr<const ov::Node>& op,
+                                             std::string& errorMessage) noexcept {
+    try {
+        if (op->get_type_info() != ov::op::v15::SparseConvolution::get_type_info_static()) {
+            errorMessage = "Only SparseConvolution operation from opset15 is supported by the CPU plugin.";
+            return false;
+        }
+    } catch (...) {
+        return false;
+    }
+    return true;
+}
+
+SparseConvolution::SparseConvolution(const std::shared_ptr<ov::Node>& op, const GraphContext::CPtr& context)
+    : Node(op, context, NgraphShapeInferFactory(op)) {
+    std::string errorMessage;
+    if (!isSupportedOperation(op, errorMessage)) {
+        OPENVINO_THROW_NOT_IMPLEMENTED(errorMessage);
+    }
+
+    const auto sc = std::dynamic_pointer_cast<const ov::op::v15::SparseConvolution>(op);
+    m_kernel_size = to_array3(sc->get_kernel_size());
+    m_stride = to_array3(sc->get_stride());
+    m_padding = to_array3(sc->get_padding());
+    m_dilation = to_array3(sc->get_dilation());
+    m_input_spatial_shape = to_array3(sc->get_input_spatial_shape());
+    m_output_spatial_shape = to_array3(sc->get_output_spatial_shape());
+    m_subm = sc->is_subm();
+    m_fused_relu = sc->get_fused_relu();
+    m_has_bias = sc->has_bias();
+}
+
+void SparseConvolution::getSupportedDescriptors() {
+    const auto edges = getParentEdges().size();
+    if (edges != 3 && edges != 4) {
+        CPU_NODE_THROW("has incorrect number of input edges: ", edges);
+    }
+    if (getChildEdges().size() < 2) {
+        CPU_NODE_THROW("has incorrect number of output edges: ", getChildEdges().size());
+    }
+}
+
+void SparseConvolution::initSupportedPrimitiveDescriptors() {
+    if (!supportedPrimitiveDescriptors.empty())
+        return;
+
+    auto features_prc = getOriginalInputPrecisionAtPort(FEATURES_IDX);
+    auto coords_prc = getOriginalInputPrecisionAtPort(COORDS_IDX);
+    auto weights_prc = getOriginalInputPrecisionAtPort(WEIGHTS_IDX);
+
+    if (features_prc != ov::element::f32 && features_prc != ov::element::f16) {
+        features_prc = ov::element::f32;
+    }
+    // Coords are constrained to i32 by the core op.
+    coords_prc = ov::element::i32;
+    // Force weights/bias to match feature precision so the templated reference
+    // implementation can run without per-element conversion.
+    weights_prc = features_prc;
+
+    std::vector<PortConfigurator> in_configs{{LayoutType::ncsp, features_prc},
+                                             {LayoutType::ncsp, coords_prc},
+                                             {LayoutType::ncsp, weights_prc}};
+    if (m_has_bias) {
+        in_configs.push_back({LayoutType::ncsp, features_prc});
+    }
+
+    addSupportedPrimDesc(in_configs,
+                         {{LayoutType::ncsp, features_prc}, {LayoutType::ncsp, coords_prc}},
+                         ref_any);
+}
+
+template <typename T, typename IdxT>
+void SparseConvolution::executeImpl() {
+    const auto& features_mem = getSrcMemoryAtPort(FEATURES_IDX);
+    const auto& coords_mem = getSrcMemoryAtPort(COORDS_IDX);
+    const auto& weights_mem = getSrcMemoryAtPort(WEIGHTS_IDX);
+
+    const auto& features_dims = features_mem->getStaticDims();
+    const auto& weights_dims = weights_mem->getStaticDims();
+    OPENVINO_ASSERT(features_dims.size() == 2, "SparseConvolution expects features rank-2");
+    OPENVINO_ASSERT(weights_dims.size() == 3, "SparseConvolution expects weights rank-3 (KV, Cin, Cout)");
+    const auto num_points = features_dims[0];
+    const auto in_channels = features_dims[1];
+    const auto out_channels = weights_dims[2];
+
+    // Coords come in as IdxT; the reference impl expects int64_t. Convert
+    // once into a temporary buffer rather than per-element.
+    const auto* coords_raw = getSrcDataAtPortAs<const IdxT>(COORDS_IDX);
+    std::vector<int64_t> coords_i64(num_points * 4);
+    for (size_t i = 0; i < num_points * 4; ++i)
+        coords_i64[i] = static_cast<int64_t>(coords_raw[i]);
+
+    ov::reference::SparseConvolutionMetadata metadata;
+    OPENVINO_ASSERT(ov::reference::compute_sparse_convolution_metadata(coords_i64.data(),
+                                                                       num_points,
+                                                                       4,
+                                                                       m_input_spatial_shape,
+                                                                       m_kernel_size,
+                                                                       m_stride,
+                                                                       m_padding,
+                                                                       m_dilation,
+                                                                       m_subm,
+                                                                       metadata,
+                                                                       m_output_spatial_shape),
+                    "SparseConvolution metadata computation failed");
+
+    // Resize outputs to actual point count produced by the rulebook.
+    const auto num_out_points = metadata.num_points();
+    redefineOutputMemory({{num_out_points, out_channels}, {num_out_points, 4}});
+
+    const auto* features = getSrcDataAtPortAs<const T>(FEATURES_IDX);
+    const auto* weights = getSrcDataAtPortAs<const T>(WEIGHTS_IDX);
+    const T* bias = m_has_bias ? getSrcDataAtPortAs<const T>(BIAS_IDX) : nullptr;
+    auto* out_features = getDstDataAtPortAs<T>(0);
+    auto* out_coords = getDstDataAtPortAs<IdxT>(1);
+
+    OPENVINO_ASSERT(ov::reference::sparse_convolution<T>(features,
+                                                         num_points,
+                                                         in_channels,
+                                                         coords_i64.data(),
+                                                         4,
+                                                         weights,
+                                                         out_channels,
+                                                         bias,
+                                                         m_input_spatial_shape,
+                                                         m_kernel_size,
+                                                         m_stride,
+                                                         m_padding,
+                                                         m_dilation,
+                                                         m_subm,
+                                                         metadata,
+                                                         out_features,
+                                                         m_output_spatial_shape,
+                                                         m_fused_relu),
+                    "SparseConvolution reference execution failed");
+
+    for (size_t i = 0; i < metadata.out_indices.size(); ++i)
+        out_coords[i] = static_cast<IdxT>(metadata.out_indices[i]);
+}
+
+void SparseConvolution::execute([[maybe_unused]] const dnnl::stream& strm) {
+    const auto features_prc = getSrcMemoryAtPort(FEATURES_IDX)->getDesc().getPrecision();
+
+    // Coords are constrained to i32 by the core op (validate_and_infer_types).
+    if (features_prc == ov::element::f16) {
+        executeImpl<ov::float16, int32_t>();
+    } else {
+        executeImpl<float, int32_t>();
+    }
+}
+
+void SparseConvolution::executeDynamicImpl(const dnnl::stream& strm) {
+    execute(strm);
+}
+
+bool SparseConvolution::created() const {
+    return getType() == Type::SparseConvolution;
+}
+
+}  // namespace ov::intel_cpu::node
