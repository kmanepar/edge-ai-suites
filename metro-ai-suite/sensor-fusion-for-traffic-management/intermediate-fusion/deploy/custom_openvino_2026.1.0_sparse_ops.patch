+    auto indices = make_shared<ov::op::v0::Parameter>(element::i32, PartialShape{100, 4});
+    auto weight = make_shared<ov::op::v0::Parameter>(element::f16, PartialShape{27, 16, 16});
+    auto bias = make_shared<ov::op::v0::Parameter>(element::f16, PartialShape{16});
+
+    auto op = make_shared<ov::op::v15::SparseConvolution>(features,
+                                                          indices,
+                                                          weight,
+                                                          bias,
+                                                          vector<int64_t>{3, 3, 3},
+                                                          vector<int64_t>{1, 1, 1},
+                                                          vector<int64_t>{1, 1, 1},
+                                                          vector<int64_t>{1, 1, 1},
+                                                          true,
+                                                          0,
+                                                          vector<int64_t>{10, 10, 10});
+
+    EXPECT_EQ(op->get_output_size(), 2);
+    EXPECT_EQ(op->get_output_partial_shape(0), (PartialShape{100, 16}));
+    EXPECT_EQ(op->get_output_partial_shape(1), (PartialShape{100, 4}));
