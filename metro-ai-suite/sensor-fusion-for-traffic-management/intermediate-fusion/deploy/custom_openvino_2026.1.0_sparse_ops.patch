+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#include "sparse_to_dense_inst.h"
+
+#include "json_object.h"
+#include "openvino/reference/sparse_to_dense.hpp"
+#include "primitive_type_base.h"
+
+#include <sstream>
+#include <vector>
+
+namespace cldnn {
+
+GPU_DEFINE_PRIMITIVE_TYPE_ID(sparse_to_dense)
+
+sparse_to_dense_inst::typed_primitive_inst(network& network, sparse_to_dense_node const& node) : parent(network, node) {}
+
+layout sparse_to_dense_inst::calc_output_layout(sparse_to_dense_node const& node, const kernel_impl_params& impl_param) {
+    return calc_output_layouts<ov::PartialShape>(node, impl_param)[0];
+}
+
+template <typename ShapeType>
+std::vector<layout> sparse_to_dense_inst::calc_output_layouts(sparse_to_dense_node const& node,
+                                                              const kernel_impl_params& impl_param) {
+    const auto primitive = impl_param.typed_desc<sparse_to_dense>();
+    const auto& feature_layout = impl_param.get_input_layout(0);
+    const auto feature_shape = feature_layout.get_partial_shape();
+
+    ov::Dimension channels = ov::Dimension::dynamic();
+    if (feature_shape.rank().is_static() && feature_shape.rank().get_length() > 1) {
+        channels = feature_shape[1];
+    }
+
+    ov::PartialShape output_shape;
+    if (channels.is_static() && primitive->spatial_shape.size() == 3 && primitive->batch_size > 0) {
+        ov::Shape static_output_shape;
+        const auto success = ov::reference::compute_sparse_to_dense_output_shape(
+            {{primitive->spatial_shape[0], primitive->spatial_shape[1], primitive->spatial_shape[2]}},
+            primitive->batch_size,
+            static_cast<size_t>(channels.get_length()),
+            primitive->channels_first,
+            primitive->flatten_output,
+            static_output_shape);
+        OPENVINO_ASSERT(success, "SparseToDense shape inference failed");
+        output_shape = ov::PartialShape(static_output_shape);
+    } else {
+        if (primitive->flatten_output) {
+            output_shape = ov::PartialShape{ov::Dimension::dynamic(), ov::Dimension::dynamic(), ov::Dimension::dynamic(), ov::Dimension::dynamic()};
+        } else {
+            const auto dyn = ov::Dimension::dynamic();
+            output_shape = primitive->channels_first
+                ? ov::PartialShape{dyn, channels, dyn, dyn, dyn}
+                : ov::PartialShape{dyn, dyn, dyn, dyn, channels};
+        }
+    }
+
+    std::optional<data_types> requested_out_type;
+    if (!primitive->output_data_types.empty()) {
+        requested_out_type = primitive->output_data_types[0];
+    }
+    const auto out_type = requested_out_type.value_or(feature_layout.data_type);
+    const auto rank = primitive->flatten_output ? 4 : 5;
+    return {layout{output_shape, out_type, format::get_default_format(rank)}};
+}
+
+template std::vector<layout> sparse_to_dense_inst::calc_output_layouts<ov::PartialShape>(
+    sparse_to_dense_node const& node,
+    const kernel_impl_params& impl_param);
+
+std::string sparse_to_dense_inst::to_string(sparse_to_dense_node const& node) {
+    auto node_info = node.desc_to_json();
+    json_composite info;
+    info.add("channels_first", node.get_primitive()->channels_first);
+    info.add("flatten_output", node.get_primitive()->flatten_output);
+    info.add("batch_size", node.get_primitive()->batch_size);
+    node_info->add("SparseToDense info", info);
+
+    std::stringstream ss;
+    node_info->dump(ss);
+    return ss.str();
+}
+
+}  // namespace cldnn
