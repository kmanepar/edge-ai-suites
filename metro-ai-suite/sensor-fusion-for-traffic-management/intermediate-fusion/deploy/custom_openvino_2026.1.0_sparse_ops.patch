+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#pragma once
+
+#include "intel_gpu/graph/serialization/utils.hpp"
+#include "primitive.hpp"
+
+namespace cldnn {
+
+struct sparse_to_dense : public primitive_base<sparse_to_dense> {
+    CLDNN_DECLARE_PRIMITIVE(sparse_to_dense)
+
+    sparse_to_dense() : primitive_base("", {}) {}
+
+    sparse_to_dense(const primitive_id& id,
+                    const std::vector<input_info>& inputs,
+                    const std::vector<int64_t>& spatial_shape,
+                    int64_t batch_size,
+                    bool channels_first,
+                    bool flatten_output)
+        : primitive_base(id, inputs),
+          spatial_shape(spatial_shape),
+          batch_size(batch_size),
+          channels_first(channels_first),
+          flatten_output(flatten_output) {}
+
+    std::vector<int64_t> spatial_shape;
+    int64_t batch_size = 1;
+    bool channels_first = true;
+    bool flatten_output = false;
+
+    size_t hash() const override {
+        size_t seed = primitive::hash();
+        seed = hash_range(seed, spatial_shape.begin(), spatial_shape.end());
+        seed = hash_combine(seed, batch_size);
+        seed = hash_combine(seed, channels_first);
+        seed = hash_combine(seed, flatten_output);
+        return seed;
+    }
+
+    bool operator==(const primitive& rhs) const override {
+        if (!compare_common_params(rhs))
+            return false;
+
+        const auto& rhs_casted = downcast<const sparse_to_dense>(rhs);
+        return spatial_shape == rhs_casted.spatial_shape &&
+               batch_size == rhs_casted.batch_size &&
+               channels_first == rhs_casted.channels_first &&
+               flatten_output == rhs_casted.flatten_output;
+    }
+
+    void save(BinaryOutputBuffer& ob) const override {
+        primitive_base<sparse_to_dense>::save(ob);
+        ob << spatial_shape;
+        ob << batch_size;
+        ob << channels_first;
+        ob << flatten_output;
+    }
+
+    void load(BinaryInputBuffer& ib) override {
+        primitive_base<sparse_to_dense>::load(ib);
+        ib >> spatial_shape;
+        ib >> batch_size;
+        ib >> channels_first;
+        ib >> flatten_output;
+    }
+};
+
+}  // namespace cldnn
