+
+namespace ov::intel_gpu {
+
+namespace {
+
+std::vector<int64_t> constant_to_i64_vector(const std::shared_ptr<ov::Node>& node) {
+    const auto constant = ov::as_type_ptr<ov::op::v0::Constant>(node);
+    if (!constant)
+        return {};
+    return constant->cast_vector<int64_t>();
+}
+
+void CreateSparseToDenseOp(ProgramBuilder& p, const std::shared_ptr<ov::op::v15::SparseToDense>& op) {
+    OPENVINO_ASSERT(p.use_new_shape_infer(), "SparseToDense requires allow_new_shape_infer = true");
+    validate_inputs_count(op, {2, 4});
+
+    auto spatial_shape = op->get_spatial_shape();
+    auto batch_size = op->get_batch_size();
+    if (op->get_input_size() == 4) {
+        const auto spatial_shape_const = constant_to_i64_vector(op->get_input_node_shared_ptr(2));
+        const auto batch_size_const = constant_to_i64_vector(op->get_input_node_shared_ptr(3));
+        if (!spatial_shape_const.empty())
+            spatial_shape = spatial_shape_const;
+        if (!batch_size_const.empty())
+            batch_size = batch_size_const[0];
+    }
+
+    OPENVINO_ASSERT(spatial_shape.size() == 3,
+                    "SparseToDense requires a static spatial_shape from attributes or constant input 2");
+    OPENVINO_ASSERT(batch_size > 0,
+                    "SparseToDense requires a positive batch_size from attributes or constant input 3");
+
+    cldnn::sparse_to_dense primitive{layer_type_name_ID(op),
+                                     p.GetInputInfo(op),
+                                     spatial_shape,
+                                     batch_size,
+                                     op->get_channels_first(),
+                                     op->get_flatten_output()};
+    primitive.output_data_types = get_output_data_types(op);
+
+    p.add_primitive(*op, primitive);
+}
+
+}  // namespace
+
+REGISTER_FACTORY_IMPL(v15, SparseToDense);
+
+}  // namespace ov::intel_gpu
