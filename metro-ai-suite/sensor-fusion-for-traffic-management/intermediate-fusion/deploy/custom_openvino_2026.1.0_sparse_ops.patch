@@ -0,0 +1,166 @@
+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#pragma once
+
+#include "intel_gpu/graph/serialization/utils.hpp"
+#include "primitive.hpp"
+
+#include <string>
+
+namespace cldnn {
+
+struct sparse_convolution : public primitive_base<sparse_convolution> {
+    CLDNN_DECLARE_PRIMITIVE(sparse_convolution)
+
+    sparse_convolution() : primitive_base("", {}) {}
+
+    sparse_convolution(const primitive_id& id,
+                     const std::vector<input_info>& inputs,
+                     const std::vector<int64_t>& kernel_size,
+                     const std::vector<int64_t>& stride,
+                     const std::vector<int64_t>& padding,
+                     const std::vector<int64_t>& dilation,
+                     bool subm,
+                     uint32_t out_channels,
+                     const std::vector<int64_t>& input_spatial_shape,
+                     uint32_t in_channels = 0,
+                     const std::vector<int64_t>& output_spatial_shape = {},
+                     std::string activation = "None",
+                     uint32_t output_bound = 0,
+                     std::string rulebook = "",
+                     float input_abs_max = 0.0f)
+          : primitive_base(id, inputs, 2),
+          kernel_size(kernel_size),
+          stride(stride),
+          padding(padding),
+          dilation(dilation),
+          subm(subm),
+          out_channels(out_channels),
+            in_channels(in_channels),
+            input_spatial_shape(input_spatial_shape),
+            output_spatial_shape(output_spatial_shape),
+            activation(std::move(activation)),
+          output_bound(output_bound),
+            rulebook(std::move(rulebook)),
+                        input_abs_max(input_abs_max) {}
+
+        sparse_convolution(const primitive_id& id,
+                           const std::vector<input_info>& inputs,
+                           const std::vector<int64_t>& kernel_size,
+                           const std::vector<int64_t>& stride,
+                           const std::vector<int64_t>& padding,
+                           const std::vector<int64_t>& dilation,
+                           const std::vector<int64_t>& input_spatial_shape,
+                           bool subm,
+                           const std::vector<int64_t>& output_spatial_shape = {},
+                           bool fused_relu = false,
+                           uint32_t out_channels = 0,
+                           uint32_t output_bound = 0,
+                           std::string rulebook = "",
+                           float input_abs_max = 0.0f)
+            : sparse_convolution(id,
+                                 inputs,
+                                 kernel_size,
+                                 stride,
+                                 padding,
+                                 dilation,
+                                 subm,
+                                 out_channels,
+                                 input_spatial_shape,
+                                 0,
+                                 output_spatial_shape,
+                                 fused_relu ? "ReLU" : "None",
+                                 output_bound,
+                                 std::move(rulebook),
+                                 input_abs_max) {}
+
+    std::vector<int64_t> kernel_size;
+    std::vector<int64_t> stride;
+    std::vector<int64_t> padding;
+    std::vector<int64_t> dilation;
+    bool subm = false;
+    uint32_t out_channels = 0;
+    uint32_t in_channels = 0;
+    std::vector<int64_t> input_spatial_shape;
+    std::vector<int64_t> output_spatial_shape;
+    std::string activation = "None";
+    uint32_t output_bound = 0;
+    std::string rulebook;
+    float input_abs_max = 0.0f;
+
+    size_t hash() const override {
+        size_t seed = primitive::hash();
+        seed = hash_range(seed, kernel_size.begin(), kernel_size.end());
+        seed = hash_range(seed, stride.begin(), stride.end());
+        seed = hash_range(seed, padding.begin(), padding.end());
+        seed = hash_range(seed, dilation.begin(), dilation.end());
+        seed = hash_combine(seed, subm);
+        seed = hash_combine(seed, out_channels);
+        seed = hash_combine(seed, in_channels);
+        seed = hash_range(seed, input_spatial_shape.begin(), input_spatial_shape.end());
+        seed = hash_range(seed, output_spatial_shape.begin(), output_spatial_shape.end());
+        seed = hash_combine(seed, std::hash<std::string>{}(activation));
+        seed = hash_combine(seed, output_bound);
+        seed = hash_combine(seed, std::hash<std::string>{}(rulebook));
+        seed = hash_combine(seed, std::hash<float>{}(input_abs_max));
+        return seed;
+    }
+
+    bool operator==(const primitive& rhs) const override {
+        if (!compare_common_params(rhs))
+            return false;
+
+        const auto& rhs_casted = downcast<const sparse_convolution>(rhs);
+        return kernel_size == rhs_casted.kernel_size &&
+               stride == rhs_casted.stride &&
+               padding == rhs_casted.padding &&
+               dilation == rhs_casted.dilation &&
+               subm == rhs_casted.subm &&
+               out_channels == rhs_casted.out_channels &&
+               in_channels == rhs_casted.in_channels &&
+               input_spatial_shape == rhs_casted.input_spatial_shape &&
+               output_spatial_shape == rhs_casted.output_spatial_shape &&
+               activation == rhs_casted.activation &&
+               output_bound == rhs_casted.output_bound &&
+               rulebook == rhs_casted.rulebook &&
+               input_abs_max == rhs_casted.input_abs_max;
+    }
+
+    void save(BinaryOutputBuffer& ob) const override {
+        primitive_base<sparse_convolution>::save(ob);
+        ob << kernel_size;
+        ob << stride;
+        ob << padding;
+        ob << dilation;
+        ob << subm;
+        ob << out_channels;
+        ob << in_channels;
+        ob << input_spatial_shape;
+        ob << output_spatial_shape;
+        ob << activation;
+        ob << output_bound;
+        ob << rulebook;
+        ob << input_abs_max;
+    }
+
+    void load(BinaryInputBuffer& ib) override {
+        primitive_base<sparse_convolution>::load(ib);
+        ib >> kernel_size;
+        ib >> stride;
+        ib >> padding;
+        ib >> dilation;
+        ib >> subm;
+        ib >> out_channels;
+        ib >> in_channels;
+        ib >> input_spatial_shape;
+        ib >> output_spatial_shape;
+        ib >> activation;
+        ib >> output_bound;
+        ib >> rulebook;
+        ib >> input_abs_max;
+    }
+};
+
+}  // namespace cldnn
