+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+// Shared actual-M map for sparse operations.
+//
+// Sparse convolution kernels store actual output voxel counts keyed by the output
+// coordinate buffer pointer.  SparseToDense reads them so it only scatters
+// valid voxels instead of iterating over the entire pre-allocated buffer.
+
+#pragma once
+
+#include <algorithm>
+#include <cstddef>
+#include <cstdint>
+#include <mutex>
+#include <unordered_map>
+#include <vector>
+
+namespace cldnn {
+namespace sycl {
+
+struct sparse_actual_m_entry {
+    int actual_m = 0;
+    size_t capacity_rows = 0;
+    uint64_t sequence = 0;
+    uint64_t generation = 0;
+};
+
+inline std::unordered_map<const void*, sparse_actual_m_entry>& sparse_actual_m_entry_map() {
+    static std::unordered_map<const void*, sparse_actual_m_entry> map;
+    return map;
+}
+
+inline std::mutex& sparse_actual_m_map_mtx() {
+    static std::mutex mtx;
+    return mtx;
+}
+
+inline uint64_t& sparse_actual_m_sequence() {
+    static uint64_t sequence = 0;
+    return sequence;
+}
+
+inline void prune_sparse_actual_m_maps_unlocked() {
+    constexpr size_t max_entries = 16384;
+    constexpr size_t target_entries = 12288;
+    auto& map = sparse_actual_m_entry_map();
+    if (map.size() <= max_entries)
+        return;
+
+    std::vector<std::pair<const void*, uint64_t>> ordered;
+    ordered.reserve(map.size());
+    for (const auto& item : map) {
+        ordered.emplace_back(item.first, item.second.sequence);
+    }
+    std::sort(ordered.begin(), ordered.end(), [](const auto& lhs, const auto& rhs) {
+        return lhs.second < rhs.second;
+    });
+
+    const size_t remove_count = ordered.size() > target_entries ? ordered.size() - target_entries : 0;
+    for (size_t idx = 0; idx < remove_count; ++idx) {
+        map.erase(ordered[idx].first);
+    }
+}
+
+inline void set_sparse_actual_m(const void* buffer, int actual_m, size_t capacity_rows, uint64_t generation = 0) {
+    if (buffer == nullptr)
+        return;
+
+    std::lock_guard<std::mutex> lock(sparse_actual_m_map_mtx());
+    sparse_actual_m_entry_map()[buffer] = {actual_m, capacity_rows, ++sparse_actual_m_sequence(), generation};
+    prune_sparse_actual_m_maps_unlocked();
+}
+
+inline bool get_sparse_actual_m(const void* buffer, size_t capacity_rows, int& actual_m, uint64_t generation = 0) {
+    if (buffer == nullptr || capacity_rows == 0)
+        return false;
+
+    std::lock_guard<std::mutex> lock(sparse_actual_m_map_mtx());
+    auto entry_it = sparse_actual_m_entry_map().find(buffer);
+    if (entry_it != sparse_actual_m_entry_map().end()) {
+        auto& entry = entry_it->second;
+        if (generation != 0 && entry.generation != generation) {
+            sparse_actual_m_entry_map().erase(entry_it);
+            return false;
+        }
+        if (entry.actual_m > 0 &&
+            static_cast<size_t>(entry.actual_m) <= capacity_rows &&
+            (entry.capacity_rows == 0 || entry.capacity_rows == capacity_rows)) {
+            entry.sequence = ++sparse_actual_m_sequence();
+            actual_m = entry.actual_m;
+            return true;
+        }
+        sparse_actual_m_entry_map().erase(entry_it);
+    }
+
+    return false;
+}
+
+inline void clear_sparse_actual_m() {
+    std::lock_guard<std::mutex> lock(sparse_actual_m_map_mtx());
+    sparse_actual_m_entry_map().clear();
+}
+
