+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#pragma once
+
+#include <array>
+#include <cstddef>
+#include <cstdint>
+#include <set>
+#include <unordered_map>
+#include <unordered_set>
+#include <vector>
+
+namespace ov {
+namespace reference {
+
+struct SparseConvolutionMetadata {
+    std::vector<int64_t> out_indices;
+
+    size_t num_points() const {
+        return out_indices.size() / 4;
+    }
+};
+
+struct SparseCoord4 {
+    int64_t batch = 0;
+    int64_t z = 0;
+    int64_t y = 0;
+    int64_t x = 0;
+
+    bool operator==(const SparseCoord4& other) const {
+        return batch == other.batch && z == other.z && y == other.y && x == other.x;
+    }
+};
+
+struct SparseCoord4Hash {
+    size_t operator()(const SparseCoord4& coord) const noexcept {
+        size_t seed = 0;
+        const auto hash_combine = [&seed](int64_t value) {
+            const auto hashed = std::hash<int64_t>{}(value);
+            seed ^= hashed + 0x9e3779b97f4a7c15ULL + (seed << 6) + (seed >> 2);
+        };
+        hash_combine(coord.batch);
+        hash_combine(coord.z);
+        hash_combine(coord.y);
+        hash_combine(coord.x);
+        return seed;
+    }
+};
+
+inline bool has_positive_values(const std::array<int64_t, 3>& values) {
+    for (const auto value : values) {
+        if (value <= 0)
+            return false;
+    }
+
+    return true;
+}
+
+inline bool has_non_negative_values(const std::array<int64_t, 3>& values) {
+    for (const auto value : values) {
+        if (value < 0)
+            return false;
+    }
+
+    return true;
+}
+
+inline bool compute_sparse_convolution_output_spatial_shape(const std::array<int64_t, 3>& spatial_shape,
+                                                       const std::array<int64_t, 3>& kernel_size,
+                                                       const std::array<int64_t, 3>& stride,
+                                                       const std::array<int64_t, 3>& padding,
+                                                       const std::array<int64_t, 3>& dilation,
+                                                       bool subm,
+                                                       std::array<int64_t, 3>& output_spatial_shape) {
+    if (!has_positive_values(spatial_shape) || !has_positive_values(kernel_size) || !has_positive_values(stride) ||
+        !has_positive_values(dilation) || !has_non_negative_values(padding)) {
+        return false;
+    }
+
+    if (subm) {
+        for (size_t axis = 0; axis < stride.size(); ++axis) {
+            if (stride[axis] != 1)
+                return false;
+        }
+
+        output_spatial_shape = spatial_shape;
+        return true;
+    }
+
+    for (size_t axis = 0; axis < spatial_shape.size(); ++axis) {
+        const auto numerator = spatial_shape[axis] + 2 * padding[axis] - dilation[axis] * (kernel_size[axis] - 1) - 1;
+        output_spatial_shape[axis] = numerator < 0 ? 0 : numerator / stride[axis] + 1;
+    }
+
+    return true;
+}
+
+inline bool compute_sparse_convolution_metadata(const int64_t* indices,
+                                           size_t num_points,
+                                           size_t index_stride,
+                                           const std::array<int64_t, 3>& spatial_shape,
+                                           const std::array<int64_t, 3>& kernel_size,
+                                           const std::array<int64_t, 3>& stride,
+                                           const std::array<int64_t, 3>& padding,
+                                           const std::array<int64_t, 3>& dilation,
+                                           bool subm,
+                                           SparseConvolutionMetadata& metadata,
+                                           const std::array<int64_t, 3>& explicit_output_spatial_shape = {0, 0, 0}) {
+    metadata = {};
+
+    if (indices == nullptr || index_stride < 4)
+        return false;
+
+    std::array<int64_t, 3> out_spatial_shape{};
+    if (explicit_output_spatial_shape[0] > 0 && explicit_output_spatial_shape[1] > 0 && explicit_output_spatial_shape[2] > 0) {
+        out_spatial_shape = explicit_output_spatial_shape;
+    } else if (!compute_sparse_convolution_output_spatial_shape(spatial_shape, kernel_size, stride, padding, dilation, subm, out_spatial_shape)) {
+        return false;
+    }
+
+    using SparseCoord = std::array<int64_t, 4>;
+    std::set<SparseCoord> output_coords;
+
+    for (size_t point = 0; point < num_points; ++point) {
+        const auto* row = indices + point * index_stride;
+        const SparseCoord input_coord{{row[0], row[1], row[2], row[3]}};
+
+        if (input_coord[0] < 0)
+            continue;
+        if (input_coord[1] < 0 || input_coord[1] >= spatial_shape[0])
+            continue;
+        if (input_coord[2] < 0 || input_coord[2] >= spatial_shape[1])
+            continue;
+        if (input_coord[3] < 0 || input_coord[3] >= spatial_shape[2])
+            continue;
+
+        if (subm) {
+            output_coords.insert(input_coord);
+            continue;
+        }
+
+        for (int64_t kernel_z = 0; kernel_z < kernel_size[0]; ++kernel_z) {
+            const auto numerator_z = input_coord[1] + padding[0] - kernel_z * dilation[0];
+            if (numerator_z < 0 || numerator_z % stride[0] != 0)
+                continue;
+
+            const auto output_z = numerator_z / stride[0];
+            if (output_z < 0 || output_z >= out_spatial_shape[0])
+                continue;
+
+            for (int64_t kernel_y = 0; kernel_y < kernel_size[1]; ++kernel_y) {
+                const auto numerator_y = input_coord[2] + padding[1] - kernel_y * dilation[1];
+                if (numerator_y < 0 || numerator_y % stride[1] != 0)
+                    continue;
+
+                const auto output_y = numerator_y / stride[1];
+                if (output_y < 0 || output_y >= out_spatial_shape[1])
+                    continue;
+
+                for (int64_t kernel_x = 0; kernel_x < kernel_size[2]; ++kernel_x) {
+                    const auto numerator_x = input_coord[3] + padding[2] - kernel_x * dilation[2];
+                    if (numerator_x < 0 || numerator_x % stride[2] != 0)
+                        continue;
+
+                    const auto output_x = numerator_x / stride[2];
+                    if (output_x < 0 || output_x >= out_spatial_shape[2])
+                        continue;
+
+                    output_coords.insert(SparseCoord{{input_coord[0], output_z, output_y, output_x}});
+                }
+            }
+        }
+    }
+
+    metadata.out_indices.reserve(output_coords.size() * 4);
+    for (const auto& coord : output_coords) {
+        metadata.out_indices.insert(metadata.out_indices.end(), coord.begin(), coord.end());
+    }
+
+    return true;
+}
+
+inline bool count_sparse_convolution_output_points(const int64_t* indices,
+                                              size_t num_points,
+                                              size_t index_stride,
+                                              const std::array<int64_t, 3>& spatial_shape,
+                                              const std::array<int64_t, 3>& kernel_size,
+                                              const std::array<int64_t, 3>& stride,
+                                              const std::array<int64_t, 3>& padding,
+                                              const std::array<int64_t, 3>& dilation,
+                                              bool subm,
+                                              size_t& output_point_count,
+                                              const std::array<int64_t, 3>& explicit_output_spatial_shape = {0, 0, 0}) {
+    output_point_count = 0;
+
+    if (indices == nullptr || index_stride < 4)
+        return false;
+
+    std::array<int64_t, 3> out_spatial_shape{};
+    if (explicit_output_spatial_shape[0] > 0 && explicit_output_spatial_shape[1] > 0 && explicit_output_spatial_shape[2] > 0) {
+        out_spatial_shape = explicit_output_spatial_shape;
+    } else if (!compute_sparse_convolution_output_spatial_shape(spatial_shape,
+                                                           kernel_size,
+                                                           stride,
+                                                           padding,
+                                                           dilation,
+                                                           subm,
+                                                           out_spatial_shape)) {
+        return false;
+    }
+
+    if (subm) {
+        output_point_count = num_points;
+        return true;
+    }
+
+    int64_t max_batch = 0;
+    for (size_t point = 0; point < num_points; ++point) {
+        const auto batch = indices[point * index_stride];
+        if (batch > max_batch)
+            max_batch = batch;
+    }
+
+    const auto oZ = out_spatial_shape[0];
+    const auto oY = out_spatial_shape[1];
+    const auto oX = out_spatial_shape[2];
+    const auto grid_volume = static_cast<size_t>(oZ) * static_cast<size_t>(oY) * static_cast<size_t>(oX);
+
+    const bool use_flat_grid = (max_batch == 0) && (grid_volume > 0) && (grid_volume < 64 * 1024 * 1024);
+
+    if (use_flat_grid) {
+        std::vector<uint8_t> grid(grid_volume, 0);
+        size_t count = 0;
+
+        for (size_t point = 0; point < num_points; ++point) {
+            const auto* row = indices + point * index_stride;
+            const auto iz = row[1], iy = row[2], ix = row[3];
+
+            if (iz < 0 || iz >= spatial_shape[0])
+                continue;
+            if (iy < 0 || iy >= spatial_shape[1])
+                continue;
+            if (ix < 0 || ix >= spatial_shape[2])
+                continue;
+
+            for (int64_t kz = 0; kz < kernel_size[0]; ++kz) {
+                const auto nz = iz + padding[0] - kz * dilation[0];
+                if (nz < 0 || nz % stride[0] != 0)
+                    continue;
+                const auto oz = nz / stride[0];
+                if (oz < 0 || oz >= oZ)
+                    continue;
+
+                for (int64_t ky = 0; ky < kernel_size[1]; ++ky) {
+                    const auto ny = iy + padding[1] - ky * dilation[1];
+                    if (ny < 0 || ny % stride[1] != 0)
+                        continue;
+                    const auto oy = ny / stride[1];
+                    if (oy < 0 || oy >= oY)
+                        continue;
+
+                    for (int64_t kx = 0; kx < kernel_size[2]; ++kx) {
+                        const auto nx = ix + padding[2] - kx * dilation[2];
+                        if (nx < 0 || nx % stride[2] != 0)
+                            continue;
+                        const auto ox = nx / stride[2];
+                        if (ox < 0 || ox >= oX)
+                            continue;
+
+                        const auto flat_idx = static_cast<size_t>(oz) * static_cast<size_t>(oY * oX) +
+                                              static_cast<size_t>(oy) * static_cast<size_t>(oX) +
+                                              static_cast<size_t>(ox);
+                        if (!grid[flat_idx]) {
+                            grid[flat_idx] = 1;
+                            ++count;
+                        }
+                    }
+                }
+            }
+        }
+        output_point_count = count;
+        return true;
+    }
+
+    std::unordered_set<SparseCoord4, SparseCoord4Hash> output_coords;
+    output_coords.reserve(num_points);
+
+    for (size_t point = 0; point < num_points; ++point) {
+        const auto* row = indices + point * index_stride;
+        const SparseCoord4 input_coord{row[0], row[1], row[2], row[3]};
+
+        if (input_coord.batch < 0)
+            continue;
+        if (input_coord.z < 0 || input_coord.z >= spatial_shape[0])
+            continue;
+        if (input_coord.y < 0 || input_coord.y >= spatial_shape[1])
+            continue;
+        if (input_coord.x < 0 || input_coord.x >= spatial_shape[2])
+            continue;
+
+        for (int64_t kz = 0; kz < kernel_size[0]; ++kz) {
+            const auto nz = input_coord.z + padding[0] - kz * dilation[0];
+            if (nz < 0 || nz % stride[0] != 0)
+                continue;
+            const auto oz = nz / stride[0];
+            if (oz < 0 || oz >= out_spatial_shape[0])
+                continue;
+
+            for (int64_t ky = 0; ky < kernel_size[1]; ++ky) {
+                const auto ny = input_coord.y + padding[1] - ky * dilation[1];
+                if (ny < 0 || ny % stride[1] != 0)
+                    continue;
+                const auto oy = ny / stride[1];
+                if (oy < 0 || oy >= out_spatial_shape[1])
+                    continue;
+
+                for (int64_t kx = 0; kx < kernel_size[2]; ++kx) {
+                    const auto nx = input_coord.x + padding[2] - kx * dilation[2];
+                    if (nx < 0 || nx % stride[2] != 0)
+                        continue;
+                    const auto ox = nx / stride[2];
+                    if (ox < 0 || ox >= out_spatial_shape[2])
+                        continue;
+
+                    output_coords.insert(SparseCoord4{input_coord.batch, oz, oy, ox});
+                }
+            }
+        }
+    }
+
+    output_point_count = output_coords.size();
+    return true;
+}
+
+inline bool resolve_sparse_convolution_output_spatial_shape(const std::array<int64_t, 3>& spatial_shape,
+                                                       const std::array<int64_t, 3>& kernel_size,
+                                                       const std::array<int64_t, 3>& stride,
+                                                       const std::array<int64_t, 3>& padding,
+                                                       const std::array<int64_t, 3>& dilation,
+                                                       bool subm,
+                                                       const std::array<int64_t, 3>& explicit_output_spatial_shape,
+                                                       std::array<int64_t, 3>& output_spatial_shape) {
+    if (explicit_output_spatial_shape[0] > 0 && explicit_output_spatial_shape[1] > 0 && explicit_output_spatial_shape[2] > 0) {
+        output_spatial_shape = explicit_output_spatial_shape;
+        return true;
+    }
+
+    return compute_sparse_convolution_output_spatial_shape(
+        spatial_shape, kernel_size, stride, padding, dilation, subm, output_spatial_shape);
+}
+
+template <typename T>
+inline bool sparse_convolution(const T* features,
+                          size_t num_points,
+                          size_t in_channels,
+                          const int64_t* indices,
+                          size_t index_stride,
+                          const T* weights,
+                          size_t out_channels,
+                          const T* bias,
+                          const std::array<int64_t, 3>& spatial_shape,
+                          const std::array<int64_t, 3>& kernel_size,
+                          const std::array<int64_t, 3>& stride,
+                          const std::array<int64_t, 3>& padding,
+                          const std::array<int64_t, 3>& dilation,
+                          bool subm,
+                          const SparseConvolutionMetadata& metadata,
+                          T* output_features,
+                          const std::array<int64_t, 3>& explicit_output_spatial_shape = {0, 0, 0},
+                          bool fused_relu = false) {
+    if (features == nullptr || indices == nullptr || weights == nullptr || output_features == nullptr || index_stride < 4)
+        return false;
+
+    if (metadata.out_indices.size() % 4 != 0)
+        return false;
+
+    const auto num_output_points = metadata.num_points();
+    std::unordered_map<SparseCoord4, size_t, SparseCoord4Hash> input_row_by_coord;
+    input_row_by_coord.reserve(num_points * 2 + 1);
+    for (size_t point = 0; point < num_points; ++point) {
+        const auto* row = indices + point * index_stride;
+        const SparseCoord4 input_coord{row[0], row[1], row[2], row[3]};
+        if (input_coord.batch < 0)
+            continue;
+        if (input_coord.z < 0 || input_coord.z >= spatial_shape[0])
+            continue;
+        if (input_coord.y < 0 || input_coord.y >= spatial_shape[1])
+            continue;
+        if (input_coord.x < 0 || input_coord.x >= spatial_shape[2])
+            continue;
+        input_row_by_coord.emplace(input_coord, point);
+    }
+
+    std::vector<double> accum(num_output_points * out_channels, 0.0);
+    if (bias != nullptr) {
+        for (size_t output_point = 0; output_point < num_output_points; ++output_point) {
+            auto* dst = accum.data() + output_point * out_channels;
+            for (size_t output_channel = 0; output_channel < out_channels; ++output_channel) {
+                dst[output_channel] = static_cast<double>(bias[output_channel]);
+            }
+        }
+    }
+
+    for (size_t output_point = 0; output_point < num_output_points; ++output_point) {
+        const auto offset = output_point * 4;
+        const SparseCoord4 output_coord{metadata.out_indices[offset + 0],
+                                        metadata.out_indices[offset + 1],
+                                        metadata.out_indices[offset + 2],
+                                        metadata.out_indices[offset + 3]};
+        auto* dst = accum.data() + output_point * out_channels;
+
+        size_t kernel_index = 0;
+        for (int64_t kernel_z = 0; kernel_z < kernel_size[0]; ++kernel_z) {
+            for (int64_t kernel_y = 0; kernel_y < kernel_size[1]; ++kernel_y) {
+                for (int64_t kernel_x = 0; kernel_x < kernel_size[2]; ++kernel_x, ++kernel_index) {
+                    const SparseCoord4 input_coord{output_coord.batch,
+                                                   output_coord.z * stride[0] - padding[0] + kernel_z * dilation[0],
+                                                   output_coord.y * stride[1] - padding[1] + kernel_y * dilation[1],
+                                                   output_coord.x * stride[2] - padding[2] + kernel_x * dilation[2]};
+                    if (input_coord.z < 0 || input_coord.z >= spatial_shape[0])
+                        continue;
+                    if (input_coord.y < 0 || input_coord.y >= spatial_shape[1])
+                        continue;
+                    if (input_coord.x < 0 || input_coord.x >= spatial_shape[2])
+                        continue;
+
+                    const auto found = input_row_by_coord.find(input_coord);
+                    if (found == input_row_by_coord.end())
+                        continue;
+
+                    const auto* src = features + found->second * in_channels;
+                    const auto* kernel_weights = weights + kernel_index * in_channels * out_channels;
+                    for (size_t input_channel = 0; input_channel < in_channels; ++input_channel) {
+                        const auto input_value = static_cast<double>(src[input_channel]);
+                        if (input_value == 0.0)
+                            continue;
+                        const auto* kernel_row = kernel_weights + input_channel * out_channels;
+                        for (size_t output_channel = 0; output_channel < out_channels; ++output_channel) {
+                            dst[output_channel] += input_value * static_cast<double>(kernel_row[output_channel]);
+                        }
+                    }
+                }
+            }
+        }
+    }
+
+    for (size_t index = 0; index < accum.size(); ++index) {
+        auto value = accum[index];
+        if (fused_relu && value < 0.0)
+            value = 0.0;
+        output_features[index] = static_cast<T>(value);
+    }
+    return true;
+}
