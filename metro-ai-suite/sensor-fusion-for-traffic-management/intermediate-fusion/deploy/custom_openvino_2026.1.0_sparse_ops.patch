+class TypePropSparseConvolutionTest : public ::testing::Test {};
+
+TEST_F(TypePropSparseConvolutionTest, default_ctor) {
+    auto features = make_shared<ov::op::v0::Parameter>(element::f32, PartialShape{10, 16});
+    auto indices = make_shared<ov::op::v0::Parameter>(element::i32, PartialShape{10, 4});
+    auto weight = make_shared<ov::op::v0::Parameter>(element::f32, PartialShape{27, 16, 32});
+    auto bias = make_shared<ov::op::v0::Parameter>(element::f32, PartialShape{32});
+
+    auto op = make_shared<ov::op::v15::SparseConvolution>(features,
+                                                          indices,
+                                                          weight,
+                                                          bias,
+                                                          vector<int64_t>{3, 3, 3},
+                                                          vector<int64_t>{2, 2, 2},
+                                                          vector<int64_t>{1, 1, 1},
+                                                          vector<int64_t>{1, 1, 1},
+                                                          false,
+                                                          0,
+                                                          vector<int64_t>{10, 10, 10});
+
+    EXPECT_EQ(op->get_output_size(), 2);
+    EXPECT_EQ(op->get_output_element_type(0), element::f32);
+    EXPECT_EQ(op->get_output_element_type(1), element::i32);
+    EXPECT_TRUE(op->get_output_partial_shape(0)[0].is_dynamic());
+    EXPECT_EQ(op->get_output_partial_shape(0)[1].get_length(), 32);
+    EXPECT_TRUE(op->get_output_partial_shape(1)[0].is_dynamic());
+    EXPECT_EQ(op->get_output_partial_shape(1)[1].get_length(), 4);
+}
