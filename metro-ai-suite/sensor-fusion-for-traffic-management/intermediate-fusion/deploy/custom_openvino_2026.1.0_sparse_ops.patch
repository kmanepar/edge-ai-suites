+bool SparseConvolution::visit_attributes(AttributeVisitor& visitor) {
+    visitor.on_attribute("kernel_size", m_kernel_size);
+    visitor.on_attribute("stride", m_stride);
+    visitor.on_attribute("padding", m_padding);
+    visitor.on_attribute("dilation", m_dilation);
+    visitor.on_attribute("subm", m_subm);
+    visitor.on_attribute("out_channels", m_out_channels);
+    visitor.on_attribute("in_channels", m_in_channels);
+    visitor.on_attribute("input_spatial_shape", m_input_spatial_shape);
