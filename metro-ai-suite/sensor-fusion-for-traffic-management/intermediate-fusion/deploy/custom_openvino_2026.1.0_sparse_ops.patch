+std::vector<int64_t> get_ints_attr(const ov::frontend::onnx::Node& node,
+                                   const std::string& name,
+                                   const std::vector<int64_t>& default_value) {
+    const auto values = node.get_attribute_value<std::vector<int64_t>>(name, default_value);
+    CHECK_VALID_NODE(node,
+                     values.size() == 3,
+                     "Attribute '",
+                     name,
+                     "' must contain exactly 3 elements. Got: ",
+                     values.size());
+    return values;
+}
+
+}  // namespace
+
+ov::OutputVector sparse_convolution(const ov::frontend::onnx::Node& node) {
+    const auto inputs = node.get_ov_inputs();
+    CHECK_VALID_NODE(node,
+                     inputs.size() == 4,
+                     "SparseConvolution expects exactly 4 inputs: features, indices, weight, bias. Got: ",
+                     inputs.size());
+
+    const auto kernel_size = get_ints_attr(node, "kernel_size", {1, 1, 1});
+    const auto stride = get_ints_attr(node, "stride", {1, 1, 1});
+    const auto padding = get_ints_attr(node, "padding", {0, 0, 0});
+    const auto dilation = get_ints_attr(node, "dilation", {1, 1, 1});
+    auto spatial_shape = get_ints_attr(node, "input_spatial_shape",
+                            node.get_attribute_value<std::vector<int64_t>>("spatial_shape", {1, 1, 1}));
+    if (spatial_shape.size() != 3)
+        spatial_shape = get_ints_attr(node, "spatial_shape", {1, 1, 1});
+    auto output_spatial_shape = node.get_attribute_value<std::vector<int64_t>>("output_spatial_shape", std::vector<int64_t>{});
+    if (output_spatial_shape.empty()) {
+        output_spatial_shape = node.get_attribute_value<std::vector<int64_t>>("output_spatial_shape_i", std::vector<int64_t>{});
+    }
+    auto out_channels = node.get_attribute_value<int64_t>("out_channels", -1);
+    if (out_channels <= 0) {
+        out_channels = node.get_attribute_value<int64_t>("out_channels_i", -1);
+    }
+    auto in_channels = node.get_attribute_value<int64_t>("in_channels", -1);
+    if (in_channels <= 0) {
+        in_channels = node.get_attribute_value<int64_t>("in_channels_i", -1);
+    }
+    auto subm_val = node.get_attribute_value<int64_t>("submanifold", node.get_attribute_value<int64_t>("subm", -1));
+    if (subm_val < 0) {
+        subm_val = node.get_attribute_value<int64_t>("submanifold_i", 0);
+    }
+    const auto subm = subm_val != 0;
+    auto activation = node.get_attribute_value<std::string>("activation_s",
+                          node.get_attribute_value<std::string>("activation", "None"));
+    if (activation.empty())
+        activation = "None";
+
+    if (out_channels > 0) {
+        const auto weight_ps = inputs.at(2).get_partial_shape();
+        if (weight_ps.rank().is_static() && weight_ps[2].is_static()) {
+            CHECK_VALID_NODE(node,
+                             weight_ps[2].get_length() == out_channels,
+                             "Attribute 'out_channels' must match weight.shape[2]. Got out_channels=",
+                             out_channels,
+                             ", weight.shape[2]=",
+                             weight_ps[2].get_length());
+        }
+    }
+
+    // Parse output_bound for shape inference optimization
+    auto output_bound_val = node.get_attribute_value<int64_t>("output_bound", -1);
+    if (output_bound_val < 0)
+        output_bound_val = node.get_attribute_value<int64_t>("output_bound_i", 0);
+    const auto rulebook = node.get_attribute_value<std::string>("rulebook_s",
+                              node.get_attribute_value<std::string>("rulebook", ""));
+    const auto input_abs_max = node.get_attribute_value<float>("input_abs_max", 0.0f);
+
+    if (output_spatial_shape.empty())
+        output_spatial_shape = {0, 0, 0};
+
+    auto sc_op = std::make_shared<ov::op::v15::SparseConvolution>(inputs.at(0),
+                                                                  inputs.at(1),
+                                                                  inputs.at(2),
+                                                                  inputs.at(3),
+                                                                  kernel_size,
+                                                                  stride,
+                                                                  padding,
+                                                                  dilation,
+                                                                  subm,
+                                                                  out_channels > 0 ? out_channels : 0,
+                                                                  spatial_shape,
+                                                                  in_channels > 0 ? in_channels : 0,
+                                                                  output_spatial_shape,
+                                                                  activation,
+                                                                  output_bound_val > 0 ? output_bound_val : 0,
+                                                                  rulebook,
+                                                                  input_abs_max);
+
+    // Store extra attributes in runtime info for the GPU plugin bridge
+    auto& rt = sc_op->get_rt_info();
+    rt["out_channels"] = static_cast<int64_t>(out_channels > 0 ? out_channels : 0);
+    rt["in_channels"] = static_cast<int64_t>(in_channels > 0 ? in_channels : 0);
+    rt["output_bound"] = static_cast<int64_t>(output_bound_val > 0 ? output_bound_val : 0);
+    rt["rulebook"] = rulebook;
+
+    return sc_op->outputs();
+}
+
+static bool register_sparse_convolution_translator(void) {
+    ONNX_OP_M("SparseConvolution", OPSET_SINCE(1), org_openvinotoolkit::opset_1::sparse_convolution, OPENVINO_ONNX_DOMAIN);
+    return true;
+}
+
+static bool registered = register_sparse_convolution_translator();
+
+}  // namespace opset_1
