+    visitor.on_attribute("activation", m_activation);
+    visitor.on_attribute("output_bound", m_output_bound);
+    visitor.on_attribute("rulebook", m_rulebook);
+    visitor.on_attribute("input_abs_max", m_input_abs_max);
