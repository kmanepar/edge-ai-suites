+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#include "intel_gpu/plugin/common_utils.hpp"
+#include "intel_gpu/plugin/program_builder.hpp"
+#include "intel_gpu/primitives/sparse_convolution.hpp"
+#include "openvino/op/sparse_convolution.hpp"
+
+#include <limits>
+
+namespace ov::intel_gpu {
+namespace {
+
+void CreateSparseConvolutionOp(ProgramBuilder& p,
+                               const std::shared_ptr<ov::op::v15::SparseConvolution>& op) {
+    OPENVINO_ASSERT(p.use_new_shape_infer(), "SparseConvolution requires allow_new_shape_infer = true");
+    validate_inputs_count(op, {4});
+
+    auto to_u32 = [](int64_t value, const char* name) -> uint32_t {
+        OPENVINO_ASSERT(value >= 0 && value <= static_cast<int64_t>(std::numeric_limits<uint32_t>::max()),
+                        "SparseConvolution attribute '",
+                        name,
+                        "' is out of uint32 range: ",
+                        value);
+        return static_cast<uint32_t>(value);
+    };
+
+    int64_t out_channels = op->get_out_channels();
+    int64_t output_bound = op->get_output_bound();
+    std::string rulebook = op->get_rulebook();
+    const auto& rt = op->get_rt_info();
+    if (out_channels <= 0) {
+        if (auto it = rt.find("out_channels"); it != rt.end())
+            out_channels = it->second.as<int64_t>();
+    }
+    if (output_bound <= 0) {
+        if (auto it = rt.find("output_bound"); it != rt.end())
+            output_bound = it->second.as<int64_t>();
+    }
+    if (rulebook.empty()) {
+        if (auto it = rt.find("rulebook"); it != rt.end())
+            rulebook = it->second.as<std::string>();
+    }
+    if (out_channels <= 0) {
+        const auto& weight_shape = op->get_input_partial_shape(2);
+        if (weight_shape.rank().is_static() && weight_shape.rank().get_length() == 3 && weight_shape[2].is_static())
+            out_channels = weight_shape[2].get_length();
+    }
+
+    cldnn::sparse_convolution primitive{layer_type_name_ID(op),
+                                   p.GetInputInfo(op),
+                                   op->get_kernel_size(),
+                                   op->get_stride(),
+                                   op->get_padding(),
+                                   op->get_dilation(),
+                                   op->is_subm(),
+                                   to_u32(out_channels, "out_channels"),
+                                   op->get_input_spatial_shape(),
+                                   to_u32(op->get_in_channels(), "in_channels"),
+                                   op->get_output_spatial_shape(),
+                                   op->get_activation(),
+                                   to_u32(output_bound, "output_bound"),
+                                   rulebook,
+                                   op->get_input_abs_max()};
+    primitive.output_data_types = get_output_data_types(op);
+
+    p.add_primitive(*op, primitive);
+}
+
+}  // namespace
+
+REGISTER_FACTORY_IMPL(v15, SparseConvolution);
+
+}  // namespace ov::intel_gpu
