+// V2 minuet handles same-layer reuse internally. The wrapper adds a validated
+// same-frame SubM cache so layers sharing a rulebook can borrow the same LUT.
+
+float clamp_quant_abs_max(float abs_max) {
+    return abs_max > 1e-8f ? abs_max : 1e-8f;
+}
+
+int align_up_int(int value, int align) {
+    return ((value + align - 1) / align) * align;
+}
+
+template <typename T>
+::sycl::event quantize_tensor_to_int8(::sycl::queue& q,
+                                      const T* input,
+                                      int8_t* output,
+                                      size_t count,
+                                      float abs_max) {
+    const float scale_inv = 127.0f / clamp_quant_abs_max(abs_max);
+    return q.parallel_for(::sycl::range<1>(count), [=](::sycl::id<1> id) {
+        const auto idx = id[0];
+        float scaled = static_cast<float>(input[idx]) * scale_inv;
+        int value = static_cast<int>(::sycl::round(scaled));
+        value = value > 127 ? 127 : value;
+        value = value < -127 ? -127 : value;
+        output[idx] = static_cast<int8_t>(value);
+    });
+}
+
+template <typename T>
+::sycl::event quantize_weights_to_int8(::sycl::queue& q,
+                                       const T* weights,
+                                       int8_t* weights_i8,
+                                       float* per_channel_scale,
+                                       int kernel_volume,
+                                       int input_channels,
+                                       int output_channels) {
+    constexpr int wg_size = 256;
+    const int64_t weights_per_channel = static_cast<int64_t>(kernel_volume) * input_channels;
+    auto reduce_event = q.submit([&](::sycl::handler& cgh) {
+        auto local_max = ::sycl::local_accessor<float, 1>(wg_size, cgh);
+        cgh.parallel_for(
+            ::sycl::nd_range<1>(::sycl::range<1>(static_cast<size_t>(output_channels * wg_size)),
+                                ::sycl::range<1>(wg_size)),
+            [=](::sycl::nd_item<1> item) {
+                const int oc = static_cast<int>(item.get_group(0));
+                const int lid = static_cast<int>(item.get_local_id(0));
+                float max_value = 0.0f;
+                for (int64_t idx = lid; idx < weights_per_channel; idx += wg_size) {
+                    const float value = ::sycl::fabs(static_cast<float>(weights[idx * output_channels + oc]));
+                    max_value = ::sycl::fmax(max_value, value);
+                }
+                local_max[lid] = max_value;
+                item.barrier(::sycl::access::fence_space::local_space);
+                for (int offset = wg_size / 2; offset > 0; offset >>= 1) {
+                    if (lid < offset)
+                        local_max[lid] = ::sycl::fmax(local_max[lid], local_max[lid + offset]);
+                    item.barrier(::sycl::access::fence_space::local_space);
+                }
+                if (lid == 0)
+                    per_channel_scale[oc] = clamp_quant_abs_max(local_max[0]) / 127.0f;
+            });
+    });
+
+    const int64_t total = static_cast<int64_t>(kernel_volume) * input_channels * output_channels;
+    return q.submit([&](::sycl::handler& cgh) {
+        cgh.depends_on(reduce_event);
+        cgh.parallel_for(::sycl::range<1>(static_cast<size_t>(total)), [=](::sycl::id<1> id) {
+            const int64_t idx = static_cast<int64_t>(id[0]);
+            const int oc = static_cast<int>(idx % output_channels);
+            const float scale_inv = 1.0f / per_channel_scale[oc];
+            int value = static_cast<int>(::sycl::round(static_cast<float>(weights[idx]) * scale_inv));
+            value = value > 127 ? 127 : value;
+            value = value < -127 ? -127 : value;
+            weights_i8[idx] = static_cast<int8_t>(value);
+        });
+    });
+}
+
+::sycl::event pack_weights_i8_packed_b(::sycl::queue& q,
+                                       const int8_t* weights,
+                                       int8_t* weights_packed,
+                                       int kernel_volume,
+                                       int input_channels,
+                                       int output_channels,
+                                       int input_channels_padded,
+                                       int output_channels_padded,
+                                       const std::vector<::sycl::event>& deps = {}) {
+    const size_t packed_count = static_cast<size_t>(kernel_volume) * input_channels_padded * output_channels_padded;
+    auto clear_event = q.memset(weights_packed, 0, packed_count * sizeof(int8_t));
+    const size_t source_count = static_cast<size_t>(kernel_volume) * input_channels * output_channels;
+    return q.submit([&](::sycl::handler& cgh) {
+        cgh.depends_on(clear_event);
+        if (!deps.empty()) cgh.depends_on(deps);
+        cgh.parallel_for(::sycl::range<1>(source_count), [=](::sycl::id<1> id) {
+            const size_t idx = id[0];
+            const int oc = static_cast<int>(idx % output_channels);
+            const int tmp = static_cast<int>(idx / output_channels);
+            const int ic = tmp % input_channels;
+            const int k = tmp / input_channels;
+            const size_t packed_stride = static_cast<size_t>(output_channels_padded) * 4;
+            const size_t packed_offset =
+                (static_cast<size_t>(k) * (input_channels_padded / 4) + (ic / 4)) * packed_stride +
+                static_cast<size_t>(oc) * 4 + (ic & 3);
+            weights_packed[packed_offset] = weights[idx];
+        });
+    });
+}
