+
+std::vector<int64_t> read_i64_vector(memory::ptr mem, const stream& stream) {
+    const auto count = mem->get_layout().count();
+    std::vector<int64_t> values(count);
+
+    switch (mem->get_layout().data_type) {
+    case data_types::i32: {
+        mem_lock<int32_t, mem_lock_type::read> lock(mem, stream);
+        for (size_t i = 0; i < count; ++i) {
+            values[i] = static_cast<int64_t>(lock.data()[i]);
+        }
+        break;
+    }
+    case data_types::i64: {
+        mem_lock<int64_t, mem_lock_type::read> lock(mem, stream);
+        for (size_t i = 0; i < count; ++i) {
+            values[i] = lock.data()[i];
+        }
+        break;
+    }
+    case data_types::u32: {
+        mem_lock<uint32_t, mem_lock_type::read> lock(mem, stream);
+        for (size_t i = 0; i < count; ++i) {
+            values[i] = static_cast<int64_t>(lock.data()[i]);
+        }
+        break;
+    }
+    case data_types::u64: {
+        mem_lock<uint64_t, mem_lock_type::read> lock(mem, stream);
+        for (size_t i = 0; i < count; ++i) {
+            values[i] = static_cast<int64_t>(lock.data()[i]);
+        }
+        break;
+    }
+    default:
+        OPENVINO_THROW("SparseToDense supports only i32/i64/u32/u64 metadata inputs");
+    }
+
+    return values;
+}
+
+void zero_memory(memory::ptr mem, stream& stream) {
+    mem_lock<uint8_t, mem_lock_type::write> lock(mem, stream);
+    std::fill_n(lock.data(), mem->get_layout().bytes_count(), uint8_t{0});
+}
+
+template <typename T>
+bool execute_sparse_to_dense(const sparse_to_dense_inst& instance,
+                             memory::ptr feature_mem,
+                             memory::ptr output_mem,
+                             const std::vector<int64_t>& indices_values,
+                             const std::vector<int64_t>& spatial_values,
+                             int64_t batch_size,
+                             stream& stream) {
+    const auto feature_shape = feature_mem->get_layout().get_shape();
+    OPENVINO_ASSERT(feature_shape.size() == 2, "SparseToDense expects the feature input to be rank-2 at execution time");
+    const auto num_points = feature_shape[0];
+    const auto channels = feature_shape[1];
+
+    OPENVINO_ASSERT(indices_values.size() == num_points * 4,
+                    "SparseToDense indices input size mismatch: expected ",
+                    num_points * 4,
+                    ", got ",
+                    indices_values.size());
+    OPENVINO_ASSERT(spatial_values.size() == 3, "SparseToDense spatial_shape input must contain exactly three values");
+
+    ov::Shape expected_shape;
+    OPENVINO_ASSERT(ov::reference::compute_sparse_to_dense_output_shape({{spatial_values[0], spatial_values[1], spatial_values[2]}},
+                                                                        batch_size,
+                                                                        channels,
+                                                                        instance.get_typed_desc<sparse_to_dense>()->channels_first,
+                                                                        instance.get_typed_desc<sparse_to_dense>()->flatten_output,
+                                                                        expected_shape),
+                    "SparseToDense failed to compute the dense output shape");
+    OPENVINO_ASSERT(output_mem->get_layout().get_shape() == expected_shape,
+                    "SparseToDense output layout mismatch: expected ",
+                    expected_shape,
+                    ", got ",
+                    output_mem->get_layout().get_shape());
+
+    mem_lock<const T, mem_lock_type::read> feature_lock(feature_mem, stream);
+    mem_lock<T, mem_lock_type::write> output_lock(output_mem, stream);
+
+    return ov::reference::sparse_to_dense<T>(feature_lock.data(),
+                                             num_points,
+                                             channels,
+                                             indices_values.data(),
+                                             4,
+                                             {{spatial_values[0], spatial_values[1], spatial_values[2]}},
+                                             batch_size,
+                                             instance.get_typed_desc<sparse_to_dense>()->channels_first,
+                                             instance.get_typed_desc<sparse_to_dense>()->flatten_output,
+                                             output_lock.data());
+}
+
+}  // namespace
+
+struct sparse_to_dense_impl : typed_primitive_impl<sparse_to_dense> {
+    using parent = typed_primitive_impl<sparse_to_dense>;
+    using parent::parent;
+
+    DECLARE_OBJECT_TYPE_SERIALIZATION(cldnn::cpu::sparse_to_dense_impl)
+
+    sparse_to_dense_impl() : parent("sparse_to_dense_cpu_impl") {}
+
+    std::unique_ptr<primitive_impl> clone() const override {
+        return std::make_unique<sparse_to_dense_impl>(*this);
+    }
+
+    explicit sparse_to_dense_impl(const sparse_to_dense_node& outer) {
+        set_node_params(outer);
+    }
+
+    void set_node_params(const program_node& arg) override {
+        OPENVINO_ASSERT(arg.is_type<sparse_to_dense>(), "[GPU] Incorrect program_node type");
+    }
+
+    void save(BinaryOutputBuffer& ob) const override {
+        parent::save(ob);
+    }
+
+    void load(BinaryInputBuffer& ib) override {
+        parent::load(ib);
+    }
+
+    event::ptr execute_impl(const std::vector<event::ptr>& events, sparse_to_dense_inst& instance) override {
+        OV_ITT_SCOPED_TASK(ov::intel_gpu::itt::domains::intel_gpu_plugin, "sparse_to_dense::execute_impl");
+        auto& stream = instance.get_network().get_stream();
+
+        const bool pass_through_events =
+            (stream.get_queue_type() == QueueTypes::out_of_order) && instance.all_dependencies_cpu_impl();
+        if (!pass_through_events) {
+            stream.wait_for_events(events);
+        }
+
+        const auto& primitive = *instance.get_node().as<sparse_to_dense>().get_primitive();
+        const auto indices_values = read_i64_vector(instance.dep_memory_ptr(1), stream);
+        const auto& spatial_values = primitive.spatial_shape;
+        const auto batch_size_val = primitive.batch_size;
+
+        auto feature_mem = instance.input_memory_ptr(0);
+        auto output_mem = instance.output_memory_ptr(0);
+        zero_memory(output_mem, stream);
+
+        std::vector<int64_t> spatial_vec(spatial_values.begin(), spatial_values.end());
+        switch (feature_mem->get_layout().data_type) {
+        case data_types::f32:
+            OPENVINO_ASSERT(execute_sparse_to_dense<float>(instance,
+                                                           feature_mem,
+                                                           output_mem,
+                                                           indices_values,
+                                                           spatial_vec,
+                                                           batch_size_val,
+                                                           stream),
+                            "SparseToDense CPU execution failed");
+            break;
+        case data_types::f16:
+            OPENVINO_ASSERT(execute_sparse_to_dense<ov::float16>(instance,
+                                                                 feature_mem,
+                                                                 output_mem,
+                                                                 indices_values,
+                                                                 spatial_vec,
+                                                                 batch_size_val,
+                                                                 stream),
+                            "SparseToDense CPU execution failed");
+            break;
+        default:
+            OPENVINO_THROW("SparseToDense CPU implementation supports only f16/f32 feature tensors");
+        }
+
+        if (pass_through_events) {
+            return stream.group_events(events);
+        }
+
+        return make_output_event(stream, instance.is_output());
+    }
+
+    void init_kernels(const kernels_cache&, const kernel_impl_params&) override {}
+
+    void update(primitive_inst& inst, const kernel_impl_params& impl_param) override {}
+
+    static std::unique_ptr<primitive_impl> create(const sparse_to_dense_node& arg,
+                                                  const kernel_impl_params& impl_param) {
+        return std::make_unique<sparse_to_dense_impl>();
+    }
+};
