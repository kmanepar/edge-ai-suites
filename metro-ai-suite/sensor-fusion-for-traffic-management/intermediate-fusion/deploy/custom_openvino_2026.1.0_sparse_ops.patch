+#pragma once
+
+#include <algorithm>
+#include <vector>
+
+#include "sparse_convolution_inst.h"
+#include "registry/implementation_manager.hpp"
+
+namespace cldnn {
+namespace sycl {
+
+struct SparseConvolutionV15SyclImpl : public ImplementationManager {
+    OV_GPU_PRIMITIVE_IMPL("sycl::sparse_convolution")
+
+    SparseConvolutionV15SyclImpl(shape_types shape_type, ValidateFunc vf = nullptr)
+        : ImplementationManager(impl_types::sycl, shape_type, vf) {}
+
+    std::unique_ptr<primitive_impl> create_impl(const program_node& node, const kernel_impl_params& params) const override;
+
+    bool validate_impl(const program_node& node) const override {
+        assert(node.is_type<sparse_convolution>());
+
+        if (node.has_fused_primitives())
+            return false;
+
+        if (node.get_input_layouts().size() != 4 || node.get_output_layouts().size() != 2)
+            return false;
+
+        const auto& sparse_node = node.as<sparse_convolution>();
+        const auto& primitive = sparse_node.get_primitive();
+
+        const auto is_all = [](const std::vector<int64_t>& values, int64_t expected) {
+            return values.size() == 3 && std::all_of(values.begin(), values.end(), [&](int64_t value) {
+                return value == expected;
+            });
+        };
+        if (primitive->kernel_size.size() != 3)
+            return false;
+        for (size_t i = 0; i < 3; ++i) {
+            if (primitive->kernel_size[i] <= 0 || primitive->kernel_size[i] % 2 != 1)
+                return false;
+        }
+
+        if (primitive->subm) {
+            if (primitive->kernel_size[0] != primitive->kernel_size[1] ||
+                primitive->kernel_size[1] != primitive->kernel_size[2])
+                return false;
+            const auto half_kernel = primitive->kernel_size[0] / 2;
+            if (!is_all(primitive->stride, 1) || !is_all(primitive->dilation, 1) || !is_all(primitive->padding, half_kernel))
+                return false;
+        }
+
+        if (!primitive->subm) {
+            for (size_t i = 0; i < primitive->stride.size(); ++i) {
+                if (primitive->stride[i] < 1)
+                    return false;
+            }
+            for (size_t i = 0; i < primitive->dilation.size(); ++i) {
+                if (primitive->dilation[i] < 1)
+                    return false;
+            }
+        }
+
+        const auto& feature_layout = sparse_node.get_input_layout(0);
+        if (!one_of(feature_layout.data_type, {data_types::f16, data_types::f32}) || feature_layout.data_padding)
+            return false;
+        if (feature_layout.format != format::bfyx)
+            return false;
+
+        const auto& indices_layout = sparse_node.get_input_layout(1);
+        if (indices_layout.format != format::bfyx || indices_layout.data_padding)
+            return false;
+        if (!one_of(indices_layout.data_type, {data_types::i32}))
+            return false;
+
+        const auto& weight_layout = sparse_node.get_input_layout(2);
+        if (!one_of(weight_layout.data_type, {data_types::f16, data_types::f32}) || weight_layout.data_padding)
+            return false;
+        if (weight_layout.data_type != feature_layout.data_type)
+            return false;
+
+        const auto& bias_layout = sparse_node.get_input_layout(3);
+        if (!one_of(bias_layout.data_type, {data_types::f16, data_types::f32}) || bias_layout.data_padding)
+            return false;
+        if (bias_layout.data_type != feature_layout.data_type)
+            return false;
+
+        for (size_t out_idx = 0; out_idx < 2; ++out_idx) {
+            const auto& out_layout = sparse_node.get_output_layout(out_idx);
+            if (out_layout.data_padding)
+                return false;
+        }
+
+        if (sparse_node.get_output_layout(0).data_type != feature_layout.data_type)
+            return false;
+        if (sparse_node.get_output_layout(1).data_type != indices_layout.data_type)
+            return false;
+
+        return true;
+    }
+};
+
+}  // namespace sycl
+}  // namespace cldnn
