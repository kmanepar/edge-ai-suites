+
+void SparseConvolution::validate_and_infer_types() {
+    const auto num_inputs = get_input_size();
+    NODE_VALIDATION_CHECK(this,
+                          num_inputs == 3 || num_inputs == 4,
+                          "SparseConvolution expects 3 or 4 inputs: features, coords, weights[, bias]. Got: ",
+                          num_inputs);
+
+    validate_attr(this, m_kernel_size, "kernel_size", false);
+    validate_attr(this, m_stride, "stride", false);
+    validate_attr(this, m_padding, "padding", true);
+    validate_attr(this, m_dilation, "dilation", false);
+    validate_attr(this, m_input_spatial_shape, "input_spatial_shape", false);
+    validate_attr(this, m_output_spatial_shape, "output_spatial_shape", true);
+    NODE_VALIDATION_CHECK(this, m_out_channels >= 0, "Attribute 'out_channels' must be non-negative.");
+    NODE_VALIDATION_CHECK(this, m_in_channels >= 0, "Attribute 'in_channels' must be non-negative.");
+    NODE_VALIDATION_CHECK(this, m_output_bound >= 0, "Attribute 'output_bound' must be non-negative.");
+    NODE_VALIDATION_CHECK(this, m_input_abs_max >= 0.0f, "Attribute 'input_abs_max' must be non-negative.");
+
+    const auto features_et = get_input_element_type(0);
+    const auto coords_et = get_input_element_type(1);
+    const auto weight_et = get_input_element_type(2);
+
+    NODE_VALIDATION_CHECK(this,
+                          features_et.is_real(),
+                          "Input 0 (features) must be a floating-point tensor. Got: ",
+                          features_et);
+    NODE_VALIDATION_CHECK(this, coords_et == element::i32, "Input 1 (coords) must be i32. Got: ", coords_et);
+    NODE_VALIDATION_CHECK(this,
+                          weight_et.is_real(),
+                          "Input 2 (weights) must be a floating-point tensor. Got: ",
+                          weight_et);
+    NODE_VALIDATION_CHECK(this,
+                          features_et.compatible(weight_et),
+                          "Input 0 (features) and input 2 (weights) element types must be compatible. Got: ",
+                          features_et,
+                          " and ",
+                          weight_et);
+
+    if (num_inputs == 4) {
+        const auto bias_et = get_input_element_type(3);
+        NODE_VALIDATION_CHECK(this,
+                              bias_et.is_real(),
+                              "Input 3 (bias) must be a floating-point tensor. Got: ",
+                              bias_et);
+        NODE_VALIDATION_CHECK(this,
+                              features_et.compatible(bias_et),
+                              "Input 0 (features) and input 3 (bias) element types must be compatible. Got: ",
+                              features_et,
+                              " and ",
+                              bias_et);
+    }
+
+    const auto features_ps = get_input_partial_shape(0);
+    const auto coords_ps = get_input_partial_shape(1);
+    const auto weight_ps = get_input_partial_shape(2);
+
+    NODE_VALIDATION_CHECK(this,
+                          features_ps.rank().compatible(2),
+                          "Input 0 (features) rank must be compatible with 2 [N, C_in]. Got: ",
+                          features_ps);
+    NODE_VALIDATION_CHECK(this,
+                          coords_ps.rank().compatible(2),
+                          "Input 1 (coords) rank must be compatible with 2 [N, 4]. Got: ",
+                          coords_ps);
+    if (coords_ps.rank().is_static()) {
+        NODE_VALIDATION_CHECK(this,
+                              coords_ps[1].compatible(4),
+                              "Input 1 (coords) second dimension must be 4 [batch, z, y, x]. Got: ",
+                              coords_ps);
+    }
+
+    NODE_VALIDATION_CHECK(this,
+                          weight_ps.rank().compatible(3),
+                          "Input 2 (weights) rank must be compatible with 3 [kernel_volume, C_in, C_out]. Got: ",
+                          weight_ps);
+    if (weight_ps.rank().is_static()) {
+        int64_t kernel_volume = 1;
+        for (const auto value : m_kernel_size)
+            kernel_volume *= value;
+
+        NODE_VALIDATION_CHECK(this,
+                              weight_ps[0].compatible(kernel_volume),
+                              "Input 2 (weights) first dimension must match kernel_volume. Got: ",
+                              weight_ps,
+                              ", expected ",
+                              kernel_volume);
+    }
+
+    if (features_ps.rank().is_static() && weight_ps.rank().is_static()) {
+        NODE_VALIDATION_CHECK(this,
+                              features_ps[1].compatible(weight_ps[1]),
+                              "Input 0 (features) channel dimension must match Input 2 (weights) input channels. Got: ",
+                              features_ps,
+                              " and ",
+                              weight_ps);
+    }
+    if (m_in_channels > 0 && features_ps.rank().is_static()) {
+        NODE_VALIDATION_CHECK(this,
+                              features_ps[1].compatible(Dimension(m_in_channels)),
+                              "Attribute 'in_channels' must match Input 0 (features) channel dimension. Got in_channels=",
+                              m_in_channels,
+                              ", features shape: ",
+                              features_ps);
+    }
+
+    if (num_inputs == 4) {
+        const auto bias_ps = get_input_partial_shape(3);
+        NODE_VALIDATION_CHECK(this,
+                              bias_ps.rank().compatible(1),
+                              "Input 3 (bias) rank must be compatible with 1 [C_out]. Got: ",
+                              bias_ps);
+        if (weight_ps.rank().is_static() && bias_ps.rank().is_static()) {
+            NODE_VALIDATION_CHECK(this,
+                                  bias_ps[0].compatible(weight_ps[2]),
+                                  "Input 3 (bias) size must match Input 2 (weights) output channels. Got: ",
+                                  bias_ps,
+                                  " and ",
+                                  weight_ps);
+        }
+        if (m_out_channels > 0 && bias_ps.rank().is_static()) {
+            NODE_VALIDATION_CHECK(this,
+                                  bias_ps[0].compatible(Dimension(m_out_channels)),
+                                  "Attribute 'out_channels' must match Input 3 (bias) size. Got out_channels=",
+                                  m_out_channels,
+                                  ", bias shape: ",
+                                  bias_ps);
+        }
+    }
+    if (m_out_channels > 0 && weight_ps.rank().is_static()) {
+        NODE_VALIDATION_CHECK(this,
+                              weight_ps[2].compatible(Dimension(m_out_channels)),
+                              "Attribute 'out_channels' must match Input 2 (weights) output channels. Got out_channels=",
+                              m_out_channels,
+                              ", weight shape: ",
+                              weight_ps);
+    }
+
+    Dimension out_channels = Dimension::dynamic();
+    if (m_out_channels > 0)
+        out_channels = Dimension(m_out_channels);
+    else if (weight_ps.rank().is_static())
+        out_channels = weight_ps[2];
+
+    Dimension out_points = Dimension::dynamic();
+    if (m_subm && features_ps.rank().is_static())
+        out_points = features_ps[0];
+    else if (!m_subm && m_output_bound > 0)
+        out_points = Dimension(m_output_bound);
+
+    set_output_size(2);
+    set_output_type(0, features_et, PartialShape{out_points, out_channels});
+    set_output_type(1, element::i32, PartialShape{out_points, 4});
+}
+
+std::shared_ptr<Node> SparseConvolution::clone_with_new_inputs(const OutputVector& new_args) const {
+    check_new_args_count(this, new_args);
+    if (new_args.size() == 4) {
+        return std::make_shared<SparseConvolution>(new_args[0],
+                                                   new_args[1],
+                                                   new_args[2],
+                                                   new_args[3],
+                                                   m_kernel_size,
+                                                   m_stride,
+                                                   m_padding,
+                                                   m_dilation,
+                                                   m_subm,
+                                                   m_out_channels,
+                                                   m_input_spatial_shape,
+                                                   m_in_channels,
+                                                   m_output_spatial_shape,
+                                                   m_activation,
+                                                   m_output_bound,
+                                                   m_rulebook,
+                                                   m_input_abs_max);
+    }
+
+    return std::make_shared<SparseConvolution>(new_args[0],
+                                               new_args[1],
+                                               new_args[2],
+                                               m_kernel_size,
+                                               m_stride,
+                                               m_padding,
+                                               m_dilation,
+                                               m_subm,
+                                               m_out_channels,
+                                               m_input_spatial_shape,
+                                               m_in_channels,
+                                               m_output_spatial_shape,
+                                               m_activation,
+                                               m_output_bound,
+                                               m_rulebook,
+                                               m_input_abs_max);
+}
+
+bool SparseConvolution::evaluate(TensorVector& outputs, const TensorVector& inputs) const {
+    OV_OP_SCOPE(v15_SparseConvolution_evaluate);
+    if (outputs.size() != 2 || inputs.size() != 4)
+        return false;
+
+    const auto indices_values = to_i64_vector(inputs[1]);
+    if (indices_values.empty())
+        return false;
+
+    const auto feature_shape = inputs[0].get_shape();
+    const auto weight_shape = inputs[2].get_shape();
+    const auto bias_shape = inputs[3].get_shape();
+    if (feature_shape.size() != 2 || weight_shape.size() != 3 || bias_shape.size() != 1 ||
+        feature_shape[0] * 4 != indices_values.size() || feature_shape[1] != weight_shape[1] ||
+        bias_shape[0] != weight_shape[2])
+        return false;
+
+    const auto in_channels = weight_shape[1];
+    const auto out_channels = weight_shape[2];
+
+    ov::reference::SparseConvolutionMetadata metadata;
+    std::array<int64_t, 3> explicit_oss = {0, 0, 0};
+    if (m_output_spatial_shape.size() == 3)
+        explicit_oss = to_array3(m_output_spatial_shape);
+
+    if (!ov::reference::compute_sparse_convolution_metadata(indices_values.data(),
+                                                       indices_values.size() / 4,
+                                                       4,
+                                                       to_array3(m_input_spatial_shape),
+                                                       to_array3(m_kernel_size),
+                                                       to_array3(m_stride),
+                                                       to_array3(m_padding),
+                                                       to_array3(m_dilation),
+                                                       m_subm,
+                                                       metadata,
+                                                       explicit_oss)) {
+        return false;
+    }
+
+    outputs[0].set_shape({metadata.num_points(), out_channels});
+    outputs[1].set_shape({metadata.num_points(), 4});
+
+    if (!write_i64_tensor_data(metadata.out_indices, outputs[1]))
+        return false;
+
+    const auto fused_relu = is_relu_activation(m_activation);
+    switch (outputs[0].get_element_type()) {
+    case element::Type_t::f32:
+        return ov::reference::sparse_convolution<float>(inputs[0].data<const float>(),
+                                                   feature_shape[0],
+                                                   in_channels,
+                                                   indices_values.data(),
+                                                   4,
+                                                   inputs[2].data<const float>(),
+                                                   out_channels,
+                                                   inputs[3].data<const float>(),
+                                                   to_array3(m_input_spatial_shape),
+                                                   to_array3(m_kernel_size),
+                                                   to_array3(m_stride),
+                                                   to_array3(m_padding),
+                                                   to_array3(m_dilation),
+                                                   m_subm,
+                                                   metadata,
+                                                   outputs[0].data<float>(),
+                                                   explicit_oss,
+                                                   fused_relu);
+    case element::Type_t::f16:
+        return ov::reference::sparse_convolution<ov::float16>(inputs[0].data<const ov::float16>(),
+                                                         feature_shape[0],
+                                                         in_channels,
+                                                         indices_values.data(),
+                                                         4,
+                                                         inputs[2].data<const ov::float16>(),
+                                                         out_channels,
+                                                         inputs[3].data<const ov::float16>(),
+                                                         to_array3(m_input_spatial_shape),
+                                                         to_array3(m_kernel_size),
+                                                         to_array3(m_stride),
+                                                         to_array3(m_padding),
+                                                         to_array3(m_dilation),
+                                                         m_subm,
+                                                         metadata,
+                                                         outputs[0].data<ov::float16>(),
+                                                         explicit_oss,
+                                                         fused_relu);
+    default:
+        return false;
+    }
+}
+
+bool SparseConvolution::has_evaluate() const {
+    OV_OP_SCOPE(v15_SparseConvolution_has_evaluate);
+    if (get_input_size() != 4)
+        return false;
+
+    const auto features_et = get_input_element_type(0);
+    const auto weight_et = get_input_element_type(2);
+    const auto bias_et = get_input_element_type(3);
+
+    const bool fp_supported = (features_et == element::f16 || features_et == element::f32);
+    return fp_supported && features_et.compatible(weight_et) && features_et.compatible(bias_et) &&
+           get_input_element_type(1) == element::i32;
+}
+
+bool SparseConvolution::has_bias() const {
+    return get_input_size() == 4;
+}
+
+bool SparseConvolution::is_subm() const {
+    return m_subm;
+}
+
+bool SparseConvolution::get_subm() const {
+    return m_subm;
+}
+
+bool SparseConvolution::get_fused_relu() const {
+    return is_relu_activation(m_activation);
+}
+
+const std::vector<int64_t>& SparseConvolution::get_kernel_size() const {
+    return m_kernel_size;
+}
+
+const std::vector<int64_t>& SparseConvolution::get_stride() const {
+    return m_stride;
+}
+
+const std::vector<int64_t>& SparseConvolution::get_padding() const {
+    return m_padding;
+}
+
+const std::vector<int64_t>& SparseConvolution::get_dilation() const {
+    return m_dilation;
+}
+
+int64_t SparseConvolution::get_out_channels() const {
+    return m_out_channels;
+}
+
+int64_t SparseConvolution::get_in_channels() const {
+    return m_in_channels;
+}
+
+const std::vector<int64_t>& SparseConvolution::get_input_spatial_shape() const {
+    return m_input_spatial_shape;
+}
+
+const std::vector<int64_t>& SparseConvolution::get_spatial_shape() const {
+    return m_input_spatial_shape;
+}
+
+const std::vector<int64_t>& SparseConvolution::get_output_spatial_shape() const {
+    return m_output_spatial_shape;
+}
+
+const std::string& SparseConvolution::get_activation() const {
+    return m_activation;
+}
+
+int64_t SparseConvolution::get_output_bound() const {
+    return m_output_bound;
+}
+
+const std::string& SparseConvolution::get_rulebook() const {
+    return m_rulebook;
+}
+
+float SparseConvolution::get_input_abs_max() const {
+    return m_input_abs_max;
+}
