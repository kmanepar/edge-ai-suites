+
+ov::OutputVector sparse_to_dense(const ov::frontend::onnx::Node& node) {
+    const auto inputs = node.get_ov_inputs();
+    CHECK_VALID_NODE(node,
+                     inputs.size() == 2 || inputs.size() == 4,
+                     "SparseToDense expects 2 or 4 inputs: features, indices[, spatial_shape, batch_size]. Got: ",
+                     inputs.size());
+
+    const auto channels_first = node.get_attribute_value<int64_t>("channels_first", 1) != 0;
+    const auto flatten_default = node.get_attribute_value<int64_t>("flatten_output", 1);
+    const auto flatten_output = node.get_attribute_value<int64_t>("fuse_permute_reshape", flatten_default) != 0;
+
+    if (inputs.size() == 4) {
+        return {std::make_shared<ov::op::v15::SparseToDense>(inputs,
+                                                             std::vector<int64_t>{},
+                                                             1,
+                                                             channels_first,
+                                                             flatten_output)};
+    }
+
+    const auto spatial_shape = node.get_attribute_value<std::vector<int64_t>>("spatial_shape", std::vector<int64_t>{});
+    CHECK_VALID_NODE(node,
+                     spatial_shape.size() == 3,
+                     "Attribute 'spatial_shape' must contain exactly 3 elements. Got: ",
+                     spatial_shape.size());
+
+    const auto batch_size = node.get_attribute_value<int64_t>("batch_size", 1);
+
+    return {std::make_shared<ov::op::v15::SparseToDense>(inputs,
+                                                         spatial_shape,
+                                                         batch_size,
+                                                         channels_first,
+                                                         flatten_output)};
+}
+
+static bool register_sparse_to_dense_translator(void) {
+    ONNX_OP_M("SparseToDense", OPSET_SINCE(1), org_openvinotoolkit::opset_1::sparse_to_dense, OPENVINO_ONNX_DOMAIN);
+    return true;
+}
+
+static bool registered = register_sparse_to_dense_translator();
+
+}  // namespace opset_1
+}  // namespace org_openvinotoolkit
+}  // namespace onnx
+}  // namespace frontend
+}  // namespace ov
