+#include "registry/implementation_manager.hpp"
+#include "sparse_to_dense_inst.h"
+
+namespace cldnn {
+namespace sycl {
+
+struct SparseToDenseV15SyclImpl : public ImplementationManager {
+    OV_GPU_PRIMITIVE_IMPL("sycl::sparse_to_dense")
+
+    SparseToDenseV15SyclImpl(shape_types shape_type, ValidateFunc vf = nullptr)
+        : ImplementationManager(impl_types::sycl, shape_type, vf) {}
+
+    std::unique_ptr<primitive_impl> create_impl(const program_node& node, const kernel_impl_params& params) const override;
+
+    bool validate_impl(const program_node& node) const override {
+        assert(node.is_type<sparse_to_dense>());
+
+        if (node.has_fused_primitives())
+            return false;
+
+        if (node.get_input_layouts().size() < 2 || node.get_output_layouts().size() != 1)
+            return false;
+
+        const auto& sparse_node = node.as<sparse_to_dense>();
+        const auto& feature_layout = sparse_node.get_input_layout(0);
+        if (!one_of(feature_layout.data_type, {data_types::f16, data_types::f32}) || feature_layout.data_padding)
+            return false;
+
+        const auto& indices_layout = sparse_node.get_input_layout(1);
+        if (indices_layout.data_padding)
+            return false;
+        if (!one_of(indices_layout.data_type, {data_types::i32, data_types::u32, data_types::i64, data_types::u64}))
+            return false;
+
+        const auto& output_layout = sparse_node.get_output_layout(0);
+        return output_layout.data_type == feature_layout.data_type && !output_layout.data_padding;
+    }
+};
+
+}  // namespace sycl
+}  // namespace cldnn
