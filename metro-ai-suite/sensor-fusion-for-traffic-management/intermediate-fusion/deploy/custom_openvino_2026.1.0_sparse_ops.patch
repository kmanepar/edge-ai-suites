+
+namespace {
+
+template <typename T>
+void expect_buffer_eq(const memory::ptr& mem, const std::vector<T>& expected) {
+    mem_lock<T, mem_lock_type::read> lock(mem, get_test_stream());
+    ASSERT_EQ(lock.size(), expected.size());
+    for (size_t i = 0; i < expected.size(); ++i) {
+        ASSERT_EQ(lock[i], expected[i]) << "at index " << i;
+    }
+}
+
+void run_sparse_to_dense_test(bool channels_first,
+                              bool flatten_output,
+                              const ov::Shape& expected_shape,
+                              const std::vector<float>& expected) {
+    auto& engine = get_test_engine();
+    auto stream = get_test_stream_ptr(get_test_default_config(engine));
+
+    const auto features = engine.allocate_memory({ov::Shape{3, 2}, data_types::f32, format::bfyx}, allocation_type::usm_host);
+    const auto indices = engine.allocate_memory({ov::Shape{3, 4}, data_types::i32, format::bfyx}, allocation_type::usm_host);
+
+    set_values<float>(features, {1.f, 2.f, 3.f, 4.f, 5.f, 6.f});
+    set_values<int32_t>(indices, {0, 0, 0, 0, 0, 1, 0, 1, 1, 0, 1, 0});
+
+    topology topology;
+    topology.add(input_layout("features", layout{ov::PartialShape{ov::Dimension::dynamic(), 2}, data_types::f32, format::bfyx}));
+    topology.add(input_layout("indices", layout{ov::PartialShape{ov::Dimension::dynamic(), 4}, data_types::i32, format::bfyx}));
+    topology.add(sparse_to_dense("sparse_to_dense",
+                                 {input_info("features"), input_info("indices")},
+                                 {2, 2, 2},
+                                 2,
+                                 channels_first,
+                                 flatten_output));
+
+    auto config = get_test_default_config(engine);
+    config.set_property(ov::intel_gpu::allow_new_shape_infer(true));
+    auto network = get_network(engine, topology, config, stream, false);
+    network->set_input_data("features", features);
+    network->set_input_data("indices", indices);
+
+    const auto primitive = network->get_primitive("sparse_to_dense");
+    ASSERT_NE(primitive, nullptr);
+    ASSERT_NE(primitive->get_impl(), nullptr);
+#if OV_GPU_WITH_SYCL
+    EXPECT_FALSE(primitive->get_impl()->is_cpu());
+#endif
+
+    const auto outputs = network->execute();
+    const auto output = outputs.at("sparse_to_dense").get_memory();
+
+    EXPECT_EQ(output->get_layout().get_shape(), expected_shape);
+    expect_buffer_eq<float>(output, expected);
+}
+
+TEST(sparse_to_dense_gpu_test, channels_first_f32) {
+    run_sparse_to_dense_test(true,
+                             false,
+                             ov::Shape{2, 2, 2, 2, 2},
+                             {1.f, 0.f, 0.f, 0.f, 0.f, 3.f, 0.f, 0.f,
+                              2.f, 0.f, 0.f, 0.f, 0.f, 4.f, 0.f, 0.f,
+                              0.f, 0.f, 5.f, 0.f, 0.f, 0.f, 0.f, 0.f,
+                              0.f, 0.f, 6.f, 0.f, 0.f, 0.f, 0.f, 0.f});
+}
