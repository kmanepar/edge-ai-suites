+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#pragma once
+
+#include <algorithm>
+#include <array>
+#include <cstddef>
+#include <cstdint>
+#include <limits>
+
+#include "openvino/core/shape.hpp"
+
+namespace ov {
+namespace reference {
+
+inline bool compute_sparse_to_dense_output_shape(const std::array<int64_t, 3>& spatial_shape,
+                                                 int64_t batch_size,
+                                                 size_t channels,
+                                                 bool channels_first,
+                                                 bool flatten_output,
+                                                 ov::Shape& output_shape) {
+    if (batch_size < 0)
+        return false;
+
+    for (const auto dim : spatial_shape) {
+        if (dim < 0)
+            return false;
+    }
+
+    const auto batch = static_cast<size_t>(batch_size);
+    const auto depth = static_cast<size_t>(spatial_shape[0]);
+    const auto height = static_cast<size_t>(spatial_shape[1]);
+    const auto width = static_cast<size_t>(spatial_shape[2]);
+
+    if (flatten_output) {
+        if (!channels_first)
+            return false;
+        if (width != 0 && channels > std::numeric_limits<size_t>::max() / width)
+            return false;
+
+        output_shape = ov::Shape{batch, channels * width, depth, height};
+        return true;
+    }
+
+    output_shape = channels_first ? ov::Shape{batch, channels, depth, height, width}
+                                  : ov::Shape{batch, depth, height, width, channels};
+    return true;
+}
+
+template <typename T>
+inline bool sparse_to_dense(const T* features,
+                            size_t num_points,
+                            size_t channels,
+                            const int64_t* indices,
+                            size_t index_stride,
+                            const std::array<int64_t, 3>& spatial_shape,
+                            int64_t batch_size,
+                            bool channels_first,
+                            bool flatten_output,
+                            T* output) {
+    if (features == nullptr || indices == nullptr || output == nullptr || index_stride < 4)
+        return false;
+
+    if (batch_size < 0)
+        return false;
+
+    for (const auto dim : spatial_shape) {
+        if (dim < 0)
+            return false;
+    }
+
+    const auto batch = static_cast<size_t>(batch_size);
+    const auto depth = static_cast<size_t>(spatial_shape[0]);
+    const auto height = static_cast<size_t>(spatial_shape[1]);
+    const auto width = static_cast<size_t>(spatial_shape[2]);
+    const auto channel_plane = depth * height * width;
+
+    if (flatten_output && !channels_first)
+        return false;
+
+    for (size_t point = 0; point < num_points; ++point) {
+        const auto* row = indices + point * index_stride;
+        const auto batch_idx = row[0];
+        const auto z = row[1];
+        const auto y = row[2];
+        const auto x = row[3];
+
+        if (batch_idx < 0 || static_cast<size_t>(batch_idx) >= batch)
+            continue;
+        if (z < 0 || static_cast<size_t>(z) >= depth)
+            continue;
+        if (y < 0 || static_cast<size_t>(y) >= height)
+            continue;
+        if (x < 0 || static_cast<size_t>(x) >= width)
+            continue;
+
+        const auto* src = features + point * channels;
+
+        if (flatten_output) {
+            for (size_t channel = 0; channel < channels; ++channel) {
+                const auto output_channel = channel * width + static_cast<size_t>(x);
+                const auto dense_offset = (((static_cast<size_t>(batch_idx) * (channels * width) + output_channel) * depth +
+                                            static_cast<size_t>(z)) * height + static_cast<size_t>(y));
+                output[dense_offset] = src[channel];
+            }
+        } else if (channels_first) {
+            const auto spatial_offset = (static_cast<size_t>(z) * height + static_cast<size_t>(y)) * width +
+                                        static_cast<size_t>(x);
+            const auto batch_offset = static_cast<size_t>(batch_idx) * channels * channel_plane;
+            for (size_t channel = 0; channel < channels; ++channel) {
+                output[batch_offset + channel * channel_plane + spatial_offset] = src[channel];
+            }
+        } else {
+            const auto dense_offset = ((((static_cast<size_t>(batch_idx) * depth + static_cast<size_t>(z)) * height +
+                                         static_cast<size_t>(y)) * width + static_cast<size_t>(x)) * channels);
+            std::copy(src, src + channels, output + dense_offset);
+        }
+    }
+
+    return true;
+}
+
+}  // namespace reference
+}  // namespace ov
