+        }
+    }
+}
+
+static inline void load_int8_weight_tile_to_slm_wide(::sycl::local_accessor<int8_t, 1>& slm_weight,
+                                                     int slm_base,
+                                                     int local_id,
+                                                     int out_col_start,
+                                                     int K,
+                                                     int N,
+                                                     int kernel_idx,
+                                                     int k_offset_in_kernel,
+                                                     const int8_t* __restrict__ weights) {
+    const int k_row = local_id / 8;
+    const int n_base = (local_id % 8) * 8;
+    if (k_row >= XMX_I8_TILE_K)
+        return;
+
+    const int global_k = k_offset_in_kernel + k_row;
+    const int global_n = out_col_start + n_base;
+    int8_t* slm_ptr = &slm_weight[slm_base + k_row * SLM_I8_WT_STRIDE_WIDE + n_base];
+    if (global_k < K && global_n + 8 <= N && n_base + 8 <= XMX_I8_TILE_N_WIDE) {
+        using char8 = ::sycl::vec<int8_t, 8>;
+        const int8_t* src = weights + static_cast<int64_t>(kernel_idx) * K * N + static_cast<int64_t>(global_k) * N + global_n;
+        char8 v;
+        v.load(0,
+               ::sycl::address_space_cast<::sycl::access::address_space::global_space,
+                                          ::sycl::access::decorated::no>(src));
+        for (int j = 0; j < 8; ++j)
+            slm_ptr[j] = v[j];
+    } else {
+        for (int j = 0; j < 8; ++j) {
+            const int n_idx = n_base + j;
+            int8_t value = 0;
+            if (global_k < K && n_idx < XMX_I8_TILE_N_WIDE && out_col_start + n_idx < N) {
+                value = weights[static_cast<int64_t>(kernel_idx) * K * N + static_cast<int64_t>(global_k) * N + out_col_start + n_idx];
+            }
+            slm_ptr[j] = value;
+        }
+    }
+}
+
+static void conv_implicit_gemm_int8_xmx_kernel_wide(::sycl::nd_item<2> item,
+                                                    ::sycl::local_accessor<int8_t, 1> slm_input,
+                                                    ::sycl::local_accessor<int8_t, 1> slm_weight,
+                                                    ::sycl::local_accessor<int32_t, 1> slm_temp,
+                                                    int M,
+                                                    int K,
+                                                    int N,
+                                                    int k_vol,
+                                                    const int8_t* __restrict__ in_feats,
+                                                    const int8_t* __restrict__ weights,
+                                                    const int32_t* __restrict__ out_in_map,
+                                                    ::sycl::half* __restrict__ out_feats,
+                                                    float act_abs_max,
+                                                    const float* __restrict__ per_channel_weight_scale,
+                                                    const ::sycl::half* __restrict__ bias,
+                                                    bool apply_relu) {
+    auto sg = item.get_sub_group();
+    const int sg_id = sg.get_group_linear_id();
+    const int local_id = item.get_local_linear_id();
+    const int out_row_start = item.get_group(0) * XMX_I8_TILE_M;
+    const int out_col_start = item.get_group(1) * XMX_I8_TILE_N_WIDE;
+    const int sg_row_start = out_row_start + (sg_id / 4) * XMX_I8_TM;
+    const int sg_col_start = out_col_start + (sg_id % 4) * XMX_I8_TN;
+
+    sycl_matrix::joint_matrix<::sycl::sub_group, int8_t, sycl_matrix::use::a,
+                              XMX_I8_TM, XMX_I8_TK, sycl_matrix::layout::row_major> sub_a;
+    sycl_matrix::joint_matrix<::sycl::sub_group, int8_t, sycl_matrix::use::b,
+                              XMX_I8_TK, XMX_I8_TN, sycl_matrix::layout::row_major> sub_b;
+    sycl_matrix::joint_matrix<::sycl::sub_group, int32_t, sycl_matrix::use::accumulator,
+                              XMX_I8_TM, XMX_I8_TN> sub_c;
+    sycl_matrix::joint_matrix_fill(sg, sub_c, 0);
+
+    const int K_tile_padded = ((K + XMX_I8_TILE_K - 1) / XMX_I8_TILE_K) * XMX_I8_TILE_K;
+    const int total_k_iters = (K_tile_padded * k_vol) / XMX_I8_TILE_K;
+    const int sg_slm_row = (sg_id / 4) * XMX_I8_TM;
+    const int sg_slm_col_b = (sg_id % 4) * XMX_I8_TN;
+
+    if (total_k_iters > 0) {
+        int cur_buf = 0;
+        load_int8_input_tile_to_slm_wide(slm_input, 0, local_id, out_row_start, M, K, k_vol, 0, 0, in_feats, out_in_map);
+        load_int8_weight_tile_to_slm_wide(slm_weight, 0, local_id, out_col_start, K, N, 0, 0, weights);
+
+        for (int k_iter = 0; k_iter < total_k_iters; ++k_iter) {
+            item.barrier(::sycl::access::fence_space::local_space);
+            const int in_base = cur_buf * SLM_I8_IN_BUF_SIZE;
+            const int wt_base = cur_buf * SLM_I8_WT_BUF_SIZE_WIDE;
+            const int next_buf = 1 - cur_buf;
+
+            if (k_iter + 1 < total_k_iters) {
+                const int next_iter = k_iter + 1;
+                const int next_kernel_idx = next_iter * XMX_I8_TILE_K / K_tile_padded;
+                const int next_k_offset = (next_iter * XMX_I8_TILE_K) % K_tile_padded;
+                load_int8_input_tile_to_slm_wide(slm_input,
+                                                 next_buf * SLM_I8_IN_BUF_SIZE,
+                                                 local_id,
+                                                 out_row_start,
+                                                 M,
+                                                 K,
+                                                 k_vol,
+                                                 next_kernel_idx,
+                                                 next_k_offset,
+                                                 in_feats,
+                                                 out_in_map);
+                load_int8_weight_tile_to_slm_wide(slm_weight,
+                                                  next_buf * SLM_I8_WT_BUF_SIZE_WIDE,
+                                                  local_id,
+                                                  out_col_start,
+                                                  K,
+                                                  N,
+                                                  next_kernel_idx,
+                                                  next_k_offset,
+                                                  weights);
+            }
+
+            sycl_matrix::joint_matrix_load(sg,
+                                           sub_a,
+                                           slm_input.template get_multi_ptr<::sycl::access::decorated::no>() +
+                                               in_base + sg_slm_row * SLM_I8_IN_STRIDE,
+                                           SLM_I8_IN_STRIDE);
+            sycl_matrix::joint_matrix_load(sg,
+                                           sub_b,
+                                           slm_weight.template get_multi_ptr<::sycl::access::decorated::no>() + wt_base + sg_slm_col_b,
+                                           SLM_I8_WT_STRIDE_WIDE);
+            sycl_matrix::joint_matrix_mad(sg, sub_c, sub_a, sub_b, sub_c);
+            cur_buf = next_buf;
+        }
+    }
+
+    constexpr int elements_per_sg = XMX_I8_TM * XMX_I8_TN;
+    int32_t* temp_c = slm_temp.get_multi_ptr<::sycl::access::decorated::no>().get_raw() + sg_id * elements_per_sg;
+    auto temp_c_ptr = ::sycl::address_space_cast<::sycl::access::address_space::local_space,
+                                                 ::sycl::access::decorated::no>(temp_c);
+    sycl_matrix::joint_matrix_store(sg, sub_c, temp_c_ptr, XMX_I8_TN, sycl_matrix::layout::row_major);
+
+    if (act_abs_max < 1e-8f)
+        act_abs_max = 1e-8f;
+    const float act_scale = act_abs_max / 127.0f;
+    float wscale_cache[XMX_I8_TN];
+    float bias_cache[XMX_I8_TN];
+    for (int j = 0; j < XMX_I8_TN; ++j) {
+        const int gc = sg_col_start + j;
+        wscale_cache[j] = (gc < N) ? per_channel_weight_scale[gc] : 0.0f;
+        bias_cache[j] = (gc < N && bias) ? static_cast<float>(bias[gc]) : 0.0f;
+    }
+
+    const int sg_local_id = static_cast<int>(sg.get_local_id()[0]);
+    constexpr int elems_per_thread = elements_per_sg / XMX_I8_SG_SIZE;
+    const int flat_start = sg_local_id * elems_per_thread;
+    for (int i = 0; i < elems_per_thread; ++i) {
+        const int flat = flat_start + i;
+        const int row = flat / XMX_I8_TN;
+        const int col = flat % XMX_I8_TN;
+        const int global_row = sg_row_start + row;
+        const int global_col = sg_col_start + col;
+        if (global_row < M && global_col < N) {
+            const int64_t out_idx = static_cast<int64_t>(global_row) * N + global_col;
+            float value = static_cast<float>(temp_c[flat]) * act_scale * wscale_cache[col] + bias_cache[col];
+            if (apply_relu && value < 0.0f)
+                value = 0.0f;
+            out_feats[out_idx] = static_cast<::sycl::half>(value);
+        }
+    }
+}
+
+static ::sycl::event run_implicit_gemm_int8_xmx(::sycl::queue& q,
+                                                const std::vector<::sycl::event>& deps,
+                                                const int8_t* in_feats,
+                                                const int8_t* weights,
+                                                const int32_t* out_in_map,
+                                                ::sycl::half* out_feats,
+                                                float act_abs_max,
+                                                const float* per_channel_weight_scale,
+                                                const ::sycl::half* bias,
+                                                bool apply_relu,
+                                                int M,
+                                                int K,
+                                                int N,
+                                                int k_vol) {
+    const int num_groups_m = (M + XMX_I8_TILE_M - 1) / XMX_I8_TILE_M;
+    const int slm_input_size = 2 * SLM_I8_IN_BUF_SIZE;
+    const int slm_temp_size = XMX_I8_NUM_SG * XMX_I8_TM * XMX_I8_TN;
+
+    if (N >= XMX_I8_TILE_N_WIDE) {
+        const int num_groups_n = (N + XMX_I8_TILE_N_WIDE - 1) / XMX_I8_TILE_N_WIDE;
+        const int slm_weight_size = 2 * SLM_I8_WT_BUF_SIZE_WIDE;
+        return q.submit([&](::sycl::handler& cgh) {
+            if (!deps.empty()) cgh.depends_on(deps);
+            auto slm_in = ::sycl::local_accessor<int8_t, 1>(slm_input_size, cgh);
+            auto slm_wt = ::sycl::local_accessor<int8_t, 1>(slm_weight_size, cgh);
+            auto slm_tmp = ::sycl::local_accessor<int32_t, 1>(XMX_I8_NUM_SG_WIDE * XMX_I8_TM * XMX_I8_TN, cgh);
+            cgh.parallel_for(::sycl::nd_range<2>(
+                                 ::sycl::range<2>(num_groups_m * XMX_I8_NUM_SG_WIDE,
+                                                   num_groups_n * XMX_I8_SG_SIZE),
+                                 ::sycl::range<2>(XMX_I8_NUM_SG_WIDE, XMX_I8_SG_SIZE)),
+                             [=](::sycl::nd_item<2> item) [[sycl::reqd_sub_group_size(16)]] {
+                                 conv_implicit_gemm_int8_xmx_kernel_wide(item,
+                                                                         slm_in,
+                                                                         slm_wt,
+                                                                         slm_tmp,
+                                                                         M,
+                                                                         K,
+                                                                         N,
+                                                                         k_vol,
+                                                                         in_feats,
+                                                                         weights,
+                                                                         out_in_map,
+                                                                         out_feats,
+                                                                         act_abs_max,
+                                                                         per_channel_weight_scale,
+                                                                         bias,
+                                                                         apply_relu);
+                             });
+        });
+    }
+
+    const int num_groups_n = (N + XMX_I8_TILE_N - 1) / XMX_I8_TILE_N;
+    const int slm_weight_size = 2 * SLM_I8_WT_BUF_SIZE;
+    return q.submit([&](::sycl::handler& cgh) {
+        if (!deps.empty()) cgh.depends_on(deps);
+        auto slm_in = ::sycl::local_accessor<int8_t, 1>(slm_input_size, cgh);
+        auto slm_wt = ::sycl::local_accessor<int8_t, 1>(slm_weight_size, cgh);
+        auto slm_tmp = ::sycl::local_accessor<int32_t, 1>(slm_temp_size, cgh);
+        cgh.parallel_for(::sycl::nd_range<2>(
+                             ::sycl::range<2>(num_groups_m * XMX_I8_NUM_SG,
+                                               num_groups_n * XMX_I8_SG_SIZE),
+                             ::sycl::range<2>(XMX_I8_NUM_SG, XMX_I8_SG_SIZE)),
+                         [=](::sycl::nd_item<2> item) [[sycl::reqd_sub_group_size(16)]] {
+                             conv_implicit_gemm_int8_xmx_kernel(item,
+                                                                slm_in,
+                                                                slm_wt,
+                                                                slm_tmp,
+                                                                M,
+                                                                K,
+                                                                N,
+                                                                k_vol,
+                                                                in_feats,
+                                                                weights,
+                                                                out_in_map,
+                                                                out_feats,
+                                                                act_abs_max,
+                                                                per_channel_weight_scale,
+                                                                bias,
+                                                                apply_relu);
+                         });
+    });
+}
+
+static void conv_minuet_int8_xmx_kernel(::sycl::nd_item<2> item,
+                                        ::sycl::local_accessor<int8_t, 1> a_slm,
+                                        ::sycl::local_accessor<int32_t, 1> c_slm,
+                                        ::sycl::local_accessor<float, 1> scale_slm,
+                                        ::sycl::local_accessor<float, 1> bias_slm,
+                                        const int8_t* __restrict__ in_feats,
+                                        const int8_t* __restrict__ weights_packed,
+                                        const uint32_t* __restrict__ lut,
+                                        ::sycl::half* __restrict__ out_feats,
+                                        float act_abs_max,
+                                        const float* __restrict__ per_channel_weight_scale,
+                                        const ::sycl::half* __restrict__ bias,
+                                        bool apply_relu,
+                                        int M,
+                                        int K,
+                                        int N,
+                                        int Kp,
+                                        int Np,
+                                        int k_vol,
+                                        int bm,
+                                        int bn,
+                                        int nWgn) {
+    constexpr int rm = 1;
+    constexpr int rn = 4;
+    constexpr int mSgn = rm * XMX_I8_TM;
+    constexpr int nSgn = rn * XMX_I8_TN;
+    constexpr int elements_per_tile = XMX_I8_TM * XMX_I8_TN;
+
+    auto sg = item.get_sub_group();
+    const int start_row = item.get_group(0) * bm;
+    const int start_col = item.get_group(1) * bn;
+    const int tid = static_cast<int>(item.get_local_id(1));
+    const int wis = static_cast<int>(item.get_local_range(1));
+    const int sg_lin = sg.get_group_linear_id();
+    const int sg_id_m = sg_lin / nWgn;
+    const int sg_id_n = sg_lin - sg_id_m * nWgn;
+    const int sg_m_off = sg_id_m * mSgn;
+    const int sg_n_off = sg_id_n * nSgn;
+
+    auto a_ptr = a_slm.template get_multi_ptr<::sycl::access::decorated::no>();
+    sycl_matrix::joint_matrix<::sycl::sub_group, int32_t, sycl_matrix::use::accumulator,
+                              XMX_I8_TM, XMX_I8_TN> c_acc[rm][rn];
+    #pragma unroll
+    for (int mi = 0; mi < rm; ++mi) {
+        #pragma unroll
+        for (int ni = 0; ni < rn; ++ni) {
+            sycl_matrix::joint_matrix_fill(sg, c_acc[mi][ni], 0);
+        }
+    }
+
+    const int k_tiles = Kp / XMX_I8_TK;
+    for (int kk = 0; kk < k_vol; ++kk) {
+        const int total = bm * Kp;
+        for (int p = tid; p < total; p += wis) {
+            const int m_loc = p / Kp;
+            const int c = p - m_loc * Kp;
+            const int global_m = start_row + m_loc;
+            int8_t value = 0;
+            if (global_m < M && c < K) {
+                const uint32_t input_idx = lut[static_cast<size_t>(global_m) * k_vol + kk];
+                if (input_idx != ~0u) {
+                    value = in_feats[static_cast<size_t>(input_idx) * K + c];
+                }
+            }
+            a_slm[static_cast<size_t>(m_loc) * Kp + c] = value;
+        }
+        item.barrier(::sycl::access::fence_space::local_space);
+
+        const int8_t* w_packed_base = weights_packed + static_cast<size_t>(kk) * Kp * Np;
+        #pragma unroll 1
+        for (int kt_idx = 0; kt_idx < k_tiles; ++kt_idx) {
+            const int kt = kt_idx * XMX_I8_TK;
+            sycl_matrix::joint_matrix<::sycl::sub_group, int8_t, sycl_matrix::use::a,
+                                      XMX_I8_TM, XMX_I8_TK, sycl_matrix::layout::row_major> tA[rm];
+            #pragma unroll
+            for (int mi = 0; mi < rm; ++mi) {
+                sycl_matrix::joint_matrix_load(sg,
+                                               tA[mi],
+                                               a_ptr + static_cast<size_t>(sg_m_off + mi * XMX_I8_TM) * Kp + kt,
+                                               Kp);
+            }
+
+            sycl_matrix::joint_matrix<::sycl::sub_group, int8_t, sycl_matrix::use::b,
+                                      XMX_I8_TK, XMX_I8_TN, sycl_matrix::layout::ext_intel_packed> tB[rn];
+            #pragma unroll
+            for (int ni = 0; ni < rn; ++ni) {
+                const int n_off = start_col + sg_n_off + ni * XMX_I8_TN;
+                sycl_matrix::joint_matrix_load(sg,
+                                               tB[ni],
+                                               ::sycl::address_space_cast<::sycl::access::address_space::global_space,
+                                                                          ::sycl::access::decorated::no>(
+                                                   w_packed_base + static_cast<size_t>(kt / 4) * Np * 4 + static_cast<size_t>(n_off) * 4),
+                                               Np * 4);
+            }
+
+            #pragma unroll
+            for (int mi = 0; mi < rm; ++mi) {
+                #pragma unroll
+                for (int ni = 0; ni < rn; ++ni) {
+                    sycl_matrix::joint_matrix_mad(sg, c_acc[mi][ni], tA[mi], tB[ni], c_acc[mi][ni]);
+                }
+            }
+        }
+        item.barrier(::sycl::access::fence_space::local_space);
+    }
+
+    const float act_scale = (act_abs_max > 1e-8f ? act_abs_max : 1e-8f) / 127.0f;
+    for (int p = tid; p < bn; p += wis) {
+        const int global_n = start_col + p;
+        scale_slm[p] = (global_n < N) ? act_scale * per_channel_weight_scale[global_n] : 0.0f;
+        bias_slm[p] = (global_n < N && bias) ? static_cast<float>(bias[global_n]) : 0.0f;
+    }
+    item.barrier(::sycl::access::fence_space::local_space);
+
+    auto c_ptr = c_slm.template get_multi_ptr<::sycl::access::decorated::no>();
+    int32_t* sg_tile = c_ptr.get_raw() + static_cast<size_t>(sg_lin) * rm * rn * elements_per_tile;
+    auto sg_tile_ptr = ::sycl::address_space_cast<::sycl::access::address_space::local_space,
+                                                  ::sycl::access::decorated::no>(sg_tile);
+    #pragma unroll
+    for (int mi = 0; mi < rm; ++mi) {
+        #pragma unroll
+        for (int ni = 0; ni < rn; ++ni) {
+            sycl_matrix::joint_matrix_store(sg,
+                                            c_acc[mi][ni],
+                                            sg_tile_ptr + (mi * rn + ni) * elements_per_tile,
+                                            XMX_I8_TN,
+                                            sycl_matrix::layout::row_major);
+        }
+    }
+    ::sycl::group_barrier(sg);
+
+    const int sg_local = static_cast<int>(sg.get_local_id()[0]);
+    constexpr int elems_per_thread = elements_per_tile / XMX_I8_SG_SIZE;
+    const int flat_start = sg_local * elems_per_thread;
+    #pragma unroll
+    for (int mi = 0; mi < rm; ++mi) {
+        #pragma unroll
+        for (int ni = 0; ni < rn; ++ni) {
+            const int32_t* tile = sg_tile + (mi * rn + ni) * elements_per_tile;
+            #pragma unroll
+            for (int i = 0; i < elems_per_thread; ++i) {
+                const int flat = flat_start + i;
+                const int row = flat / XMX_I8_TN;
+                const int col = flat - row * XMX_I8_TN;
+                const int global_m = start_row + sg_m_off + mi * XMX_I8_TM + row;
+                const int local_n = sg_n_off + ni * XMX_I8_TN + col;
+                const int global_n = start_col + local_n;
+                if (global_m < M && global_n < N) {
+                    const int64_t out_idx = static_cast<int64_t>(global_m) * N + global_n;
+                    float value = static_cast<float>(tile[flat]) * scale_slm[local_n] + bias_slm[local_n];
+                    if (apply_relu && value < 0.0f) {
+                        value = 0.0f;
+                    }
+                    out_feats[out_idx] = static_cast<::sycl::half>(value);
+                }
+            }
+        }
+    }
+}
+
+static ::sycl::event run_minuet_gemm_int8_xmx(::sycl::queue& q,
+                                              const std::vector<::sycl::event>& deps,
+                                              const int8_t* in_feats,
+                                              const int8_t* weights,
+                                              const int8_t* weights_packed,
+                                              const uint32_t* lut,
+                                              ::sycl::half* out_feats,
+                                              float act_abs_max,
+                                              const float* per_channel_weight_scale,
+                                              const ::sycl::half* bias,
+                                              bool apply_relu,
+                                              int M,
+                                              int K,
+                                              int N,
+                                              int Kp,
+                                              int Np,
+                                              int k_vol) {
+    constexpr int sgs = XMX_I8_SG_SIZE;
+    constexpr int rm = 1;
+    constexpr int rn = 4;
+    constexpr int mSgn = rm * XMX_I8_TM;
+    constexpr int nSgn = rn * XMX_I8_TN;
+
+    if (weights_packed == nullptr || lut == nullptr || (Np % nSgn) != 0 || (Kp % XMX_I8_TK) != 0 || Np < nSgn) {
+        return run_implicit_gemm_int8_xmx(q,
+                                          deps,
+                                          in_feats,
+                                          weights,
+                                          reinterpret_cast<const int32_t*>(lut),
+                                          out_feats,
+                                          act_abs_max,
+                                          per_channel_weight_scale,
+                                          bias,
+                                          apply_relu,
+                                          M,
+                                          K,
+                                          N,
+                                          k_vol);
+    }
+
+    int ven = 1;
+    int xcn = 0;
+    size_t slm_size = q.get_device().get_info<::sycl::info::device::local_mem_size>();
+    try {
+        const int slice = q.get_device().get_info<::sycl::ext::intel::info::device::gpu_slices>();
+        const int subslice = q.get_device().get_info<::sycl::ext::intel::info::device::gpu_subslices_per_slice>();
+        ven = q.get_device().get_info<::sycl::ext::intel::info::device::gpu_eu_count_per_subslice>();
+        xcn = slice * subslice;
+    } catch (...) {
+        ven = 1;
+        xcn = 0;
+    }
+
+    const int nBlkNum = Np / nSgn;
+    int nWgn = 1;
+    for (int t = std::min(nBlkNum, std::max(1, ven)); t >= 1; --t) {
+        if ((nBlkNum % t) == 0) {
+            nWgn = t;
+            break;
+        }
+    }
+    int mWgn = std::max(1, std::max(1, ven) / nWgn);
+    int bm = mWgn * mSgn;
+    const int bn = nWgn * nSgn;
+
+    auto slm_bytes = [&](int mWgn_try) {
+        const size_t bm_try = static_cast<size_t>(mWgn_try) * mSgn;
+        return bm_try * static_cast<size_t>(Kp) * sizeof(int8_t) +
+               bm_try * static_cast<size_t>(bn) * sizeof(int32_t) +
+               static_cast<size_t>(bn) * 2 * sizeof(float);
+    };
+    while (mWgn > 1 && slm_bytes(mWgn) > slm_size) {
+        mWgn >>= 1;
+    }
+    if (slm_bytes(mWgn) > slm_size) {
+        return run_implicit_gemm_int8_xmx(q,
+                                          deps,
+                                          in_feats,
+                                          weights,
+                                          reinterpret_cast<const int32_t*>(lut),
+                                          out_feats,
+                                          act_abs_max,
+                                          per_channel_weight_scale,
+                                          bias,
+                                          apply_relu,
+                                          M,
+                                          K,
+                                          N,
+                                          k_vol);
+    }
+    bm = mWgn * mSgn;
+    if (xcn > 0) {
+        const int mTilesTry = (M + bm - 1) / bm;
+        if (mTilesTry * (Np / bn) < xcn && mWgn > 1) {
+            while (mWgn > 1) {
+                const int mWgnTry = mWgn >> 1;
+                const int bmTry = mWgnTry * mSgn;
+                const int mTilesNext = (M + bmTry - 1) / bmTry;
+                if (mTilesNext * (Np / bn) >= xcn || mWgnTry == 1) {
+                    mWgn = mWgnTry;
+                    break;
+                }
+                mWgn = mWgnTry;
+            }
+            bm = mWgn * mSgn;
+        }
+    }
+
+    const int wis = mWgn * nWgn * sgs;
+    const int mPad = ((M + bm - 1) / bm) * bm;
+    const int mTiles = mPad / bm;
+    const int nTiles = Np / bn;
+    const size_t aSlmSize = static_cast<size_t>(bm) * Kp;
+    const size_t cSlmSize = static_cast<size_t>(mWgn * nWgn) * rm * rn * XMX_I8_TM * XMX_I8_TN;
+
+    return q.submit([&](::sycl::handler& cgh) {
+        if (!deps.empty()) cgh.depends_on(deps);
+        auto a_slm = ::sycl::local_accessor<int8_t, 1>(aSlmSize, cgh);
+        auto c_slm = ::sycl::local_accessor<int32_t, 1>(cSlmSize, cgh);
+        auto scale_slm = ::sycl::local_accessor<float, 1>(bn, cgh);
+        auto bias_slm = ::sycl::local_accessor<float, 1>(bn, cgh);
+        cgh.parallel_for(::sycl::nd_range<2>(::sycl::range<2>(mTiles, nTiles * wis),
+                                             ::sycl::range<2>(1, wis)),
+                         [=](::sycl::nd_item<2> item) [[sycl::reqd_sub_group_size(sgs)]] {
+                             conv_minuet_int8_xmx_kernel(item,
+                                                         a_slm,
+                                                         c_slm,
+                                                         scale_slm,
+                                                         bias_slm,
+                                                         in_feats,
+                                                         weights_packed,
+                                                         lut,
+                                                         out_feats,
+                                                         act_abs_max,
+                                                         per_channel_weight_scale,
+                                                         bias,
+                                                         apply_relu,
+                                                         M,
+                                                         K,
+                                                         N,
+                                                         Kp,
+                                                         Np,
+                                                         k_vol,
+                                                         bm,
+                                                         bn,
+                                                         nWgn);
+                         });
+    });
+}
+
+constexpr int32_t kMaxMortonCoord = (1 << 20) - 1;
+
+bool is_relu_activation(const std::string& activation) {
+    return activation == "ReLU" || activation == "relu";
+}
+
+uint32_t round_up_pow2(uint32_t value) {
+    if (value <= 1)
+        return 1;
+
+    --value;
+    value |= value >> 1;
+    value |= value >> 2;
+    value |= value >> 4;
+    value |= value >> 8;
+    value |= value >> 16;
+    return value + 1;
+}
+
+struct BatchFoldConfig {
+    int32_t batch_stride = 0;
+    int32_t max_supported_batch = -1;
+    bool valid = false;
+};
+
+BatchFoldConfig make_batch_fold_config(const sparse_convolution& desc) {
+    OPENVINO_ASSERT(desc.input_spatial_shape.size() == 3, "SparseConvolution SYCL: expected 3D input_spatial_shape");
+    OPENVINO_ASSERT(desc.kernel_size.size() == 3, "SparseConvolution SYCL: expected 3D kernel size");
+
+    auto x_extent = desc.input_spatial_shape[2];
+    if (!desc.subm && desc.output_spatial_shape.size() == 3) {
+        x_extent = std::max(x_extent, desc.output_spatial_shape[2]);
+    }
+    const auto x_radius = desc.kernel_size[2] / 2;
+    OPENVINO_ASSERT(x_extent > 0, "SparseConvolution SYCL: input_spatial_shape.x must be positive");
+    OPENVINO_ASSERT(x_radius >= 0, "SparseConvolution SYCL: invalid kernel radius");
+
+    const auto min_stride = static_cast<uint64_t>(x_extent + x_radius);
+    const auto batch_stride = static_cast<uint64_t>(round_up_pow2(static_cast<uint32_t>(std::max<uint64_t>(1, min_stride))));
+    const auto max_x = static_cast<uint64_t>(x_extent - 1);
+    if (batch_stride == 0 || batch_stride > static_cast<uint64_t>(std::numeric_limits<int32_t>::max()))
+        return {};
+    if (max_x > static_cast<uint64_t>(kMaxMortonCoord) || batch_stride <= max_x)
+        return {};
+
+    const auto max_supported_batch = static_cast<int64_t>((static_cast<int64_t>(kMaxMortonCoord) - static_cast<int64_t>(max_x)) /
+                                                           static_cast<int64_t>(batch_stride));
+    if (max_supported_batch < 0 || max_supported_batch > std::numeric_limits<int32_t>::max())
+        return {};
+
+    return {static_cast<int32_t>(batch_stride), static_cast<int32_t>(max_supported_batch), true};
+}
+
+struct BatchPartition {
+    bool single_batch = false;
+    int32_t single_batch_id = 0;
+    std::vector<int32_t> ordered_point_indices;
+    std::vector<int32_t> batch_of_point;
+    std::vector<size_t> segment_offsets;
+};
+
+struct PreparedSingleBatchCoordsEntry {
+    std::weak_ptr<memory> indices_mem;
+    std::weak_ptr<memory> coords_xyz_mem;
+    void* queue_identity = nullptr;
+    uint64_t generation = 0;
+    size_t num_points = 0;
+    int32_t batch_id = 0;
+};
+
+std::mutex prepared_single_batch_coords_mutex;
+std::unordered_map<const memory*, PreparedSingleBatchCoordsEntry> prepared_single_batch_coords_cache;
+
+// Same-frame SubM rulebook cache. Used by both INT8 and FP16 paths so that
+// downstream SubM layers in a chain (sharing the same rulebook name and the
+// same point count within one inference) can reuse the producer's already-
+// built rulebook and skip Morton sort + LUT construction. Only the producer's
+// per-instance MinuetV2 owns the device buffers; the cache holds raw borrowed
+// pointers and a generation counter to invalidate across frames.
+struct MinuetSubmRulebookCacheEntry {
+    const void* owner = nullptr;       // producer impl, used for ownership-scoped erase
+    uint64_t generation = 0;
+    int points = 0;
+    int kernel_volume = 0;
+    const uint32_t* lut_ok = nullptr;     // for INT8 GEMM (reads pre-sort input space)
+    const uint32_t* lut_sorted = nullptr; // for FP16 chain reuse (reads sort-ordered input space)
+    const int32_t*  qc_xyz = nullptr;     // sorted output coords, reused as output for chain layers
+};
+
+std::mutex minuet_subm_rulebook_cache_mutex;
+std::unordered_map<std::string, MinuetSubmRulebookCacheEntry> minuet_subm_rulebook_cache;
+std::atomic<uint64_t> sparse_inference_generation{0};
+
+bool find_minuet_subm_rulebook_cache(const std::string& rulebook,
+                                     uint64_t generation,
+                                     int points,
+                                     int kernel_volume,
+                                     MinuetSubmRulebookCacheEntry& out) {
+    if (rulebook.empty() || generation == 0 || points <= 0 || kernel_volume <= 0)
+        return false;
+
+    const std::lock_guard<std::mutex> lock(minuet_subm_rulebook_cache_mutex);
+    auto it = minuet_subm_rulebook_cache.find(rulebook);
+    if (it == minuet_subm_rulebook_cache.end())
+        return false;
+
+    const auto& entry = it->second;
+    if (entry.generation == generation &&
+        entry.points == points &&
+        entry.kernel_volume == kernel_volume &&
+        entry.lut_ok != nullptr) {
+        out = entry;
+        return true;
+    }
+    return false;
+}
+
+void update_minuet_subm_rulebook_cache(const std::string& rulebook,
+                                       const void* owner,
+                                       uint64_t generation,
+                                       int points,
+                                       int kernel_volume,
+                                       const uint32_t* lut_ok,
+                                       const uint32_t* lut_sorted,
+                                       const int32_t*  qc_xyz) {
+    if (rulebook.empty() || owner == nullptr || generation == 0 || points <= 0 || kernel_volume <= 0 || lut_ok == nullptr)
+        return;
+
+    const std::lock_guard<std::mutex> lock(minuet_subm_rulebook_cache_mutex);
+    auto& entry = minuet_subm_rulebook_cache[rulebook];
+    entry.owner = owner;
+    entry.generation = generation;
+    entry.points = points;
+    entry.kernel_volume = kernel_volume;
+    entry.lut_ok = lut_ok;
+    entry.lut_sorted = lut_sorted;
+    entry.qc_xyz = qc_xyz;
+}
+
+void erase_minuet_subm_rulebook_cache_owner(const void* owner) {
+    if (owner == nullptr)
+        return;
+
+    const std::lock_guard<std::mutex> lock(minuet_subm_rulebook_cache_mutex);
+    for (auto it = minuet_subm_rulebook_cache.begin(); it != minuet_subm_rulebook_cache.end();) {
+        if (it->second.owner == owner) {
+            it = minuet_subm_rulebook_cache.erase(it);
+        } else {
+            ++it;
+        }
+    }
+}
+
+void prune_prepared_single_batch_coords_cache_locked() {
+    constexpr size_t max_entries = 512;
+    for (auto it = prepared_single_batch_coords_cache.begin(); it != prepared_single_batch_coords_cache.end();) {
+        if (it->second.indices_mem.expired() || it->second.coords_xyz_mem.expired()) {
+            it = prepared_single_batch_coords_cache.erase(it);
+        } else {
+            ++it;
+        }
+    }
+    if (prepared_single_batch_coords_cache.size() > max_entries)
+        prepared_single_batch_coords_cache.clear();
+}
+
+memory::ptr find_prepared_single_batch_coords(const memory::ptr& indices_mem,
+                                              void* queue_identity,
+                                              uint64_t generation,
+                                              size_t num_points,
+                                              int32_t& batch_id) {
+    if (!indices_mem || generation == 0)
+        return nullptr;
+
+    const std::lock_guard<std::mutex> lock(prepared_single_batch_coords_mutex);
+    auto it = prepared_single_batch_coords_cache.find(indices_mem.get());
+    if (it == prepared_single_batch_coords_cache.end())
+        return nullptr;
+
+    auto owner_mem = it->second.indices_mem.lock();
+    auto coords_xyz_mem = it->second.coords_xyz_mem.lock();
+    if (!owner_mem || owner_mem.get() != indices_mem.get() || !coords_xyz_mem) {
+        prepared_single_batch_coords_cache.erase(it);
+        return nullptr;
+    }
+
+    if (it->second.queue_identity != queue_identity ||
+        it->second.generation != generation ||
+        it->second.num_points != num_points)
+        return nullptr;
+
+    batch_id = it->second.batch_id;
+    return coords_xyz_mem;
+}
+
+void update_prepared_single_batch_coords(const memory::ptr& indices_mem,
+                                         const memory::ptr& coords_xyz_mem,
+                                         void* queue_identity,
+                                         uint64_t generation,
+                                         size_t num_points,
+                                         int32_t batch_id) {
+    if (!indices_mem || !coords_xyz_mem || generation == 0)
+        return;
+
+    const std::lock_guard<std::mutex> lock(prepared_single_batch_coords_mutex);
+    prune_prepared_single_batch_coords_cache_locked();
+    prepared_single_batch_coords_cache[indices_mem.get()] = {
+        indices_mem,
+        coords_xyz_mem,
+        queue_identity,
+        generation,
+        num_points,
+        batch_id,
+    };
+}
+
+void clear_prepared_single_batch_coords(const memory::ptr& indices_mem) {
+    if (!indices_mem)
+        return;
+
+    const std::lock_guard<std::mutex> lock(prepared_single_batch_coords_mutex);
+    prepared_single_batch_coords_cache.erase(indices_mem.get());
+}
+
+BatchPartition build_batch_partition(const std::vector<int32_t>& batch_ids) {
+    std::map<int32_t, std::vector<int32_t>> by_batch;
+    for (size_t point = 0; point < batch_ids.size(); ++point) {
+        by_batch[batch_ids[point]].push_back(static_cast<int32_t>(point));
+    }
+
+    BatchPartition partition;
+    if (batch_ids.empty()) {
+        partition.segment_offsets = {0};
+        return partition;
+    }
+
+    partition.single_batch = by_batch.size() == 1;
+    if (partition.single_batch)
+        partition.single_batch_id = by_batch.begin()->first;
+
+    partition.segment_offsets.reserve(by_batch.size() + 1);
+    partition.segment_offsets.push_back(0);
+
+    if (partition.single_batch) {
+        partition.segment_offsets.push_back(batch_ids.size());
+        return partition;
+    }
+
+    for (const auto& entry : by_batch) {
+        const auto batch = entry.first;
+        const auto& points = entry.second;
+        partition.ordered_point_indices.insert(partition.ordered_point_indices.end(), points.begin(), points.end());
+        partition.batch_of_point.insert(partition.batch_of_point.end(), points.size(), batch);
+        partition.segment_offsets.push_back(partition.ordered_point_indices.size());
+    }
+
+    return partition;
+}
+
+::sycl::event extract_batch_ids(::sycl::queue& queue,
+                                const int32_t* src_indices,
+                                int32_t* dst_batch_ids,
+                                size_t num_points) {
+    return queue.submit([&](::sycl::handler& cgh) {
+        cgh.parallel_for(::sycl::range<1>(num_points), [=](::sycl::id<1> id) {
+            const auto point = static_cast<size_t>(id[0]);
+            dst_batch_ids[point] = src_indices[point * 4];
+        });
+    });
+}
+
+template <typename T>
+::sycl::event convert_to_f32(::sycl::queue& queue, const T* src, float* dst, size_t count) {
+    return queue.submit([&](::sycl::handler& cgh) {
+        cgh.parallel_for(::sycl::range<1>(count), [=](::sycl::id<1> id) {
+            const auto idx = static_cast<size_t>(id[0]);
+            dst[idx] = static_cast<float>(src[idx]);
+        });
+    });
+}
+
+template <typename TSrc, typename TDst>
+::sycl::event convert_buffer(::sycl::queue& queue, const TSrc* src, TDst* dst, size_t count) {
+    return queue.submit([&](::sycl::handler& cgh) {
+        cgh.parallel_for(::sycl::range<1>(count), [=](::sycl::id<1> id) {
+            const auto idx = static_cast<size_t>(id[0]);
+            dst[idx] = static_cast<TDst>(static_cast<float>(src[idx]));
+        });
+    });
+}
+
+::sycl::event fold_coords_bzyx_to_xyz(::sycl::queue& queue,
+                                      const int32_t* src_indices,
+                                      int32_t* dst_coords,
+                                      size_t num_points,
+                                      int32_t batch_stride) {
+    // Multi-batch fold: prepend batch * batch_stride to axis-0 so different
+    // batches share a single Morton sort. The axis order of the input/output
+    // matches reorder_coords_bzyx_to_xyz_identity.
+    return queue.submit([&](::sycl::handler& cgh) {
+        cgh.parallel_for(::sycl::range<1>(num_points), [=](::sycl::id<1> id) {
+            const auto point = static_cast<size_t>(id[0]);
+            const auto src_offset = point * 4;
+            const auto dst_offset = point * 3;
+            const auto batch = src_indices[src_offset + 0];
+            const auto axis0 = src_indices[src_offset + 1];
+            const auto axis1 = src_indices[src_offset + 2];
+            const auto axis2 = src_indices[src_offset + 3];
+            dst_coords[dst_offset + 0] = batch * batch_stride + axis0;
+            dst_coords[dst_offset + 1] = axis1;
+            dst_coords[dst_offset + 2] = axis2;
+        });
+    });
+}
+
+::sycl::event reorder_coords_bzyx_to_xyz_identity(::sycl::queue& queue,
+                                                  const int32_t* src_indices,
+                                                  int32_t* dst_coords,
+                                                  size_t num_points) {
+    // Strip the batch slot. The SparseConvolution coord stream is
+    // [batch, axis0, axis1, axis2]; downstream (Minuet) treats them as XYZ.
+    // The wrapper passes kernel_size/stride/oss attributes in the same axis
+    // order (axis0, axis1, axis2) so the convolution math stays consistent.
+    return queue.submit([&](::sycl::handler& cgh) {
+        cgh.parallel_for(::sycl::range<1>(num_points), [=](::sycl::id<1> id) {
+            const auto point = static_cast<size_t>(id[0]);
+            const auto src_offset = point * 4;
+            const auto dst_offset = point * 3;
+            dst_coords[dst_offset + 0] = src_indices[src_offset + 1];
+            dst_coords[dst_offset + 1] = src_indices[src_offset + 2];
+            dst_coords[dst_offset + 2] = src_indices[src_offset + 3];
+        });
+    });
+}
+
+::sycl::event reorder_coords_bzyx_to_xyz(::sycl::queue& queue,
+                                         const int32_t* src_indices,
+                                         const int32_t* ordered_point_indices,
+                                         int32_t* dst_coords,
+                                         size_t num_points) {
+    return queue.submit([&](::sycl::handler& cgh) {
+        cgh.parallel_for(::sycl::range<1>(num_points), [=](::sycl::id<1> id) {
+            const auto ordered_point = static_cast<size_t>(id[0]);
+            const auto original_point = static_cast<size_t>(ordered_point_indices[ordered_point]);
+            const auto src_offset = original_point * 4;
+            const auto dst_offset = ordered_point * 3;
+            dst_coords[dst_offset + 0] = src_indices[src_offset + 1];
+            dst_coords[dst_offset + 1] = src_indices[src_offset + 2];
+            dst_coords[dst_offset + 2] = src_indices[src_offset + 3];
+        });
+    });
+}
+
+template <typename T>
+::sycl::event reorder_features(::sycl::queue& queue,
+                               const T* src_features,
+                               const int32_t* ordered_point_indices,
+                               T* dst_features,
+                               size_t num_points,
+                               size_t channels) {
+    const auto work_items = num_points * channels;
+    return queue.submit([&](::sycl::handler& cgh) {
+        cgh.parallel_for(::sycl::range<1>(work_items), [=](::sycl::id<1> id) {
+            const auto linear = static_cast<size_t>(id[0]);
+            const auto ordered_point = linear / channels;
+            const auto channel = linear % channels;
+            const auto original_point = static_cast<size_t>(ordered_point_indices[ordered_point]);
+            dst_features[linear] = src_features[original_point * channels + channel];
+        });
+    });
+}
+
+::sycl::event pack_output_indices(::sycl::queue& queue,
+                                  const int32_t* src_coords,
+                                  const int32_t* batch_of_point,
+                                  int32_t* dst_indices,
+                                  size_t num_points) {
+    // src_coords: [axis0, axis1, axis2] per point (Minuet-side order).
+    // dst_indices: [batch, axis0, axis1, axis2] (OV layout, batch slot first).
+    return queue.submit([&](::sycl::handler& cgh) {
+        cgh.parallel_for(::sycl::range<1>(num_points), [=](::sycl::id<1> id) {
+            const auto point = static_cast<size_t>(id[0]);
+            const auto src_offset = point * 3;
+            const auto dst_offset = point * 4;
+            dst_indices[dst_offset + 0] = batch_of_point[point];
+            dst_indices[dst_offset + 1] = src_coords[src_offset + 0];
+            dst_indices[dst_offset + 2] = src_coords[src_offset + 1];
+            dst_indices[dst_offset + 3] = src_coords[src_offset + 2];
+        });
+    });
+}
+
+::sycl::event pack_output_indices_single_batch(::sycl::queue& queue,
+                                               const int32_t* src_coords,
+                                               int32_t batch_id,
+                                               int32_t* dst_indices,
+                                               size_t num_points) {
+    return queue.submit([&](::sycl::handler& cgh) {
+        cgh.parallel_for(::sycl::range<1>(num_points), [=](::sycl::id<1> id) {
+            const auto point = static_cast<size_t>(id[0]);
+            const auto src_offset = point * 3;
+            const auto dst_offset = point * 4;
+            dst_indices[dst_offset + 0] = batch_id;
+            dst_indices[dst_offset + 1] = src_coords[src_offset + 0];
+            dst_indices[dst_offset + 2] = src_coords[src_offset + 1];
+            dst_indices[dst_offset + 3] = src_coords[src_offset + 2];
+        });
+    });
+}
+
+::sycl::event unfold_output_indices_xyz_to_bzyx(::sycl::queue& queue,
+                                                const int32_t* src_coords,
+                                                int32_t* dst_indices,
+                                                size_t num_points,
+                                                int32_t batch_stride) {
+    return queue.submit([&](::sycl::handler& cgh) {
+        cgh.parallel_for(::sycl::range<1>(num_points), [=](::sycl::id<1> id) {
+            const auto point = static_cast<size_t>(id[0]);
+            const auto src_offset = point * 3;
+            const auto dst_offset = point * 4;
+            const auto folded_axis0 = src_coords[src_offset + 0];
+            const auto batch = folded_axis0 / batch_stride;
+            const auto axis0 = folded_axis0 - batch * batch_stride;
+            dst_indices[dst_offset + 0] = batch;
+            dst_indices[dst_offset + 1] = axis0;
+            dst_indices[dst_offset + 2] = src_coords[src_offset + 1];
+            dst_indices[dst_offset + 3] = src_coords[src_offset + 2];
+        });
+    });
+}
