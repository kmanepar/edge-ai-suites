+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#include "openvino/op/sparse_to_dense.hpp"
+
+#include <algorithm>
+#include <array>
+#include <limits>
+#include <optional>
+
+#include "itt.hpp"
+#include "openvino/core/type/float16.hpp"
+#include "openvino/op/constant.hpp"
+#include "openvino/reference/sparse_to_dense.hpp"
+
+namespace {
+
+std::vector<int64_t> to_i64_vector(const ov::Tensor& tensor) {
+    const auto count = ov::shape_size(tensor.get_shape());
+    std::vector<int64_t> values(count);
+
+    switch (tensor.get_element_type()) {
+    case ov::element::Type_t::i32: {
+        const auto* src = tensor.data<const int32_t>();
+        for (size_t i = 0; i < count; ++i)
+            values[i] = static_cast<int64_t>(src[i]);
+        break;
+    }
+    case ov::element::Type_t::i64: {
+        const auto* src = tensor.data<const int64_t>();
+        std::copy(src, src + count, values.begin());
+        break;
+    }
+    case ov::element::Type_t::u32: {
+        const auto* src = tensor.data<const uint32_t>();
+        for (size_t i = 0; i < count; ++i)
+            values[i] = static_cast<int64_t>(src[i]);
+        break;
+    }
+    case ov::element::Type_t::u64: {
+        const auto* src = tensor.data<const uint64_t>();
+        for (size_t i = 0; i < count; ++i) {
+            if (src[i] > static_cast<uint64_t>(std::numeric_limits<int64_t>::max())) {
+                values.clear();
+                return values;
+            }
+            values[i] = static_cast<int64_t>(src[i]);
+        }
+        break;
+    }
+    default:
+        values.clear();
+        break;
+    }
+
+    return values;
+}
+
+template <typename T>
+void fill_zero(ov::Tensor& output) {
+    auto* dst = output.data<T>();
+    std::fill(dst, dst + ov::shape_size(output.get_shape()), T{0});
+}
+
+std::vector<int64_t> constant_to_i64_vector(const std::shared_ptr<ov::Node>& node) {
+    const auto constant = ov::as_type_ptr<ov::op::v0::Constant>(node);
+    if (!constant)
+        return {};
+    return constant->cast_vector<int64_t>();
+}
+
+}  // namespace
+
+namespace ov {
+namespace op {
+namespace v15 {
+
+SparseToDense::SparseToDense(const OutputVector& inputs,
+                             std::vector<int64_t> spatial_shape,
+                             int64_t batch_size,
+                             bool channels_first,
+                             bool flatten_output)
+    : Op(inputs),
+      m_spatial_shape(std::move(spatial_shape)),
+      m_batch_size(batch_size),
+      m_channels_first(channels_first),
+      m_flatten_output(flatten_output) {
+    constructor_validate_and_infer_types();
+}
+
+bool SparseToDense::visit_attributes(AttributeVisitor& visitor) {
+    visitor.on_attribute("spatial_shape", m_spatial_shape);
+    visitor.on_attribute("batch_size", m_batch_size);
+    visitor.on_attribute("channels_first", m_channels_first);
+    visitor.on_attribute("flatten_output", m_flatten_output);
+    visitor.on_attribute("fuse_permute_reshape", m_flatten_output);
+    return true;
+}
+
+void SparseToDense::validate_and_infer_types() {
+    NODE_VALIDATION_CHECK(this,
+                          get_input_size() == 2 || get_input_size() == 4,
+                          "SparseToDense expects 2 or 4 inputs: features, indices[, spatial_shape, batch_size]. Got: ",
+                          get_input_size());
+
+    const auto features_et = get_input_element_type(0);
+    const auto indices_et = get_input_element_type(1);
+
+    NODE_VALIDATION_CHECK(this,
+                          features_et.is_real(),
+                          "Input 0 (features) must be a floating-point tensor. Got: ",
+                          features_et);
+    NODE_VALIDATION_CHECK(this,
+                          indices_et.is_integral_number(),
+                          "Input 1 (indices) must be an integer tensor. Got: ",
+                          indices_et);
+
+    const auto features_ps = get_input_partial_shape(0);
+    const auto indices_ps = get_input_partial_shape(1);
+
+    NODE_VALIDATION_CHECK(this,
+                          features_ps.rank().compatible(2),
+                          "Input 0 (features) rank must be compatible with 2 [N, C]. Got: ",
+                          features_ps);
+    NODE_VALIDATION_CHECK(this,
+                          indices_ps.rank().compatible(2),
+                          "Input 1 (indices) rank must be compatible with 2 [N, 4]. Got: ",
+                          indices_ps);
+    if (indices_ps.rank().is_static()) {
+        NODE_VALIDATION_CHECK(this,
+                              indices_ps[1].compatible(4),
+                              "Input 1 (indices) second dimension must be 4 [batch, z, y, x]. Got: ",
+                              indices_ps);
+    }
+
+    if (features_ps.rank().is_static() && indices_ps.rank().is_static()) {
+        NODE_VALIDATION_CHECK(this,
+                              features_ps[0].compatible(indices_ps[0]),
+                              "Input 0 (features) and input 1 (indices) must agree on the number of sparse points. Got: ",
+                              features_ps,
+                              " and ",
+                              indices_ps);
+    }
+
+    std::vector<int64_t> spatial_shape = m_spatial_shape;
+    std::optional<int64_t> batch_size;
+    if (get_input_size() == 2) {
+        batch_size = m_batch_size;
+    } else {
+        const auto spatial_shape_et = get_input_element_type(2);
+        const auto batch_size_et = get_input_element_type(3);
+        NODE_VALIDATION_CHECK(this,
+                              spatial_shape_et.is_integral_number(),
+                              "Input 2 (spatial_shape) must be an integer tensor. Got: ",
+                              spatial_shape_et);
+        NODE_VALIDATION_CHECK(this,
+                              batch_size_et.is_integral_number(),
+                              "Input 3 (batch_size) must be an integer tensor. Got: ",
+                              batch_size_et);
+
+        const auto spatial_shape_ps = get_input_partial_shape(2);
+        NODE_VALIDATION_CHECK(this,
+                              spatial_shape_ps.rank().compatible(1),
+                              "Input 2 (spatial_shape) rank must be compatible with 1 [3]. Got: ",
+                              spatial_shape_ps);
+        if (spatial_shape_ps.rank().is_static()) {
+            NODE_VALIDATION_CHECK(this,
+                                  spatial_shape_ps[0].compatible(3),
+                                  "Input 2 (spatial_shape) length must be 3 [Z, Y, X]. Got: ",
+                                  spatial_shape_ps);
+        }
+
+        const auto batch_size_ps = get_input_partial_shape(3);
+        NODE_VALIDATION_CHECK(this,
+                              batch_size_ps.rank().compatible(0) || batch_size_ps.rank().compatible(1),
+                              "Input 3 (batch_size) must be scalar or rank-1 [1]. Got: ",
+                              batch_size_ps);
+        if (batch_size_ps.rank().is_static() && batch_size_ps.rank().get_length() == 1) {
+            NODE_VALIDATION_CHECK(this,
+                                  batch_size_ps[0].compatible(1),
+                                  "Input 3 (batch_size) rank-1 input must have length 1. Got: ",
+                                  batch_size_ps);
+        }
+
+        const auto spatial_shape_const = constant_to_i64_vector(get_input_node_shared_ptr(2));
+        if (!spatial_shape_const.empty())
+            spatial_shape = spatial_shape_const;
+
+        const auto batch_size_const = constant_to_i64_vector(get_input_node_shared_ptr(3));
+        if (!batch_size_const.empty())
+            batch_size = batch_size_const[0];
+    }
+
+    if (get_input_size() == 2 || !spatial_shape.empty()) {
+        NODE_VALIDATION_CHECK(this,
+                              spatial_shape.size() == 3,
+                              "SparseToDense spatial_shape must contain exactly 3 elements. Got: ",
+                              spatial_shape.size());
+    }
+
+    if (batch_size.has_value()) {
+        NODE_VALIDATION_CHECK(this,
+                              *batch_size > 0,
+                              "SparseToDense batch_size must be positive. Got: ",
+                              *batch_size);
+    }
+
+    NODE_VALIDATION_CHECK(this,
+                          !m_flatten_output || m_channels_first,
+                          "SparseToDense flatten_output=true currently requires channels_first=true.");
+
+    ov::Dimension channels = ov::Dimension::dynamic();
+    if (features_ps.rank().is_static())
+        channels = features_ps[1];
+
+    PartialShape output_shape;
+    if (channels.is_static() && spatial_shape.size() == 3 && batch_size.has_value() && *batch_size > 0) {
+        const auto B = *batch_size;
+        const auto C = channels.get_length();
+        const auto Z = spatial_shape[0];
+        const auto Y = spatial_shape[1];
+        const auto X = spatial_shape[2];
+        if (m_flatten_output) {
+            output_shape = PartialShape{B, C * X, Z, Y};
+        } else if (m_channels_first) {
+            output_shape = PartialShape{B, C, Z, Y, X};
+        } else {
+            output_shape = PartialShape{B, Z, Y, X, C};
+        }
+    } else {
+        if (m_flatten_output) {
+            output_shape = PartialShape{ov::Dimension::dynamic(),
+                                        ov::Dimension::dynamic(),
+                                        ov::Dimension::dynamic(),
+                                        ov::Dimension::dynamic()};
+        } else {
+            const auto dyn = ov::Dimension::dynamic();
+            output_shape = m_channels_first ? PartialShape{dyn, channels, dyn, dyn, dyn}
+                                            : PartialShape{dyn, dyn, dyn, dyn, channels};
+        }
+    }
+    set_output_type(0, features_et, output_shape);
+}
+
+std::shared_ptr<Node> SparseToDense::clone_with_new_inputs(const OutputVector& new_args) const {
+    check_new_args_count(this, new_args);
+    return std::make_shared<SparseToDense>(new_args, m_spatial_shape, m_batch_size, m_channels_first, m_flatten_output);
+}
+
+bool SparseToDense::evaluate(TensorVector& outputs, const TensorVector& inputs) const {
+    OV_OP_SCOPE(v15_SparseToDense_evaluate);
+    OPENVINO_ASSERT(outputs.size() == 1);
+    OPENVINO_ASSERT(inputs.size() == 2 || inputs.size() == 4);
+
+    const auto feature_shape = inputs[0].get_shape();
+    if (feature_shape.size() != 2)
+        return false;
+
+    const auto num_points = feature_shape[0];
+    const auto channels = feature_shape[1];
+    const auto indices_values = to_i64_vector(inputs[1]);
+
+    auto spatial_shape = m_spatial_shape;
+    auto batch_size = m_batch_size;
+    if (inputs.size() == 4) {
+        spatial_shape = to_i64_vector(inputs[2]);
+        const auto batch_values = to_i64_vector(inputs[3]);
+        if (batch_values.empty())
+            return false;
+        batch_size = batch_values[0];
+    }
+
+    if (indices_values.size() != num_points * 4 || spatial_shape.size() != 3 || batch_size <= 0)
+        return false;
+
+    ov::Shape output_shape;
+    if (!ov::reference::compute_sparse_to_dense_output_shape({{spatial_shape[0], spatial_shape[1], spatial_shape[2]}},
+                                                             batch_size,
+                                                             channels,
+                                                             m_channels_first,
+                                                             m_flatten_output,
+                                                             output_shape)) {
+        return false;
+    }
+
+    outputs[0].set_shape(output_shape);
+
+    switch (outputs[0].get_element_type()) {
+    case element::Type_t::f32:
+        fill_zero<float>(outputs[0]);
+        return ov::reference::sparse_to_dense<float>(inputs[0].data<const float>(),
+                                                     num_points,
+                                                     channels,
+                                                     indices_values.data(),
+                                                     4,
+                                                     {{spatial_shape[0], spatial_shape[1], spatial_shape[2]}},
+                                                     batch_size,
+                                                     m_channels_first,
+                                                     m_flatten_output,
+                                                     outputs[0].data<float>());
+    case element::Type_t::f16:
+        fill_zero<ov::float16>(outputs[0]);
+        return ov::reference::sparse_to_dense<ov::float16>(inputs[0].data<const ov::float16>(),
+                                                           num_points,
+                                                           channels,
+                                                           indices_values.data(),
+                                                           4,
+                                                           {{spatial_shape[0], spatial_shape[1], spatial_shape[2]}},
+                                                           batch_size,
+                                                           m_channels_first,
+                                                           m_flatten_output,
+                                                           outputs[0].data<ov::float16>());
+    default:
+        return false;
+    }
+}
+
+bool SparseToDense::has_evaluate() const {
+    OV_OP_SCOPE(v15_SparseToDense_has_evaluate);
+    const auto features_et = get_input_element_type(0);
+    if (get_input_size() != 2 && get_input_size() != 4)
+        return false;
+    if ((features_et != element::f16 && features_et != element::f32) || !get_input_element_type(1).is_integral_number())
+        return false;
+    if (get_input_size() == 4)
+        return get_input_element_type(2).is_integral_number() && get_input_element_type(3).is_integral_number();
+    return true;
+}
+
+const std::vector<int64_t>& SparseToDense::get_spatial_shape() const {
+    return m_spatial_shape;
+}
+
+void SparseToDense::set_spatial_shape(const std::vector<int64_t>& value) {
+    m_spatial_shape = value;
+}
+
+int64_t SparseToDense::get_batch_size() const {
+    return m_batch_size;
+}
+
+void SparseToDense::set_batch_size(int64_t value) {
+    m_batch_size = value;
+}
+
+bool SparseToDense::get_channels_first() const {
+    return m_channels_first;
+}
+
+void SparseToDense::set_channels_first(bool value) {
+    m_channels_first = value;
+}
+
+bool SparseToDense::get_flatten_output() const {
+    return m_flatten_output;
+}
+
+void SparseToDense::set_flatten_output(bool value) {
+    m_flatten_output = value;
+}
+
+bool SparseToDense::get_fuse_permute_reshape() const {
+    return m_flatten_output;
+}
+
+void SparseToDense::set_fuse_permute_reshape(bool value) {
+    m_flatten_output = value;
+}
