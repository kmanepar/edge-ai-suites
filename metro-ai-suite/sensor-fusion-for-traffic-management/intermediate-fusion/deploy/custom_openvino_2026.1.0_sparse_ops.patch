new file mode 100644
index 0000000000..8c3f71d3ec
--- /dev/null
+++ b/src/plugins/intel_gpu/src/graph/impls/cpu/sparse_convolution.cpp
@@ -0,0 +1,314 @@
+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#include "impls/cpu/cpu_impl_helpers.hpp"
+#include "register.hpp"
+#include "registry/implementation_map.hpp"
+#include "sparse_convolution_inst.h"
+
+#include "openvino/reference/sparse_convolution.hpp"
+
+#include <algorithm>
+#include <vector>
+
+namespace cldnn {
+namespace cpu {
+
+namespace {
+
+std::array<int64_t, 3> to_array3(const std::vector<int64_t>& values) {
+    OPENVINO_ASSERT(values.size() == 3, "SparseConvolution expects 3D attributes");
+    return {values[0], values[1], values[2]};
+}
+
+bool is_relu_activation(const std::string& activation) {
+    return activation == "ReLU" || activation == "relu";
+}
+
+std::vector<int64_t> read_i64_vector(memory::ptr mem, const stream& stream) {
+    const auto count = mem->get_layout().count();
+    std::vector<int64_t> values(count);
+
+    switch (mem->get_layout().data_type) {
+    case data_types::i32: {
+        mem_lock<int32_t, mem_lock_type::read> lock(mem, stream);
+        for (size_t i = 0; i < count; ++i)
+            values[i] = static_cast<int64_t>(lock.data()[i]);
+        break;
+    }
+    case data_types::i64: {
+        mem_lock<int64_t, mem_lock_type::read> lock(mem, stream);
+        for (size_t i = 0; i < count; ++i)
+            values[i] = lock.data()[i];
+        break;
+    }
+    case data_types::u32: {
+        mem_lock<uint32_t, mem_lock_type::read> lock(mem, stream);
+        for (size_t i = 0; i < count; ++i)
+            values[i] = static_cast<int64_t>(lock.data()[i]);
+        break;
+    }
+    case data_types::u64: {
+        mem_lock<uint64_t, mem_lock_type::read> lock(mem, stream);
+        for (size_t i = 0; i < count; ++i)
+            values[i] = static_cast<int64_t>(lock.data()[i]);
+        break;
+    }
+    default:
+        OPENVINO_THROW("SparseConvolution supports only i32/i64/u32/u64 metadata inputs");
+    }
+
+    return values;
+}
+
+void write_i64_vector(memory::ptr mem, stream& stream, const std::vector<int64_t>& values) {
+    OPENVINO_ASSERT(mem->get_layout().count() == values.size(),
+                    "SparseConvolution output buffer size mismatch: expected ",
+                    mem->get_layout().count(),
+                    ", got ",
+                    values.size());
+
+    switch (mem->get_layout().data_type) {
+    case data_types::i32: {
+        mem_lock<int32_t, mem_lock_type::write> lock(mem, stream);
+        for (size_t i = 0; i < values.size(); ++i)
+            lock.data()[i] = static_cast<int32_t>(values[i]);
+        break;
+    }
+    case data_types::i64: {
+        mem_lock<int64_t, mem_lock_type::write> lock(mem, stream);
+        for (size_t i = 0; i < values.size(); ++i)
+            lock.data()[i] = values[i];
+        break;
+    }
+    case data_types::u32: {
+        mem_lock<uint32_t, mem_lock_type::write> lock(mem, stream);
+        for (size_t i = 0; i < values.size(); ++i)
+            lock.data()[i] = static_cast<uint32_t>(values[i]);
+        break;
+    }
+    case data_types::u64: {
+        mem_lock<uint64_t, mem_lock_type::write> lock(mem, stream);
+        for (size_t i = 0; i < values.size(); ++i)
+            lock.data()[i] = static_cast<uint64_t>(values[i]);
+        break;
+    }
+    default:
+        OPENVINO_THROW("SparseConvolution supports only i32/i64/u32/u64 metadata outputs");
+    }
+}
+
+template <typename T>
+bool execute_sparse_convolution(memory::ptr feature_mem,
+                           memory::ptr weight_mem,
+                           memory::ptr bias_mem,
+                           memory::ptr out_feature_mem,
+                           const std::vector<int64_t>& input_indices,
+                           memory::ptr out_index_mem,
+                           const sparse_convolution& primitive,
+                           stream& stream) {
+    const auto feature_shape = feature_mem->get_layout().get_shape();
+    const auto weight_shape = weight_mem->get_layout().get_shape();
+    const auto bias_shape = bias_mem->get_layout().get_shape();
+
+    OPENVINO_ASSERT(feature_shape.size() == 2, "SparseConvolution expects the feature input to be rank-2 at execution time");
+    OPENVINO_ASSERT(weight_shape.size() == 3, "SparseConvolution expects the weight input to be rank-3 at execution time");
+    OPENVINO_ASSERT(bias_shape.size() == 1, "SparseConvolution expects the bias input to be rank-1 at execution time");
+    OPENVINO_ASSERT(input_indices.size() == feature_shape[0] * 4,
+                    "SparseConvolution indices input size mismatch: expected ",
+                    feature_shape[0] * 4,
+                    ", got ",
+                    input_indices.size());
+    OPENVINO_ASSERT(weight_shape[1] == feature_shape[1],
+                    "SparseConvolution weight/input channel mismatch: expected ",
+                    feature_shape[1],
+                    ", got ",
+                    weight_shape[1]);
+    OPENVINO_ASSERT(bias_shape[0] == weight_shape[2],
+                    "SparseConvolution bias/output channel mismatch: expected ",
+                    weight_shape[2],
+                    ", got ",
+                    bias_shape[0]);
+
+    ov::reference::SparseConvolutionMetadata metadata;
+    std::array<int64_t, 3> explicit_oss = {0, 0, 0};
+    if (primitive.output_spatial_shape.size() == 3) {
+        explicit_oss = to_array3(primitive.output_spatial_shape);
+    }
+
+    OPENVINO_ASSERT(ov::reference::compute_sparse_convolution_metadata(input_indices.data(),
+                                                                  input_indices.size() / 4,
+                                                                  4,
+                                                                  to_array3(primitive.input_spatial_shape),
+                                                                  to_array3(primitive.kernel_size),
+                                                                  to_array3(primitive.stride),
+                                                                  to_array3(primitive.padding),
+                                                                  to_array3(primitive.dilation),
+                                                                  primitive.subm,
+                                                                  metadata,
+                                                                  explicit_oss),
+                    "SparseConvolution metadata computation failed for the provided runtime inputs");
+
+    const ov::Shape expected_out_feature_shape{metadata.num_points(), weight_shape[2]};
+    OPENVINO_ASSERT(out_feature_mem->get_layout().get_shape() == expected_out_feature_shape,
+                    "SparseConvolution output feature layout mismatch: expected [",
+                    metadata.num_points(),
+                    ", ",
+                    weight_shape[2],
+                    "], got ",
+                    out_feature_mem->get_layout().get_shape());
+    OPENVINO_ASSERT(out_index_mem->get_layout().count() == metadata.out_indices.size(),
+                    "SparseConvolution output index layout mismatch: expected ",
+                    metadata.out_indices.size(),
+                    ", got ",
+                    out_index_mem->get_layout().count());
+
+    mem_lock<const T, mem_lock_type::read> feature_lock(feature_mem, stream);
+    mem_lock<const T, mem_lock_type::read> weight_lock(weight_mem, stream);
+    mem_lock<const T, mem_lock_type::read> bias_lock(bias_mem, stream);
+    mem_lock<T, mem_lock_type::write> output_lock(out_feature_mem, stream);
+
+    const auto success = ov::reference::sparse_convolution<T>(feature_lock.data(),
+                                                         feature_shape[0],
+                                                         feature_shape[1],
+                                                         input_indices.data(),
+                                                         4,
+                                                         weight_lock.data(),
+                                                         weight_shape[2],
+                                                         bias_lock.data(),
+                                                         to_array3(primitive.input_spatial_shape),
+                                                         to_array3(primitive.kernel_size),
+                                                         to_array3(primitive.stride),
+                                                         to_array3(primitive.padding),
+                                                         to_array3(primitive.dilation),
+                                                         primitive.subm,
+                                                         metadata,
+                                                         output_lock.data(),
+                                                         explicit_oss,
+                                                         is_relu_activation(primitive.activation));
+    if (!success)
+        return false;
+
+    write_i64_vector(out_index_mem, stream, metadata.out_indices);
+    return true;
+}
+
+}  // namespace
+
+struct sparse_convolution_impl : typed_primitive_impl<sparse_convolution> {
+    using parent = typed_primitive_impl<sparse_convolution>;
+    using parent::parent;
+
+    DECLARE_OBJECT_TYPE_SERIALIZATION(cldnn::cpu::sparse_convolution_impl)
+
+    sparse_convolution_impl() : parent("sparse_convolution_cpu_impl") {}
+
+    std::unique_ptr<primitive_impl> clone() const override {
+        return std::make_unique<sparse_convolution_impl>(*this);
+    }
+
+    explicit sparse_convolution_impl(const sparse_convolution_node& outer) {
+        set_node_params(outer);
+    }
+
+    void set_node_params(const program_node& arg) override {
+        OPENVINO_ASSERT(arg.is_type<sparse_convolution>(), "[GPU] Incorrect program_node type");
+    }
+
+    void save(BinaryOutputBuffer& ob) const override {
+        parent::save(ob);
+    }
+
+    void load(BinaryInputBuffer& ib) override {
+        parent::load(ib);
+    }
+
+    event::ptr execute_impl(const std::vector<event::ptr>& events, sparse_convolution_inst& instance) override {
+        OV_ITT_SCOPED_TASK(ov::intel_gpu::itt::domains::intel_gpu_plugin, "sparse_convolution::execute_impl");
+        auto& stream = instance.get_network().get_stream();
+
+        const bool pass_through_events =
+            (stream.get_queue_type() == QueueTypes::out_of_order) && instance.all_dependencies_cpu_impl();
+        if (!pass_through_events) {
+            stream.wait_for_events(events);
+        }
+
+        const auto& primitive = *instance.get_node().as<sparse_convolution>().get_primitive();
+        const auto input_indices = read_i64_vector(instance.dep_memory_ptr(1), stream);
+
+        auto feature_mem = instance.dep_memory_ptr(0);
+        auto weight_mem = instance.dep_memory_ptr(2);
+        auto bias_mem = instance.dep_memory_ptr(3);
+        auto out_feature_mem = instance.output_memory_ptr(0);
+        auto out_index_mem = instance.output_memory_ptr(1);
+
+        switch (feature_mem->get_layout().data_type) {
+        case data_types::f32:
+            OPENVINO_ASSERT(execute_sparse_convolution<float>(feature_mem,
+                                                         weight_mem,
+                                                         bias_mem,
+                                                         out_feature_mem,
+                                                         input_indices,
+                                                         out_index_mem,
+                                                         primitive,
+                                                         stream),
+                            "SparseConvolution CPU execution failed");
+            break;
+        case data_types::f16:
+            OPENVINO_ASSERT(execute_sparse_convolution<ov::float16>(feature_mem,
+                                                               weight_mem,
+                                                               bias_mem,
+                                                               out_feature_mem,
+                                                               input_indices,
+                                                               out_index_mem,
+                                                               primitive,
+                                                               stream),
+                            "SparseConvolution CPU execution failed");
+            break;
+        default:
+            OPENVINO_THROW("SparseConvolution CPU implementation supports only f16/f32 feature tensors");
+        }
+
+        if (pass_through_events) {
+            return stream.group_events(events);
+        }
+
+        return make_output_event(stream, instance.is_output());
+    }
+
+    void init_kernels(const kernels_cache&, const kernel_impl_params&) override {}
+
+    void update(primitive_inst& inst, const kernel_impl_params& impl_param) override {}
+
+    static std::unique_ptr<primitive_impl> create(const sparse_convolution_node& arg,
+                                                  const kernel_impl_params& impl_param) {
+        return std::make_unique<sparse_convolution_impl>();
+    }
+};
+
+namespace detail {
+
+attach_sparse_convolution_impl::attach_sparse_convolution_impl() {
+    const auto formats = {format::bfyx};
+    const auto types = {data_types::f16, data_types::f32};
+
+    implementation_map<sparse_convolution>::add(impl_types::cpu,
+                                            shape_types::static_shape,
+                                            sparse_convolution_impl::create,
+                                            types,
+                                            formats);
+    implementation_map<sparse_convolution>::add(impl_types::cpu,
+                                            shape_types::dynamic_shape,
+                                            sparse_convolution_impl::create,
+                                            types,
+                                            formats);
+}
+
+}  // namespace detail
+
+}  // namespace cpu
+}  // namespace cldnn
+
+BIND_BINARY_BUFFER_WITH_TYPE(cldnn::cpu::sparse_convolution_impl)
+BIND_BINARY_BUFFER_WITH_TYPE(cldnn::sparse_convolution)
